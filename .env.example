# MULTIVERSE TOOLS - .env.local template
# Copy to .env.local and fill in your keys

# AI (OpenRouter) - https://openrouter.ai - free tier available
OPENROUTER_API_KEY=your_openrouter_api_key

# Entertainment (TMDB) - https://developer.themoviedb.org - completely free
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key

# News (GNews) - https://gnews.io - 100 req/day free
NEXT_PUBLIC_GNEWS_API_KEY=your_gnews_api_key

# Background Removal - https://www.remove.bg/api - 50 free/month
REMOVEBG_API_KEY=

# Clerk Auth (optional) - https://clerk.com - free tier
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Local admin access
ADMIN_EMAIL=admin@multiverse.local
ADMIN_PASSWORD=change-this-before-production
ADMIN_SESSION_SECRET=change-this-before-production
# Firebase Admin / Firestore user sync
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Newsletter (EmailJS)
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Binary paths (if not in system PATH)
# FFMPEG_PATH=/usr/bin/ffmpeg
# YTDLP_PATH=/usr/local/bin/yt-dlp
# Cloudinary prompt previews
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_PROMPT_PREVIEW_FOLDER=multiverse/prompt-previews
