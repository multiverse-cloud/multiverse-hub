# MULTIVERSE TOOLS - .env.local template
# Copy to .env.local and fill in your keys

# AI (OpenRouter) - https://openrouter.ai - free tier available
OPENROUTER_API_KEY=your_openrouter_api_key

# Entertainment (TMDB) - https://developer.themoviedb.org - completely free
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key

# News (GNews) - https://gnews.io - 100 req/day free
NEXT_PUBLIC_GNEWS_API_KEY=your_gnews_api_key

# Background Removal - https://www.remove.bg/api - 50 free/month
REMOVEBG_API_KEY=

# Local admin access
ADMIN_EMAIL=admin@multiverse.local
ADMIN_PASSWORD=change-this-before-production
ADMIN_SESSION_SECRET=change-this-before-production

# Newsletter and feedback (EmailJS)
EMAILJS_SERVICE_ID=
EMAILJS_FEEDBACK_TEMPLATE_ID=
# Optional: use a separate template for footer newsletter signups.
EMAILJS_NEWSLETTER_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Binary paths (if not in system PATH)
# FFMPEG_PATH=/usr/bin/ffmpeg
# YTDLP_PATH=/usr/local/bin/yt-dlp
# Cloudinary prompt previews
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_PROMPT_PREVIEW_FOLDER=multiverse/prompt-previews
CLOUDINARY_TEMPLATE_PREVIEW_FOLDER=multiverse/template-previews

# Shared production rate limiting (optional but recommended)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Runtime limits
AI_CONCURRENCY_LIMIT=6
AI_STREAM_CONCURRENCY_LIMIT=4
AI_MAX_REQUEST_BYTES=65536
AI_STREAM_MAX_REQUEST_BYTES=65536
DOWNLOAD_CONCURRENCY_LIMIT=2
DOWNLOAD_INFO_CONCURRENCY_LIMIT=8
DOWNLOAD_MAX_URL_LENGTH=2000
