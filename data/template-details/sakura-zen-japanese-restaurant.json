      "summary": "Main template source file imported from Website Template Hub.",
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"description\" content=\"Sakura Zen - Premium Japanese Cuisine\">\n    <meta name=\"keywords\" content=\"japanese restaurant, sushi, ramen, tempura\">\n    <title>Sakura Zen - Japanese Restaurant</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link\n        href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@600&display=swap\"\n        rel=\"stylesheet\">\n    <link href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\" rel=\"stylesheet\">\n    <style>\n        body {\n            font-family: 'Noto Sans JP', sans-serif;\n            background: #fafaf8;\n        }\n\n        .heading {\n            font-family: 'Noto Serif JP', serif;\n        }\n\n        .zen-accent {\n            color: #c41e3a;\n        }\n\n        .zen-border {\n            border-color: #c41e3a;\n        }\n\n        nav {\n            background: white;\n            border-bottom: 1px solid #e5e5e5;\n        }\n\n        .menu-section {\n            scroll-behavior: smooth;\n        }\n\n        .dish-item {\n            background: white;\n            padding: 1.5rem;\n            border-radius: 8px;\n            border-left: 4px solid #c41e3a;\n            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);\n            transition: all 0.3s;\n        }\n\n        .dish-item:hover {\n            box-shadow: 0 4px 16px rgba(196, 30, 58, 0.15);\n            transform: translateX(4px);\n        }\n\n        .price {\n            font-weight: 700;\n            font-size: 1.1rem;\n            color: #c41e3a;\n        }\n\n        .rice-bg {\n            background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e6 100%);\n        }\n    </style>\n</head>\n\n<body>\n    <!-- Navigation -->\n    <nav class=\"sticky top-0 z-50 bg-white border-b border-gray-200\">\n        <div class=\"max-w-6xl mx-auto px-4 py-4 flex justify-between items-center\">\n            <div class=\"flex items-center gap-2 text-2xl font-bold heading zen-accent\">\n                <i class=\"fas fa-leaf\"></i> SAKURA ZEN\n            </div>\n            <button class=\"md:hidden text-gray-700 text-2xl\" onclick=\"toggleMobileNav()\">\n                <i class=\"fas fa-bars\"></i>\n            </button>\n            <ul class=\"hidden md:flex gap-8 items-center\">\n                <li><a href=\"#about\" class=\"text-gray-900 hover:text-red-600 transition font-semibold\">About</a></li>\n                <li><a href=\"#menu\" class=\"text-gray-900 hover:text-red-600 transition font-semibold\">Menu</a></li>\n                <li><a href=\"#chef\" class=\"text-gray-900 hover:text-red-600 transition font-semibold\">Chef</a></li>\n                <li><a href=\"#contact\" class=\"text-gray-900 hover:text-red-600 transition font-semibold\">Contact</a></li>\n                <li><button onclick=\"openBook()\" class=\"bg-red-600 text-white px-6 py-2 rounded hover:bg-red-700 transition font-semibold\">Reserve</button></li>\n            </ul>\n        </div>\n    </nav>\n    <div id=\"mobileNavMenu\" class=\"hidden md:hidden bg-white border-b border-gray-200 shadow-lg\">\n        <ul class=\"flex flex-col gap-0 py-2\">\n            <li><a href=\"#about\" class=\"text-gray-900 hover:text-red-600 transition font-semibold block py-3 px-4\">About</a></li>\n            <li><a href=\"#menu\" class=\"text-gray-900 hover:text-red-600 transition font-semibold block py-3 px-4\">Menu</a></li>\n            <li><a href=\"#chef\" class=\"text-gray-900 hover:text-red-600 transition font-semibold block py-3 px-4\">Chef</a></li>\n            <li><a href=\"#contact\" class=\"text-gray-900 hover:text-red-600 transition font-semibold block py-3 px-4\">Contact</a></li>\n            <li class=\"px-4 py-2\"><button onclick=\"openBook()\" class=\"bg-red-600 text-white px-6 py-2 rounded hover:bg-red-700 transition font-semibold w-full\">Reserve</button></li>\n        </ul>\n    </div>\n    <script>\n        function toggleMobileNav() { document.getElementById('mobileNavMenu').classList.toggle('hidden'); }\n    </script>\n\n    <!-- Hero -->\n    <section class=\"rice-bg py-24 px-4 text-center\"\n        style=\"background-image: url('https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=1200&h=600&fit=crop'); background-size: cover; background-position: center; background-blend-mode: overlay;\">\n        <h1 class=\"text-6xl md:text-7xl font-bold heading text-gray-900 mb-4\">SAKURA ZEN</h1>\n        <div class=\"flex justify-center gap-2 mb-6\">\n            \n            <p class=\"text-xl text-gray-600\">Authentic Japanese Culinary Art</p>\n            \n        </div>\n        <p class=\"max-w-2xl mx-auto text-gray-600 mb-8 leading-relaxed\">In harmony with nature and tradition, we bring\n            you the essence of Japan's most refined cuisine, prepared with meticulous precision and respect for every\n            ingredient.</p>\n        <button onclick=\"openBook()\"\n            class=\"bg-red-600 text-white px-8 py-3 rounded hover:bg-red-700 transition font-semibold mr-4\">Reserve\n            Now</button>\n        <button onclick=\"document.getElementById('menu').scrollIntoView()\"\n            class=\"border-2 border-red-600 text-red-600 px-8 py-3 rounded hover:bg-red-50 transition font-semibold\">View\n            Menu</button>\n    </section>\n\n    <!-- About -->\n    <section id=\"about\" class=\"py-16 px-4 bg-white\">\n        <div class=\"max-w-4xl mx-auto\">\n            <h2 class=\"text-4xl font-bold heading text-gray-900 text-center mb-12\">About Sakura Zen</h2>\n            <div class=\"grid md:grid-cols-2 gap-12 items-center\">\n                <div>\n                    <p class=\"text-gray-600 mb-4 leading-relaxed\">Sakura Zen is more than a restaurant—it's a sanctuary\n                        where Japanese culinary tradition meets modern sensibility. Our chefs train for over a decade to\n                        master the art of sushi, preparing each piece with ritual precision.</p>\n                    <p class=\"text-gray-600 mb-4 leading-relaxed\">Every ingredient is hand-selected from the finest\n                        suppliers. From the rice milled just right, to the fish delivered fresh daily, we honor the\n                        philosophy of \"shokunin\"—the pursuit of craft mastery.</p>\n                    <p class=\"text-gray-600 leading-relaxed\">Come not just to eat, but to experience a moment of zen in\n                        every bite.</p>\n                </div>\n                <div class=\"text-center\">\n                    <div class=\"bg-red-50 rounded-lg p-8 border-2 border-red-200\">\n                        <i class=\"fas fa-award text-5xl text-red-600 mb-4 block\"></i>\n                        <h3 class=\"text-2xl font-bold text-gray-900 mb-2 heading\">Chef Masaru</h3>\n                        <p class=\"text-gray-600 text-sm\">15+ years training in Tokyo's finest establishments</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Menu -->\n    <section id=\"menu\" class=\"py-16 px-4 bg-gray-50\">\n        <div class=\"max-w-5xl mx-auto\">\n            <h2 class=\"text-4xl font-bold heading text-gray-900 text-center mb-4\">Menu</h2>\n            <p class=\"text-center text-gray-600 mb-12\">Changing seasonally to honor nature's bounty</p>\n\n            <!-- Sushi Section -->\n            <div class=\"menu-section mb-12\">\n                <h3 class=\"text-2xl font-bold heading text-gray-900 mb-6 pb-3 border-b-2 zen-border\">握り寿司 - Nigiri Sushi\n                </h3>\n                <div class=\"space-y-3\">\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Maguro <span\n                                    class=\"text-sm font-normal text-gray-600\">(Tuna)</span></h4>\n                            <span class=\"price\">$6</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Fatty bluefin tuna, butter-soft</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Sake <span\n                                    class=\"text-sm font-normal text-gray-600\">(Salmon)</span></h4>\n                            <span class=\"price\">$5</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Premium Atlantic salmon with delicate sweetness</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Hotate <span\n                                    class=\"text-sm font-normal text-gray-600\">(Scallop)</span></h4>\n                            <span class=\"price\">$8</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Sweet, tender scallop with subtle ocean flavor</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Uni <span\n                                    class=\"text-sm font-normal text-gray-600\">(Sea Urchin)</span></h4>\n                            <span class=\"price\">$12</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Creamy delicacy from pristine waters</p>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Rolls Section -->\n            <div class=\"menu-section mb-12\">\n                <h3 class=\"text-2xl font-bold heading text-gray-900 mb-6 pb-3 border-b-2 zen-border\">巻き物 - Sushi Rolls\n                </h3>\n                <div class=\"space-y-3\">\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">California Roll</h4>\n                            <span class=\"price\">$10</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Crab, avocado, cucumber in inside-out roll</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Dragon Roll</h4>\n                            <span class=\"price\">$16</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Eel and cucumber topped with avocado and wasabi</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Spicy Tuna Roll</h4>\n                            <span class=\"price\">$12</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Tuna with sriracha, jalapeño, and mayo</p>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Hot Dishes Section -->\n            <div class=\"menu-section mb-12\">\n                <h3 class=\"text-2xl font-bold heading text-gray-900 mb-6 pb-3 border-b-2 zen-border\">温かい料理 - Hot Dishes\n                </h3>\n                <div class=\"space-y-3\">\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Tonkotsu Ramen</h4>\n                            <span class=\"price\">$15</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Rich pork bone broth, noodles, chashu, soft egg</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Tempura Assortment</h4>\n                            <span class=\"price\">$18</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Shrimp, vegetables, white fish in light batter</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Chicken Yakitori</h4>\n                            <span class=\"price\">$14</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Grilled chicken skewers with teriyaki glaze</p>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Appetizers -->\n            <div class=\"menu-section\">\n                <h3 class=\"text-2xl font-bold heading text-gray-900 mb-6 pb-3 border-b-2 zen-border\">前菜 - Appetizers\n                </h3>\n                <div class=\"space-y-3\">\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Edamame</h4>\n                            <span class=\"price\">$5</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Boiled soybeans with sea salt</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Gyoza</h4>\n                            <span class=\"price\">$8</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Pork and vegetable dumplings, pan-fried</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Miso Soup</h4>\n                            <span class=\"price\">$4</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Traditional fermented soy broth with tofu</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Chef -->\n    <section id=\"chef\" class=\"py-16 px-4 bg-white\">\n        <div class=\"max-w-4xl mx-auto text-center\">\n            <h2 class=\"text-4xl font-bold heading text-gray-900 mb-4\">The Chef's Philosophy</h2>\n            <div class=\"bg-red-50 rounded-lg p-12 border-l-4 zen-border\">\n                <p class=\"text-gray-700 text-lg leading-relaxed mb-6\">\"In Japanese cuisine, we believe that the soul of\n                    a dish lies not in complexity, but in simplicity and respect for the ingredient. Every grain of\n                    rice, every slice of fish tells a story. Our role as chefs is to listen to that story and present it\n                    truthfully.\"</p>\n                <p class=\"font-bold text-gray-900 heading text-xl\">— Chef Masaru Yamamoto</p>\n                <p class=\"text-gray-600 text-sm mt-2\">Head Chef, Sakura Zen</p>\n            </div>\n        </div>\n    </section>\n\n    <!-- Reviews -->\n    <section class=\"py-16 px-4 bg-gray-50\">\n        <div class=\"max-w-4xl mx-auto\">\n            <h2 class=\"text-4xl font-bold heading text-gray-900 text-center mb-12\">Guest Experiences</h2>\n            <div class=\"grid md:grid-cols-2 gap-6\">\n                <div class=\"bg-white p-6 rounded border-t-4 zen-border\">\n                    <div class=\"flex gap-1 mb-2\">\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                    </div>\n                    <p class=\"text-gray-600 mb-3\">\"The most authentic sushi experience I've had outside Tokyo. Chef\n                        Masaru's hands are true artists.\"</p>\n                    <p class=\"font-bold text-gray-900 text-sm\">Hiroshi Tanaka</p>\n                </div>\n                <div class=\"bg-white p-6 rounded border-t-4 zen-border\">\n                    <div class=\"flex gap-1 mb-2\">\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                    </div>\n                    <p class=\"text-gray-600 mb-3\">\"Serene atmosphere, impeccable service, and every bite is perfect. A\n                        true zen experience.\"</p>\n                    <p class=\"font-bold text-gray-900 text-sm\">Sarah Mitchell</p>\n                </div>\n                <div class=\"bg-white p-6 rounded border-t-4 zen-border\">\n                    <div class=\"flex gap-1 mb-2\">\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                    </div>\n                    <p class=\"text-gray-600 mb-3\">\"Worth every penny. The nigiri melts in your mouth. The chef takes\n                        pride in every piece.\"</p>\n                    <p class=\"font-bold text-gray-900 text-sm\">David Chen</p>\n                </div>\n                <div class=\"bg-white p-6 rounded border-t-4 zen-border\">\n                    <div class=\"flex gap-1 mb-2\">\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                    </div>\n                    <p class=\"text-gray-600 mb-3\">\"A meditation in food. Quiet, elegant, and deeply satisfying. My\n                        favorite sushi spot.\"</p>\n                    <p class=\"font-bold text-gray-900 text-sm\">Lisa Anderson</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Contact & CTA -->\n    <section id=\"contact\" class=\"py-16 px-4 bg-gradient-to-r from-red-600 to-red-700 text-white\">\n        <div class=\"max-w-4xl mx-auto text-center\">\n            <h2 class=\"text-4xl font-bold mb-4 heading\">Visit Sakura Zen</h2>\n            <div class=\"grid md:grid-cols-3 gap-8 mb-8\">\n                <div>\n                    <i class=\"fas fa-map-marker-alt text-3xl mb-2 block\"></i>\n                    <p class=\"font-semibold\">789 Zen Lane</p>\n                    <p class=\"text-red-100\">Harmony City, HC 12345</p>\n                </div>\n                <div>\n                    <i class=\"fas fa-phone text-3xl mb-2 block\"></i>\n                    <p class=\"font-semibold\">+1 (555) 234-5678</p>\n                    <p class=\"text-red-100\">Call for inquiries</p>\n                </div>\n                <div>\n                    <i class=\"fas fa-clock text-3xl mb-2 block\"></i>\n                    <p class=\"font-semibold\">Tue-Sun: 5PM-10PM</p>\n                    <p class=\"text-red-100\">Monday: Closed</p>\n                </div>\n            </div>\n            <button onclick=\"openBook()\"\n                class=\"bg-white text-red-600 px-8 py-3 rounded font-bold hover:bg-gray-100 transition\">Make a\n                Reservation</button>\n        </div>\n    </section>\n\n    <!-- Booking Modal -->\n    <div id=\"bookModal\" class=\"hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4\">\n        <div class=\"bg-white rounded-lg max-w-md w-full p-8\">\n            <h3 class=\"text-2xl font-bold text-gray-900 heading mb-6\">Reserve Your Table</h3>\n            <form onsubmit=\"submitBook(event)\" class=\"space-y-4\">\n                <input type=\"text\" placeholder=\"Name\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-red-600\">\n                <input type=\"email\" placeholder=\"Email\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-red-600\">\n                <input type=\"date\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-red-600\">\n                <input type=\"time\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-red-600\">\n                <input type=\"number\" min=\"1\" max=\"8\" placeholder=\"Number of guests\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-red-600\">\n                <button type=\"submit\"\n                    class=\"w-full bg-red-600 text-white py-2 rounded font-bold hover:bg-red-700\">Reserve</button>\n                <button type=\"button\" onclick=\"closeBook()\"\n                    class=\"w-full border border-gray-300 py-2 rounded font-semibold text-gray-700 hover:bg-gray-50\">Cancel</button>\n            </form>\n        </div>\n    </div>\n\n    <!-- Footer -->\n    <footer class=\"bg-gray-900 text-gray-400 py-8 px-4\">\n        <div class=\"max-w-6xl mx-auto text-center\">\n            <p class=\"mb-2\">&copy; 2024 Sakura Zen. Authentic Japanese Cuisine.</p>\n            <p class=\"text-sm text-gray-500\">Crafted with care and respect for tradition.</p>\n        </div>\n    </footer>\n\n    <script>\n        function openBook() { document.getElementById('bookModal').classList.remove('hidden'); }\n        function closeBook() { document.getElementById('bookModal').classList.add('hidden'); }\n        function submitBook(e) { e.preventDefault(); alert('Reservation confirmed!'); closeBook(); }\n    </script>\n</body>\n\n</html>",
      "primary": true
    }
  ],
  "previewHtml": "<!DOCTYPE html>\n<html lang=\"en\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"description\" content=\"Sakura Zen - Premium Japanese Cuisine\">\n    <meta name=\"keywords\" content=\"japanese restaurant, sushi, ramen, tempura\">\n    <title>Sakura Zen - Japanese Restaurant</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link\n        href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@600&display=swap\"\n        rel=\"stylesheet\">\n    <link href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\" rel=\"stylesheet\">\n    <style>\n        body {\n            font-family: 'Noto Sans JP', sans-serif;\n            background: #fafaf8;\n        }\n\n        .heading {\n            font-family: 'Noto Serif JP', serif;\n        }\n\n        .zen-accent {\n            color: #c41e3a;\n        }\n\n        .zen-border {\n            border-color: #c41e3a;\n        }\n\n        nav {\n            background: white;\n            border-bottom: 1px solid #e5e5e5;\n        }\n\n        .menu-section {\n            scroll-behavior: smooth;\n        }\n\n        .dish-item {\n            background: white;\n            padding: 1.5rem;\n            border-radius: 8px;\n            border-left: 4px solid #c41e3a;\n            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);\n            transition: all 0.3s;\n        }\n\n        .dish-item:hover {\n            box-shadow: 0 4px 16px rgba(196, 30, 58, 0.15);\n            transform: translateX(4px);\n        }\n\n        .price {\n            font-weight: 700;\n            font-size: 1.1rem;\n            color: #c41e3a;\n        }\n\n        .rice-bg {\n            background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e6 100%);\n        }\n    </style>\n</head>\n\n<body>\n    <!-- Navigation -->\n    <nav class=\"sticky top-0 z-50 bg-white border-b border-gray-200\">\n        <div class=\"max-w-6xl mx-auto px-4 py-4 flex justify-between items-center\">\n            <div class=\"flex items-center gap-2 text-2xl font-bold heading zen-accent\">\n                <i class=\"fas fa-leaf\"></i> SAKURA ZEN\n            </div>\n            <button class=\"md:hidden text-gray-700 text-2xl\" onclick=\"toggleMobileNav()\">\n                <i class=\"fas fa-bars\"></i>\n            </button>\n            <ul class=\"hidden md:flex gap-8 items-center\">\n                <li><a href=\"#about\" class=\"text-gray-900 hover:text-red-600 transition font-semibold\">About</a></li>\n                <li><a href=\"#menu\" class=\"text-gray-900 hover:text-red-600 transition font-semibold\">Menu</a></li>\n                <li><a href=\"#chef\" class=\"text-gray-900 hover:text-red-600 transition font-semibold\">Chef</a></li>\n                <li><a href=\"#contact\" class=\"text-gray-900 hover:text-red-600 transition font-semibold\">Contact</a></li>\n                <li><button onclick=\"openBook()\" class=\"bg-red-600 text-white px-6 py-2 rounded hover:bg-red-700 transition font-semibold\">Reserve</button></li>\n            </ul>\n        </div>\n    </nav>\n    <div id=\"mobileNavMenu\" class=\"hidden md:hidden bg-white border-b border-gray-200 shadow-lg\">\n        <ul class=\"flex flex-col gap-0 py-2\">\n            <li><a href=\"#about\" class=\"text-gray-900 hover:text-red-600 transition font-semibold block py-3 px-4\">About</a></li>\n            <li><a href=\"#menu\" class=\"text-gray-900 hover:text-red-600 transition font-semibold block py-3 px-4\">Menu</a></li>\n            <li><a href=\"#chef\" class=\"text-gray-900 hover:text-red-600 transition font-semibold block py-3 px-4\">Chef</a></li>\n            <li><a href=\"#contact\" class=\"text-gray-900 hover:text-red-600 transition font-semibold block py-3 px-4\">Contact</a></li>\n            <li class=\"px-4 py-2\"><button onclick=\"openBook()\" class=\"bg-red-600 text-white px-6 py-2 rounded hover:bg-red-700 transition font-semibold w-full\">Reserve</button></li>\n        </ul>\n    </div>\n    <script>\n        function toggleMobileNav() { document.getElementById('mobileNavMenu').classList.toggle('hidden'); }\n    </script>\n\n    <!-- Hero -->\n    <section class=\"rice-bg py-24 px-4 text-center\"\n        style=\"background-image: url('https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=1200&h=600&fit=crop'); background-size: cover; background-position: center; background-blend-mode: overlay;\">\n        <h1 class=\"text-6xl md:text-7xl font-bold heading text-gray-900 mb-4\">SAKURA ZEN</h1>\n        <div class=\"flex justify-center gap-2 mb-6\">\n            \n            <p class=\"text-xl text-gray-600\">Authentic Japanese Culinary Art</p>\n            \n        </div>\n        <p class=\"max-w-2xl mx-auto text-gray-600 mb-8 leading-relaxed\">In harmony with nature and tradition, we bring\n            you the essence of Japan's most refined cuisine, prepared with meticulous precision and respect for every\n            ingredient.</p>\n        <button onclick=\"openBook()\"\n            class=\"bg-red-600 text-white px-8 py-3 rounded hover:bg-red-700 transition font-semibold mr-4\">Reserve\n            Now</button>\n        <button onclick=\"document.getElementById('menu').scrollIntoView()\"\n            class=\"border-2 border-red-600 text-red-600 px-8 py-3 rounded hover:bg-red-50 transition font-semibold\">View\n            Menu</button>\n    </section>\n\n    <!-- About -->\n    <section id=\"about\" class=\"py-16 px-4 bg-white\">\n        <div class=\"max-w-4xl mx-auto\">\n            <h2 class=\"text-4xl font-bold heading text-gray-900 text-center mb-12\">About Sakura Zen</h2>\n            <div class=\"grid md:grid-cols-2 gap-12 items-center\">\n                <div>\n                    <p class=\"text-gray-600 mb-4 leading-relaxed\">Sakura Zen is more than a restaurant—it's a sanctuary\n                        where Japanese culinary tradition meets modern sensibility. Our chefs train for over a decade to\n                        master the art of sushi, preparing each piece with ritual precision.</p>\n                    <p class=\"text-gray-600 mb-4 leading-relaxed\">Every ingredient is hand-selected from the finest\n                        suppliers. From the rice milled just right, to the fish delivered fresh daily, we honor the\n                        philosophy of \"shokunin\"—the pursuit of craft mastery.</p>\n                    <p class=\"text-gray-600 leading-relaxed\">Come not just to eat, but to experience a moment of zen in\n                        every bite.</p>\n                </div>\n                <div class=\"text-center\">\n                    <div class=\"bg-red-50 rounded-lg p-8 border-2 border-red-200\">\n                        <i class=\"fas fa-award text-5xl text-red-600 mb-4 block\"></i>\n                        <h3 class=\"text-2xl font-bold text-gray-900 mb-2 heading\">Chef Masaru</h3>\n                        <p class=\"text-gray-600 text-sm\">15+ years training in Tokyo's finest establishments</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Menu -->\n    <section id=\"menu\" class=\"py-16 px-4 bg-gray-50\">\n        <div class=\"max-w-5xl mx-auto\">\n            <h2 class=\"text-4xl font-bold heading text-gray-900 text-center mb-4\">Menu</h2>\n            <p class=\"text-center text-gray-600 mb-12\">Changing seasonally to honor nature's bounty</p>\n\n            <!-- Sushi Section -->\n            <div class=\"menu-section mb-12\">\n                <h3 class=\"text-2xl font-bold heading text-gray-900 mb-6 pb-3 border-b-2 zen-border\">握り寿司 - Nigiri Sushi\n                </h3>\n                <div class=\"space-y-3\">\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Maguro <span\n                                    class=\"text-sm font-normal text-gray-600\">(Tuna)</span></h4>\n                            <span class=\"price\">$6</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Fatty bluefin tuna, butter-soft</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Sake <span\n                                    class=\"text-sm font-normal text-gray-600\">(Salmon)</span></h4>\n                            <span class=\"price\">$5</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Premium Atlantic salmon with delicate sweetness</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Hotate <span\n                                    class=\"text-sm font-normal text-gray-600\">(Scallop)</span></h4>\n                            <span class=\"price\">$8</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Sweet, tender scallop with subtle ocean flavor</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Uni <span\n                                    class=\"text-sm font-normal text-gray-600\">(Sea Urchin)</span></h4>\n                            <span class=\"price\">$12</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Creamy delicacy from pristine waters</p>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Rolls Section -->\n            <div class=\"menu-section mb-12\">\n                <h3 class=\"text-2xl font-bold heading text-gray-900 mb-6 pb-3 border-b-2 zen-border\">巻き物 - Sushi Rolls\n                </h3>\n                <div class=\"space-y-3\">\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">California Roll</h4>\n                            <span class=\"price\">$10</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Crab, avocado, cucumber in inside-out roll</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Dragon Roll</h4>\n                            <span class=\"price\">$16</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Eel and cucumber topped with avocado and wasabi</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Spicy Tuna Roll</h4>\n                            <span class=\"price\">$12</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Tuna with sriracha, jalapeño, and mayo</p>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Hot Dishes Section -->\n            <div class=\"menu-section mb-12\">\n                <h3 class=\"text-2xl font-bold heading text-gray-900 mb-6 pb-3 border-b-2 zen-border\">温かい料理 - Hot Dishes\n                </h3>\n                <div class=\"space-y-3\">\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Tonkotsu Ramen</h4>\n                            <span class=\"price\">$15</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Rich pork bone broth, noodles, chashu, soft egg</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Tempura Assortment</h4>\n                            <span class=\"price\">$18</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Shrimp, vegetables, white fish in light batter</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Chicken Yakitori</h4>\n                            <span class=\"price\">$14</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Grilled chicken skewers with teriyaki glaze</p>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Appetizers -->\n            <div class=\"menu-section\">\n                <h3 class=\"text-2xl font-bold heading text-gray-900 mb-6 pb-3 border-b-2 zen-border\">前菜 - Appetizers\n                </h3>\n                <div class=\"space-y-3\">\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Edamame</h4>\n                            <span class=\"price\">$5</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Boiled soybeans with sea salt</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Gyoza</h4>\n                            <span class=\"price\">$8</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Pork and vegetable dumplings, pan-fried</p>\n                    </div>\n                    <div class=\"dish-item\">\n                        <div class=\"flex justify-between items-start mb-2\">\n                            <h4 class=\"text-lg font-bold text-gray-900\">Miso Soup</h4>\n                            <span class=\"price\">$4</span>\n                        </div>\n                        <p class=\"text-gray-600 text-sm\">Traditional fermented soy broth with tofu</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Chef -->\n    <section id=\"chef\" class=\"py-16 px-4 bg-white\">\n        <div class=\"max-w-4xl mx-auto text-center\">\n            <h2 class=\"text-4xl font-bold heading text-gray-900 mb-4\">The Chef's Philosophy</h2>\n            <div class=\"bg-red-50 rounded-lg p-12 border-l-4 zen-border\">\n                <p class=\"text-gray-700 text-lg leading-relaxed mb-6\">\"In Japanese cuisine, we believe that the soul of\n                    a dish lies not in complexity, but in simplicity and respect for the ingredient. Every grain of\n                    rice, every slice of fish tells a story. Our role as chefs is to listen to that story and present it\n                    truthfully.\"</p>\n                <p class=\"font-bold text-gray-900 heading text-xl\">— Chef Masaru Yamamoto</p>\n                <p class=\"text-gray-600 text-sm mt-2\">Head Chef, Sakura Zen</p>\n            </div>\n        </div>\n    </section>\n\n    <!-- Reviews -->\n    <section class=\"py-16 px-4 bg-gray-50\">\n        <div class=\"max-w-4xl mx-auto\">\n            <h2 class=\"text-4xl font-bold heading text-gray-900 text-center mb-12\">Guest Experiences</h2>\n            <div class=\"grid md:grid-cols-2 gap-6\">\n                <div class=\"bg-white p-6 rounded border-t-4 zen-border\">\n                    <div class=\"flex gap-1 mb-2\">\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                    </div>\n                    <p class=\"text-gray-600 mb-3\">\"The most authentic sushi experience I've had outside Tokyo. Chef\n                        Masaru's hands are true artists.\"</p>\n                    <p class=\"font-bold text-gray-900 text-sm\">Hiroshi Tanaka</p>\n                </div>\n                <div class=\"bg-white p-6 rounded border-t-4 zen-border\">\n                    <div class=\"flex gap-1 mb-2\">\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                    </div>\n                    <p class=\"text-gray-600 mb-3\">\"Serene atmosphere, impeccable service, and every bite is perfect. A\n                        true zen experience.\"</p>\n                    <p class=\"font-bold text-gray-900 text-sm\">Sarah Mitchell</p>\n                </div>\n                <div class=\"bg-white p-6 rounded border-t-4 zen-border\">\n                    <div class=\"flex gap-1 mb-2\">\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                    </div>\n                    <p class=\"text-gray-600 mb-3\">\"Worth every penny. The nigiri melts in your mouth. The chef takes\n                        pride in every piece.\"</p>\n                    <p class=\"font-bold text-gray-900 text-sm\">David Chen</p>\n                </div>\n                <div class=\"bg-white p-6 rounded border-t-4 zen-border\">\n                    <div class=\"flex gap-1 mb-2\">\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                        <i class=\"fas fa-star text-yellow-400 text-sm\"></i>\n                    </div>\n                    <p class=\"text-gray-600 mb-3\">\"A meditation in food. Quiet, elegant, and deeply satisfying. My\n                        favorite sushi spot.\"</p>\n                    <p class=\"font-bold text-gray-900 text-sm\">Lisa Anderson</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Contact & CTA -->\n    <section id=\"contact\" class=\"py-16 px-4 bg-gradient-to-r from-red-600 to-red-700 text-white\">\n        <div class=\"max-w-4xl mx-auto text-center\">\n            <h2 class=\"text-4xl font-bold mb-4 heading\">Visit Sakura Zen</h2>\n            <div class=\"grid md:grid-cols-3 gap-8 mb-8\">\n                <div>\n                    <i class=\"fas fa-map-marker-alt text-3xl mb-2 block\"></i>\n                    <p class=\"font-semibold\">789 Zen Lane</p>\n                    <p class=\"text-red-100\">Harmony City, HC 12345</p>\n                </div>\n                <div>\n                    <i class=\"fas fa-phone text-3xl mb-2 block\"></i>\n                    <p class=\"font-semibold\">+1 (555) 234-5678</p>\n                    <p class=\"text-red-100\">Call for inquiries</p>\n                </div>\n                <div>\n                    <i class=\"fas fa-clock text-3xl mb-2 block\"></i>\n                    <p class=\"font-semibold\">Tue-Sun: 5PM-10PM</p>\n                    <p class=\"text-red-100\">Monday: Closed</p>\n                </div>\n            </div>\n            <button onclick=\"openBook()\"\n                class=\"bg-white text-red-600 px-8 py-3 rounded font-bold hover:bg-gray-100 transition\">Make a\n                Reservation</button>\n        </div>\n    </section>\n\n    <!-- Booking Modal -->\n    <div id=\"bookModal\" class=\"hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4\">\n        <div class=\"bg-white rounded-lg max-w-md w-full p-8\">\n            <h3 class=\"text-2xl font-bold text-gray-900 heading mb-6\">Reserve Your Table</h3>\n            <form onsubmit=\"submitBook(event)\" class=\"space-y-4\">\n                <input type=\"text\" placeholder=\"Name\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-red-600\">\n                <input type=\"email\" placeholder=\"Email\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-red-600\">\n                <input type=\"date\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-red-600\">\n                <input type=\"time\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-red-600\">\n                <input type=\"number\" min=\"1\" max=\"8\" placeholder=\"Number of guests\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-red-600\">\n                <button type=\"submit\"\n                    class=\"w-full bg-red-600 text-white py-2 rounded font-bold hover:bg-red-700\">Reserve</button>\n                <button type=\"button\" onclick=\"closeBook()\"\n                    class=\"w-full border border-gray-300 py-2 rounded font-semibold text-gray-700 hover:bg-gray-50\">Cancel</button>\n            </form>\n        </div>\n    </div>\n\n    <!-- Footer -->\n    <footer class=\"bg-gray-900 text-gray-400 py-8 px-4\">\n        <div class=\"max-w-6xl mx-auto text-center\">\n            <p class=\"mb-2\">&copy; 2024 Sakura Zen. Authentic Japanese Cuisine.</p>\n            <p class=\"text-sm text-gray-500\">Crafted with care and respect for tradition.</p>\n        </div>\n    </footer>\n\n    <script>\n        function openBook() { document.getElementById('bookModal').classList.remove('hidden'); }\n        function closeBook() { document.getElementById('bookModal').classList.add('hidden'); }\n        function submitBook(e) { e.preventDefault(); alert('Reservation confirmed!'); closeBook(); }\n    </script>\n</body>\n\n</html>",
