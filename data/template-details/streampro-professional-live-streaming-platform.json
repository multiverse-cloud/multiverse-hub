  "previewHtml": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"description\" content=\"StreamPro - Live streaming and video platform for creators\">\n    <meta name=\"keywords\" content=\"SaaS, streaming, video platform, content creators\">\n    <title>StreamPro - Professional Live Streaming Platform</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Courier+Prime:wght@700&display=swap\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n    <style>\n        * { font-family: 'Plus Jakarta Sans', sans-serif; }\n        h1, h2, h3, h4 { font-weight: 800; letter-spacing: -0.3px; }\n        .gradient-pink { background: linear-gradient(135deg, #ec4899 0%, #f43f5e 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }\n        .live-pulse { animation: livePulse 1.5s ease-in-out infinite; }\n        @keyframes livePulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.1); } }\n        .modal-hidden { display: none; }\n        .modal-hidden.active { display: flex; }\n        .play-btn { width: 80px; height: 80px; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: rgba(255,255,255,0.2); border: 2px solid white; cursor: pointer; transition: all 0.3s; }\n        .play-btn:hover { background: rgba(255,255,255,0.4); transform: scale(1.1); }\n    </style>\n    <!-- Page Loader -->\n    \n</head>\n<body class=\"bg-white\">\n    <header class=\"fixed top-0 w-full bg-white z-50 border-b border-gray-100\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex justify-between items-center\">\n            <div class=\"flex items-center gap-3\">\n                <div class=\"w-10 h-10 bg-gradient-to-r from-pink-600 to-rose-600 rounded-lg flex items-center justify-center\"><i class=\"fas fa-circle text-white\"></i></div>\n                <span class=\"text-xl font-bold text-gray-900\">StreamPro</span>\n            </div>\n            <nav class=\"hidden lg:flex gap-10 items-center\">\n                <a href=\"#features\" class=\"text-gray-700 hover:text-pink-600 font-medium transition\">Features</a>\n                <a href=\"#pricing\" class=\"text-gray-700 hover:text-pink-600 font-medium transition\">Pricing</a>\n                <a href=\"#testimonials\" class=\"text-gray-700 hover:text-pink-600 font-medium transition\">Stories</a>\n                <button onclick=\"openModal()\" class=\"bg-pink-600 text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-pink-700 transition\">Start Streaming</button>\n            </nav>\n            <button id=\"menu-btn\" class=\"lg:hidden text-gray-700\" onclick=\"toggleMenu()\"><i class=\"fas fa-bars text-2xl\"></i></button>\n        </div>\n        <div id=\"menu\" class=\"hidden lg:hidden border-t\">\n            <div class=\"px-4 py-4 space-y-3\">\n                <a href=\"#features\" class=\"block text-gray-700 py-2 hover:text-pink-600\">Features</a>\n                <a href=\"#pricing\" class=\"block text-gray-700 py-2 hover:text-pink-600\">Pricing</a>\n                <a href=\"#testimonials\" class=\"block text-gray-700 py-2 hover:text-pink-600\">Stories</a>\n                <button onclick=\"openModal()\" class=\"w-full bg-pink-600 text-white px-6 py-2.5 rounded-lg\">Start Streaming</button>\n            </div>\n        </div>\n    </header>\n    \n    <section class=\"pt-32 pb-24 px-4 sm:px-6 lg:px-8\">\n        <div class=\"max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center\">\n            <div>\n                <div class=\"inline-block bg-pink-100 text-pink-700 px-4 py-1.5 rounded-full text-sm font-bold mb-6\"><i class=\"fas fa-circle text-red-600 mr-2\"></i> Go Live in Seconds</div>\n                <h1 class=\"text-6xl lg:text-7xl font-bold text-gray-900 leading-tight mb-6\">Stream Like a<br/><span class=\"gradient-pink\">Pro Today</span></h1>\n                <p class=\"text-xl text-gray-600 mb-8\">Professional live streaming for content creators. Ultra-low latency, HD quality, engage with your audience in real-time. No equipment needed.</p>\n                <div class=\"flex flex-col sm:flex-row gap-4\">\n                    <button onclick=\"openModal()\" class=\"bg-pink-600 text-white px-8 py-4 rounded-lg font-bold hover:bg-pink-700 transition shadow-lg\">Start Free</button>\n                    <button class=\"border-2 border-gray-300 text-gray-700 px-8 py-4 rounded-lg font-bold hover:border-pink-600 hover:text-pink-600 transition\">Watch Demo</button>\n                </div>\n            </div>\n            <div class=\"hidden lg:block relative\">\n                <div class=\"bg-gradient-to-br from-pink-200 to-rose-200 rounded-2xl h-96 flex items-center justify-center\">\n                    <div class=\"live-pulse\"><div class=\"play-btn\"><i class=\"fas fa-play text-white text-3xl ml-2\"></i></div></div>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <section id=\"features\" class=\"py-24 px-4 sm:px-6 lg:px-8 bg-gray-50\">\n        <div class=\"max-w-6xl mx-auto\">\n            <h2 class=\"text-5xl font-bold text-center text-gray-900 mb-16\">Everything You Need to Stream</h2>\n            <div class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-8\">\n                <div class=\"bg-white rounded-xl p-8 border border-gray-100 hover:shadow-lg transition\">\n                    <div class=\"w-12 h-12 bg-pink-100 rounded-lg flex items-center justify-center mb-4\"><i class=\"fas fa-video text-pink-600\"></i></div>\n                    <h3 class=\"text-xl font-bold text-gray-900 mb-2\">Ultra Low Latency</h3>\n                    <p class=\"text-gray-600\">Sub-second latency for interactive streaming. Real-time connection with viewers.</p>\n                </div>\n                <div class=\"bg-white rounded-xl p-8 border border-gray-100 hover:shadow-lg transition\">\n                    <div class=\"w-12 h-12 bg-rose-100 rounded-lg flex items-center justify-center mb-4\"><i class=\"fas fa-users text-rose-600\"></i></div>\n                    <h3 class=\"text-xl font-bold text-gray-900 mb-2\">Unlimited Viewers</h3>\n                    <p class=\"text-gray-600\">Stream to thousands of viewers simultaneously without lag.</p>\n                </div>\n                <div class=\"bg-white rounded-xl p-8 border border-gray-100 hover:shadow-lg transition\">\n                    <div class=\"w-12 h-12 bg-pink-100 rounded-lg flex items-center justify-center mb-4\"><i class=\"fas fa-comments text-pink-600\"></i></div>\n                    <h3 class=\"text-xl font-bold text-gray-900 mb-2\">Live Chat</h3>\n                    <p class=\"text-gray-600\">Engage with viewers in real-time. Moderation tools included.</p>\n                </div>\n                <div class=\"bg-white rounded-xl p-8 border border-gray-100 hover:shadow-lg transition\">\n                    <div class=\"w-12 h-12 bg-rose-100 rounded-lg flex items-center justify-center mb-4\"><i class=\"fas fa-record-vinyl text-rose-600\"></i></div>\n                    <h3 class=\"text-xl font-bold text-gray-900 mb-2\">Auto Recording</h3>\n                    <p class=\"text-gray-600\">Every stream auto-recorded and available on-demand instantly.</p>\n                </div>\n                <div class=\"bg-white rounded-xl p-8 border border-gray-100 hover:shadow-lg transition\">\n                    <div class=\"w-12 h-12 bg-pink-100 rounded-lg flex items-center justify-center mb-4\"><i class=\"fas fa-coins text-pink-600\"></i></div>\n                    <h3 class=\"text-xl font-bold text-gray-900 mb-2\">Monetization</h3>\n                    <p class=\"text-gray-600\">Multiple ways to earn. Donations, subscriptions, ads.</p>\n                </div>\n                <div class=\"bg-white rounded-xl p-8 border border-gray-100 hover:shadow-lg transition\">\n                    <div class=\"w-12 h-12 bg-rose-100 rounded-lg flex items-center justify-center mb-4\"><i class=\"fas fa-bar-chart text-rose-600\"></i></div>\n                    <h3 class=\"text-xl font-bold text-gray-900 mb-2\">Analytics</h3>\n                    <p class=\"text-gray-600\">Detailed viewer analytics and engagement metrics.</p>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <section id=\"testimonials\" class=\"py-24 px-4 sm:px-6 lg:px-8\">\n        <div class=\"max-w-6xl mx-auto\">\n            <h2 class=\"text-5xl font-bold text-center text-gray-900 mb-16\">Creator Stories</h2>\n            <div class=\"grid md:grid-cols-3 gap-8\">\n                <div class=\"bg-white rounded-xl border border-gray-100 p-8\">\n                    <div class=\"flex gap-1 mb-4\"><i class=\"fas fa-star text-yellow-400\"></i><i class=\"fas fa-star text-yellow-400\"></i><i class=\"fas fa-star text-yellow-400\"></i><i class=\"fas fa-star text-yellow-400\"></i><i class=\"fas fa-star text-yellow-400\"></i></div>\n                    <p class=\"text-gray-700 mb-6\">\"StreamPro changed everything. I went from 100 to 10K viewers in 3 months. The platform is so easy to use!\"</p>\n                    <div class=\"flex items-center gap-3\"><div class=\"w-10 h-10 rounded-full bg-gradient-to-r from-pink-400 to-rose-500\"></div><div><p class=\"font-bold text-gray-900\">Emma Creative</p><p class=\"text-sm text-gray-600\">Gaming Creator</p></div></div>\n                </div>\n                <div class=\"bg-white rounded-xl border border-gray-100 p-8\">\n                    <div class=\"flex gap-1 mb-4\"><i class=\"fas fa-star text-yellow-400\"></i><i class=\"fas fa-star text-yellow-400\"></i><i class=\"fas fa-star text-yellow-400\"></i><i class=\"fas fa-star text-yellow-400\"></i><i class=\"fas fa-star text-yellow-400\"></i></div>\n                    <p class=\"text-gray-700 mb-6\">\"The monetization features helped me earn $5K in my first month. Best investment ever!\"</p>\n                    <div class=\"flex items-center gap-3\"><div class=\"w-10 h-10 rounded-full bg-gradient-to-r from-purple-400 to-pink-500\"></div><div><p class=\"font-bold text-gray-900\">Alex Fitness</p><p class=\"text-sm text-gray-600\">Fitness Coach</p></div></div>\n                </div>\n                <div class=\"bg-white rounded-xl border border-gray-100 p-8\">\n                    <div class=\"flex gap-1 mb-4\"><i class=\"fas fa-star text-yellow-400\"></i><i class=\"fas fa-star text-yellow-400\"></i><i class=\"fas fa-star text-yellow-400\"></i><i class=\"fas fa-star text-yellow-400\"></i><i class=\"fas fa-star text-yellow-400\"></i></div>\n                    <p class=\"text-gray-700 mb-6\">\"Zero lag, great quality, easy setup. StreamPro is the best platform for serious creators.\"</p>\n                    <div class=\"flex items-center gap-3\"><div class=\"w-10 h-10 rounded-full bg-gradient-to-r from-blue-400 to-purple-500\"></div><div><p class=\"font-bold text-gray-900\">Jordan Music</p><p class=\"text-sm text-gray-600\">Music Educator</p></div></div>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <section id=\"pricing\" class=\"py-24 px-4 sm:px-6 lg:px-8 bg-gray-50\">\n        <div class=\"max-w-6xl mx-auto\">\n            <h2 class=\"text-5xl font-bold text-center text-gray-900 mb-16\">Transparent Pricing</h2>\n            <div class=\"grid md:grid-cols-3 gap-8\">\n                <div class=\"bg-white rounded-xl p-8 border border-gray-100\">\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-2\">Basic</h3>\n                    <div class=\"text-4xl font-bold text-gray-900 mb-8\">Free</div>\n                    <button onclick=\"openModal()\" class=\"w-full bg-gray-200 text-gray-900 px-6 py-3 rounded-lg font-bold hover:bg-gray-300 transition mb-8\">Get Started</button>\n                    <ul class=\"space-y-3\"><li class=\"flex gap-2\"><i class=\"fas fa-check text-pink-600\"></i> HD streaming</li><li class=\"flex gap-2\"><i class=\"fas fa-check text-pink-600\"></i> Up to 100 viewers</li></ul>\n                </div>\n                <div class=\"bg-white rounded-xl p-8 border-2 border-pink-600 relative shadow-lg\">\n                    <div class=\"absolute -top-4 left-8 bg-pink-600 text-white px-4 py-1 rounded-full text-sm font-bold\">MOST POPULAR</div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-2 mt-4\">Creator</h3>\n                    <div class=\"text-4xl font-bold text-gray-900 mb-8\">$29<span class=\"text-lg text-gray-600\">/mo</span></div>\n                    <button onclick=\"openModal()\" class=\"w-full bg-pink-600 text-white px-6 py-3 rounded-lg font-bold hover:bg-pink-700 transition mb-8\">Start Free Trial</button>\n                    <ul class=\"space-y-3\"><li class=\"flex gap-2\"><i class=\"fas fa-check text-pink-600\"></i> 4K streaming</li><li class=\"flex gap-2\"><i class=\"fas fa-check text-pink-600\"></i> Unlimited viewers</li><li class=\"flex gap-2\"><i class=\"fas fa-check text-pink-600\"></i> Monetization</li></ul>\n                </div>\n                <div class=\"bg-white rounded-xl p-8 border border-gray-100\">\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-2\">Studio</h3>\n                    <div class=\"text-4xl font-bold text-gray-900 mb-8\">$99<span class=\"text-lg text-gray-600\">/mo</span></div>\n                    <button onclick=\"openModal()\" class=\"w-full bg-gray-200 text-gray-900 px-6 py-3 rounded-lg font-bold hover:bg-gray-300 transition mb-8\">Contact</button>\n                    <ul class=\"space-y-3\"><li class=\"flex gap-2\"><i class=\"fas fa-check text-pink-600\"></i> Everything in Creator</li><li class=\"flex gap-2\"><i class=\"fas fa-check text-pink-600\"></i> Custom branding</li><li class=\"flex gap-2\"><i class=\"fas fa-check text-pink-600\"></i> Priority support</li></ul>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <section class=\"py-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-r from-pink-600 to-rose-600\">\n        <div class=\"max-w-4xl mx-auto text-center\">\n            <h2 class=\"text-5xl font-bold text-white mb-6\">Ready to Go Live?</h2>\n            <p class=\"text-xl text-pink-100 mb-8\">Join thousands of creators streaming with StreamPro</p>\n            <button onclick=\"openModal()\" class=\"bg-white text-pink-600 px-10 py-4 rounded-lg font-bold hover:bg-gray-100 transition shadow-xl\">Start Streaming Free</button>\n        </div>\n    </section>\n    \n    <footer class=\"bg-gray-900 text-gray-300 py-16 px-4 sm:px-6 lg:px-8\">\n        <div class=\"max-w-7xl mx-auto\">\n            <div class=\"grid md:grid-cols-5 gap-12 mb-12\">\n                <div><div class=\"flex items-center gap-3 mb-4\"><div class=\"w-8 h-8 bg-gradient-to-r from-pink-600 to-rose-600 rounded-lg flex items-center justify-center\"><i class=\"fas fa-circle text-white text-xs\"></i></div><span class=\"text-lg font-bold text-white\">StreamPro</span></div><p class=\"text-sm text-gray-400\">Live streaming for creators</p></div>\n                <div><h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Product</h4><ul class=\"space-y-2 text-sm\"><li><a href=\"#\" class=\"hover:text-pink-400\">Features</a></li><li><a href=\"#\" class=\"hover:text-pink-400\">Pricing</a></li></ul></div>\n                <div><h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Company</h4><ul class=\"space-y-2 text-sm\"><li><a href=\"#\" class=\"hover:text-pink-400\">About</a></li><li><a href=\"#\" class=\"hover:text-pink-400\">Blog</a></li></ul></div>\n                <div><h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Resources</h4><ul class=\"space-y-2 text-sm\"><li><a href=\"#\" class=\"hover:text-pink-400\">Help</a></li><li><a href=\"#\" class=\"hover:text-pink-400\">Support</a></li></ul></div>\n                <div><h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Legal</h4><ul class=\"space-y-2 text-sm\"><li><a href=\"#\" class=\"hover:text-pink-400\">Privacy</a></li><li><a href=\"#\" class=\"hover:text-pink-400\">Terms</a></li></ul></div>\n            </div>\n            <div class=\"border-t border-gray-800 pt-8\">\n                <p class=\"text-center text-gray-400 text-sm\">Created by <a href=\"https://devweavex.netlify.app/\" class=\"text-gray-300 hover:text-white transition\">DevWeaveX</a> — <a href=\"https://faizyab-hussain.vercel.app/\" class=\"text-gray-300 hover:text-white transition\">Syed Faizyab Hussain</a> & <a href=\"https://www.linkedin.com/in/syed-danish-raza/\" class=\"text-gray-300 hover:text-white transition\">Syed Danish Raza</a></p>\n            </div>\n        </div>\n    </footer>\n    \n    <div id=\"modal\" class=\"modal-hidden fixed inset-0 bg-black bg-opacity-50 z-50 px-4\">\n        <div class=\"bg-white rounded-2xl shadow-2xl max-w-md w-full m-auto\">\n            <div class=\"flex justify-between items-center p-6 border-b\">\n                <h3 class=\"text-2xl font-bold text-gray-900\">Start Streaming Free</h3>\n                <button onclick=\"closeModal()\" class=\"text-gray-400 hover:text-gray-600\"><i class=\"fas fa-times text-xl\"></i></button>\n            </div>\n            <div class=\"p-6\">\n                <form class=\"space-y-4\">\n                    <input type=\"text\" placeholder=\"Channel name\" class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-pink-600 focus:ring-2 focus:ring-pink-100\">\n                    <input type=\"email\" placeholder=\"Email\" class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-pink-600 focus:ring-2 focus:ring-pink-100\">\n                    <button type=\"button\" onclick=\"closeModal()\" class=\"w-full bg-pink-600 text-white py-3 rounded-lg font-bold hover:bg-pink-700 transition\">Create Channel</button>\n                </form>\n            </div>\n        </div>\n    </div>\n    \n    <script>\n        function toggleMenu() { document.getElementById('menu').classList.toggle('hidden'); }\n        function openModal() { document.getElementById('modal').classList.add('active'); document.body.style.overflow = 'hidden'; }\n        function closeModal() { document.getElementById('modal').classList.remove('active'); document.body.style.overflow = 'auto'; }\n        window.onclick = function(e) { if (e.target === document.getElementById('modal')) closeModal(); }\n    </script>\n</body>\n</html>",
