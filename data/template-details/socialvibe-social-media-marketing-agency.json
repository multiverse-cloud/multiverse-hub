      "summary": "Main template source file imported from Website Template Hub.",
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"description\" content=\"SocialVibe - Social media marketing agency. Instagram, TikTok, LinkedIn, Twitter, YouTube strategies.\">\n    <meta name=\"keywords\" content=\"social media marketing, Instagram marketing, TikTok marketing, social strategy, content creation\">\n    <title>SocialVibe - Social Media Marketing Agency</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Crimson+Text:wght@400;600&display=swap\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n    <style>\n        * { font-family: 'Poppins', sans-serif; }\n        h1, h2, h3 { font-family: 'Crimson Text', serif; }\n        .gradient-social { background: linear-gradient(135deg, #ec4899 0%, #f43f5e 100%); }\n        .modal-hide { display: none; }\n        .modal-hide.open { display: flex; }\n    </style>\n    <!-- Page Loader -->\n    \n</head>\n<body class=\"bg-white\">\n    <header class=\"fixed top-0 w-full bg-white z-50 border-b border-gray-200 shadow-sm\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center\">\n            <div class=\"flex items-center gap-3\">\n                <div class=\"w-10 h-10 gradient-social rounded-lg flex items-center justify-center\">\n                    <i class=\"fas fa-share-alt text-white font-bold\"></i>\n                </div>\n                <span class=\"text-xl font-bold text-gray-900\">SocialVibe</span>\n            </div>\n            <nav class=\"hidden lg:flex gap-10 items-center\">\n                <a href=\"#services\" class=\"text-gray-700 hover:text-pink-600 transition font-medium\">Services</a>\n                <a href=\"#portfolio\" class=\"text-gray-700 hover:text-pink-600 transition font-medium\">Portfolio</a>\n                <a href=\"#results\" class=\"text-gray-700 hover:text-pink-600 transition font-medium\">Results</a>\n                <a href=\"#team\" class=\"text-gray-700 hover:text-pink-600 transition font-medium\">Team</a>\n                <button onclick=\"openModal()\" class=\"gradient-social text-white px-6 py-2 rounded-lg font-bold hover:shadow-lg transition\">Get Proposal</button>\n            </nav>\n            <button id=\"mobileMenuBtn\" class=\"lg:hidden text-gray-900\" onclick=\"toggleMobileMenu()\">\n                <i class=\"fas fa-bars text-2xl\"></i>\n            </button>\n        </div>\n        <div id=\"mobileMenu\" class=\"hidden lg:hidden bg-white border-t border-gray-200\">\n            <div class=\"px-4 py-4 space-y-3\">\n                <a href=\"#services\" class=\"block text-gray-700 hover:text-pink-600 py-2 font-medium\">Services</a>\n                <a href=\"#portfolio\" class=\"block text-gray-700 hover:text-pink-600 py-2 font-medium\">Portfolio</a>\n                <a href=\"#results\" class=\"block text-gray-700 hover:text-pink-600 py-2 font-medium\">Results</a>\n                <a href=\"#team\" class=\"block text-gray-700 hover:text-pink-600 py-2 font-medium\">Team</a>\n                <button onclick=\"openModal()\" class=\"w-full gradient-social text-white py-2 rounded-lg font-bold\">Get Proposal</button>\n            </div>\n        </div>\n    </header>\n\n    <section class=\"pt-32 pb-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-br from-pink-50 to-rose-50\">\n        <div class=\"max-w-7xl mx-auto\">\n            <div class=\"grid lg:grid-cols-2 gap-12 items-center\">\n                <div>\n                    <span class=\"inline-block px-4 py-2 bg-pink-100 text-pink-700 rounded-full text-sm font-bold mb-6\">Social-First Strategy</span>\n                    <h1 class=\"text-6xl lg:text-7xl font-bold text-gray-900 mb-6 leading-tight\">\n                        Your Brand's\n                        <span class=\"gradient-social bg-clip-text text-transparent\"> Social Superpower</span>\n                    </h1>\n                    <p class=\"text-xl text-gray-600 mb-10 leading-relaxed\">\n                        Instagram, TikTok, LinkedIn, YouTube strategies. Viral content, community growth, engagement.\n                    </p>\n                    <div class=\"flex flex-col sm:flex-row gap-4\">\n                        <button onclick=\"openModal()\" class=\"gradient-social text-white px-8 py-4 rounded-lg font-bold hover:shadow-xl transition text-lg\">\n                            Get Social Strategy\n                        </button>\n                        <button class=\"border-2 border-pink-600 text-pink-600 px-8 py-4 rounded-lg font-bold hover:bg-pink-50 transition text-lg\">\n                            View Portfolio\n                        </button>\n                    </div>\n                    <div class=\"mt-12 space-y-4\">\n                        <div class=\"flex gap-3\">\n                            <i class=\"fas fa-check text-pink-600 text-2xl\"></i>\n                            <div>\n                                <p class=\"font-bold text-gray-900\">250M+ Impressions</p>\n                                <p class=\"text-sm text-gray-600\">Generated for our clients</p>\n                            </div>\n                        </div>\n                        <div class=\"flex gap-3\">\n                            <i class=\"fas fa-check text-pink-600 text-2xl\"></i>\n                            <div>\n                                <p class=\"font-bold text-gray-900\">40+ Brand Partnerships</p>\n                                <p class=\"text-sm text-gray-600\">From startups to Fortune 500</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"hidden lg:block relative\">\n                    <img src=\"https://images.unsplash.com/photo-1552664730-d307ca884978?w=500&h=400&fit=crop\" alt=\"Social Media\" class=\"rounded-xl shadow-2xl\">\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <section id=\"services\" class=\"py-20 px-4 sm:px-6 lg:px-8 bg-white\">\n        <div class=\"max-w-6xl mx-auto\">\n            <h2 class=\"text-4xl lg:text-5xl font-bold text-gray-900 mb-16 text-center\">Social Services</h2>\n            <div class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-8\">\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-pink-500 transition\">\n                    <div class=\"w-12 h-12 gradient-social rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-film text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Content Production</h3>\n                    <p class=\"text-gray-600 mb-6\">Professional video, photography, and design. Optimized for Instagram, TikTok, Reels, Shorts.</p>\n                    <button onclick=\"openModal()\" class=\"text-pink-600 font-bold hover:text-pink-700 transition\">Learn More →</button>\n                </div>\n\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-pink-500 transition\">\n                    <div class=\"w-12 h-12 gradient-social rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-users text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Community Management</h3>\n                    <p class=\"text-gray-600 mb-6\">24/7 engagement, response management, community growth, and relationship building.</p>\n                    <button onclick=\"openModal()\" class=\"text-pink-600 font-bold hover:text-pink-700 transition\">Learn More →</button>\n                </div>\n\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-pink-500 transition\">\n                    <div class=\"w-12 h-12 gradient-social rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-megaphone text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Influencer Partnerships</h3>\n                    <p class=\"text-gray-600 mb-6\">Authentic collaborations with relevant creators and influencers. Campaign management.</p>\n                    <button onclick=\"openModal()\" class=\"text-pink-600 font-bold hover:text-pink-700 transition\">Learn More →</button>\n                </div>\n\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-pink-500 transition\">\n                    <div class=\"w-12 h-12 gradient-social rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-bullseye text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Social Ads</h3>\n                    <p class=\"text-gray-600 mb-6\">Strategic paid campaigns. Targeting, creative optimization, and conversion tracking.</p>\n                    <button onclick=\"openModal()\" class=\"text-pink-600 font-bold hover:text-pink-700 transition\">Learn More →</button>\n                </div>\n\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-pink-500 transition\">\n                    <div class=\"w-12 h-12 gradient-social rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-chart-line text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Analytics & Reporting</h3>\n                    <p class=\"text-gray-600 mb-6\">Deep insights into performance. Monthly reports and actionable recommendations.</p>\n                    <button onclick=\"openModal()\" class=\"text-pink-600 font-bold hover:text-pink-700 transition\">Learn More →</button>\n                </div>\n\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-pink-500 transition\">\n                    <div class=\"w-12 h-12 gradient-social rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-crown text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Brand Strategy</h3>\n                    <p class=\"text-gray-600 mb-6\">Define your social brand voice, aesthetic, and strategic positioning.</p>\n                    <button onclick=\"openModal()\" class=\"text-pink-600 font-bold hover:text-pink-700 transition\">Learn More →</button>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <section id=\"portfolio\" class=\"py-20 px-4 sm:px-6 lg:px-8 bg-gray-50\">\n        <div class=\"max-w-6xl mx-auto\">\n            <h2 class=\"text-4xl lg:text-5xl font-bold text-gray-900 mb-16 text-center\">Portfolio</h2>\n            <div class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-8\">\n                <div class=\"bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition\">\n                    <img src=\"https://images.unsplash.com/photo-1579321288371-8202d5cd3dd4?w=400&h=300&fit=crop\" alt=\"Fashion Brand\" class=\"w-full h-48 object-cover\">\n                    <div class=\"p-6\">\n                        <h4 class=\"text-xl font-bold text-gray-900 mb-2\">Fashion Brand Growth</h4>\n                        <p class=\"text-gray-600 text-sm\">300K followers, +850% engagement in 6 months</p>\n                    </div>\n                </div>\n\n                <div class=\"bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition\">\n                    <img src=\"https://images.unsplash.com/photo-1493857671505-72967e2e2760?w=400&h=300&fit=crop\" alt=\"Tech Startup\" class=\"w-full h-48 object-cover\">\n                    <div class=\"p-6\">\n                        <h4 class=\"text-xl font-bold text-gray-900 mb-2\">Tech Startup Launch</h4>\n                        <p class=\"text-gray-600 text-sm\">From zero to 100K followers in 90 days</p>\n                    </div>\n                </div>\n\n                <div class=\"bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition\">\n                    <img src=\"https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=400&h=300&fit=crop\" alt=\"E-Commerce\" class=\"w-full h-48 object-cover\">\n                    <div class=\"p-6\">\n                        <h4 class=\"text-xl font-bold text-gray-900 mb-2\">E-Commerce Revenue</h4>\n                        <p class=\"text-gray-600 text-sm\">+$500K revenue through social commerce</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <section id=\"results\" class=\"py-20 px-4 sm:px-6 lg:px-8 bg-white\">\n        <div class=\"max-w-6xl mx-auto\">\n            <h2 class=\"text-4xl lg:text-5xl font-bold text-gray-900 mb-16 text-center\">Proven Results</h2>\n            <div class=\"grid md:grid-cols-4 gap-8\">\n                <div class=\"text-center p-8 bg-gray-50 rounded-xl\">\n                    <p class=\"text-4xl font-bold gradient-social bg-clip-text text-transparent mb-2\">250M+</p>\n                    <p class=\"text-gray-600 font-medium\">Total Impressions</p>\n                </div>\n                <div class=\"text-center p-8 bg-gray-50 rounded-xl\">\n                    <p class=\"text-4xl font-bold gradient-social bg-clip-text text-transparent mb-2\">15M+</p>\n                    <p class=\"text-gray-600 font-medium\">Combined Followers</p>\n                </div>\n                <div class=\"text-center p-8 bg-gray-50 rounded-xl\">\n                    <p class=\"text-4xl font-bold gradient-social bg-clip-text text-transparent mb-2\">680%</p>\n                    <p class=\"text-gray-600 font-medium\">Avg Engagement Lift</p>\n                </div>\n                <div class=\"text-center p-8 bg-gray-50 rounded-xl\">\n                    <p class=\"text-4xl font-bold gradient-social bg-clip-text text-transparent mb-2\">98%</p>\n                    <p class=\"text-gray-600 font-medium\">Client Satisfaction</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <section id=\"team\" class=\"py-20 px-4 sm:px-6 lg:px-8 bg-gray-50\">\n        <div class=\"max-w-6xl mx-auto\">\n            <h2 class=\"text-4xl lg:text-5xl font-bold text-gray-900 mb-16 text-center\">Our Team</h2>\n            <div class=\"grid md:grid-cols-4 gap-8\">\n                <div class=\"text-center\">\n                    <img src=\"https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=200&h=200&fit=crop\" alt=\"Team\" class=\"w-32 h-32 rounded-full mx-auto mb-4 object-cover\">\n                    <h4 class=\"text-xl font-bold text-gray-900\">Olivia Chen</h4>\n                    <p class=\"text-pink-600 font-semibold mb-2\">Creative Director</p>\n                    <p class=\"text-sm text-gray-600\">12+ years social expertise</p>\n                </div>\n                <div class=\"text-center\">\n                    <img src=\"https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&h=200&fit=crop\" alt=\"Team\" class=\"w-32 h-32 rounded-full mx-auto mb-4 object-cover\">\n                    <h4 class=\"text-xl font-bold text-gray-900\">Marcus Johnson</h4>\n                    <p class=\"text-pink-600 font-semibold mb-2\">Content Producer</p>\n                    <p class=\"text-sm text-gray-600\">Video & creative production</p>\n                </div>\n                <div class=\"text-center\">\n                    <img src=\"https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=200&h=200&fit=crop\" alt=\"Team\" class=\"w-32 h-32 rounded-full mx-auto mb-4 object-cover\">\n                    <h4 class=\"text-xl font-bold text-gray-900\">Emma Wilson</h4>\n                    <p class=\"text-pink-600 font-semibold mb-2\">Strategist</p>\n                    <p class=\"text-sm text-gray-600\">Growth & brand strategy</p>\n                </div>\n                <div class=\"text-center\">\n                    <img src=\"https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=200&h=200&fit=crop\" alt=\"Team\" class=\"w-32 h-32 rounded-full mx-auto mb-4 object-cover\">\n                    <h4 class=\"text-xl font-bold text-gray-900\">David Park</h4>\n                    <p class=\"text-pink-600 font-semibold mb-2\">Analytics Lead</p>\n                    <p class=\"text-sm text-gray-600\">Data & performance analysis</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <section class=\"py-20 px-4 sm:px-6 lg:px-8 gradient-social text-white\">\n        <div class=\"max-w-4xl mx-auto text-center\">\n            <h2 class=\"text-4xl lg:text-5xl font-bold mb-6\">Ready to Go Viral?</h2>\n            <p class=\"text-xl mb-10 opacity-90\">Get your custom social media strategy today.</p>\n            <button onclick=\"openModal()\" class=\"bg-white text-pink-600 px-10 py-4 rounded-lg font-bold hover:shadow-2xl transition text-lg hover:bg-gray-100\">\n                Request Proposal\n            </button>\n        </div>\n    </section>\n\n    <footer class=\"bg-gray-900 text-gray-400 py-12 px-4 sm:px-6 lg:px-8\">\n        <div class=\"max-w-6xl mx-auto\">\n            <div class=\"grid md:grid-cols-4 gap-8 mb-8\">\n                <div>\n                    <h4 class=\"text-white font-bold mb-4\">SocialVibe</h4>\n                    <p class=\"text-sm\">Your brand's social superpower.</p>\n                </div>\n                <div>\n                    <h4 class=\"text-white font-bold mb-4\">Services</h4>\n                    <ul class=\"space-y-2 text-sm\">\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Content</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Ads</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Strategy</a></li>\n                    </ul>\n                </div>\n                <div>\n                    <h4 class=\"text-white font-bold mb-4\">Company</h4>\n                    <ul class=\"space-y-2 text-sm\">\n                        <li><a href=\"#\" class=\"hover:text-white transition\">About</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Blog</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Contact</a></li>\n                    </ul>\n                </div>\n                <div>\n                    <h4 class=\"text-white font-bold mb-4\">Follow</h4>\n                    <div class=\"flex gap-4\">\n                        <a href=\"#\" class=\"hover:text-white transition\"><i class=\"fab fa-instagram\"></i></a>\n                        <a href=\"#\" class=\"hover:text-white transition\"><i class=\"fab fa-tiktok\"></i></a>\n                        <a href=\"#\" class=\"hover:text-white transition\"><i class=\"fab fa-youtube\"></i></a>\n                    </div>\n                </div>\n            </div>\n            <div class=\"border-t border-gray-700 pt-8 text-center text-sm\">\n                <p class=\"text-center text-gray-400 text-sm\">Created by <a href=\"https://devweavex.netlify.app/\" class=\"text-gray-300 hover:text-white transition\">DevWeaveX</a> — <a href=\"https://faizyab-hussain.vercel.app/\" class=\"text-gray-300 hover:text-white transition\">Syed Faizyab Hussain</a> & <a href=\"https://www.linkedin.com/in/syed-danish-raza/\" class=\"text-gray-300 hover:text-white transition\">Syed Danish Raza</a></p>\n                <p>&copy; 2026 SocialVibe. All rights reserved.</p>\n            </div>\n        </div>\n    </footer>\n\n    <div id=\"proposalModal\" class=\"modal-hide fixed inset-0 bg-black bg-opacity-50 z-50 items-center justify-center p-4\">\n        <div class=\"bg-white rounded-xl shadow-2xl max-w-md w-full p-8\">\n            <div class=\"flex justify-between items-center mb-6\">\n                <h3 class=\"text-2xl font-bold text-gray-900\">Get Proposal</h3>\n                <button onclick=\"closeModal()\" class=\"text-gray-600 hover:text-gray-900\">\n                    <i class=\"fas fa-times text-2xl\"></i>\n                </button>\n            </div>\n            <form class=\"space-y-4\">\n                <input type=\"text\" placeholder=\"Brand Name\" class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-pink-600 focus:ring-1 focus:ring-pink-600\">\n                <input type=\"email\" placeholder=\"Email\" class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-pink-600 focus:ring-1 focus:ring-pink-600\">\n                <input type=\"tel\" placeholder=\"Phone\" class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-pink-600 focus:ring-1 focus:ring-pink-600\">\n                <select class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-pink-600 focus:ring-1 focus:ring-pink-600\">\n                    <option>Select Service</option>\n                    <option>Content Production</option>\n                    <option>Community Management</option>\n                    <option>Influencer Partnerships</option>\n                    <option>Social Ads</option>\n                    <option>Full Service</option>\n                </select>\n                <button type=\"submit\" class=\"w-full gradient-social text-white py-3 rounded-lg font-bold hover:shadow-lg transition\">\n                    Send Proposal\n                </button>\n            </form>\n        </div>\n    </div>\n\n    <script>\n        function toggleMobileMenu() {\n            document.getElementById('mobileMenu').classList.toggle('hidden');\n        }\n        function openModal() {\n            document.getElementById('proposalModal').classList.add('open');\n        }\n        function closeModal() {\n            document.getElementById('proposalModal').classList.remove('open');\n        }\n        document.addEventListener('click', (e) => {\n            const modal = document.getElementById('proposalModal');\n            if (e.target === modal) closeModal();\n        });\n        document.querySelectorAll('a[href^=\"#\"]').forEach(anchor => {\n            anchor.addEventListener('click', function (e) {\n                e.preventDefault();\n                const target = document.querySelector(this.getAttribute('href'));\n                if (target) {\n                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });\n                    document.getElementById('mobileMenu').classList.add('hidden');\n                }\n            });\n        });\n    </script>\n</body>\n</html>",
