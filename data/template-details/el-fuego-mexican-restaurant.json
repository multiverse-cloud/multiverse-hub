h.com/photo-1565299585323-38d6b0865b47?w=1200&h=600&fit=crop'); background-size: cover; background-position: center; background-attachment: fixed;\">\n        <div class=\"absolute inset-0 bg-black/60\"></div>\n        <div class=\"max-w-5xl mx-auto text-center relative z-10 text-white\">\n            <h1 class=\"text-7xl font-bold mb-4\">EL FUEGO</h1>\n            <p class=\"text-3xl mb-4 mexican-gold font-bold\">Authentic Mexican Fire</p>\n            <p class=\"text-xl mb-8 max-w-2xl mx-auto\">Experience the passionate flavors of Mexico. From traditional\n                street tacos to chef-crafted specialties, every dish celebrates our culinary heritage.</p>\n            <button onclick=\"openRes()\"\n                class=\"mexican-red-bg text-white px-8 py-3 rounded font-bold text-lg hover:bg-red-700 transition mr-4\">Reservar</button>\n            <button onclick=\"document.getElementById('menu').scrollIntoView()\"\n                class=\"border-2 border-yellow-400 text-yellow-400 px-8 py-3 rounded font-bold hover:bg-yellow-400 hover:text-gray-900 transition\">Ver\n                Menú</button>\n        </div>\n    </section>\n\n    <!-- Story -->\n    <section id=\"story\" class=\"py-20 px-4 bg-white\">\n        <div class=\"max-w-6xl mx-auto\">\n            <div class=\"grid md:grid-cols-2 gap-12 items-center\">\n                <div>\n                    <img src=\"https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=500&h=500&fit=crop\"\n                        alt=\"Mexican Food\" class=\"w-full rounded-lg shadow-xl\">\n                </div>\n                <div>\n                    <h2 class=\"text-5xl font-bold mexican-red mb-6\">Passion for Flavor</h2>\n                    <p class=\"text-gray-700 text-lg mb-4 leading-relaxed\">El Fuego was born from a deep love for Mexican\n                        cuisine and tradition. Our chef, trained in Oaxaca and Mexico City, brings authentic techniques\n                        and family recipes passed down through generations.</p>\n                    <p class=\"text-gray-700 text-lg mb-6 leading-relaxed\">We source fresh chilies, spices, and\n                        ingredients directly from Mexican suppliers, ensuring every dish tastes like it came straight\n                        from the markets of Mexico.</p>\n                    <ul class=\"space-y-3 text-gray-700 font-semibold\">\n                        <li><i class=\"fas fa-check mexican-red mr-3\"></i> Authentic Recipes</li>\n                        <li><i class=\"fas fa-check mexican-red mr-3\"></i> Fresh Mexican Ingredients</li>\n                        <li><i class=\"fas fa-check mexican-red mr-3\"></i> Hand-Made Tortillas</li>\n                        <li><i class=\"fas fa-check mexican-red mr-3\"></i> Craft Margaritas</li>\n                    </ul>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Menu -->\n    <section id=\"menu\" class=\"py-20 px-4 bg-gray-50\">\n        <div class=\"max-w-6xl mx-auto\">\n            <h2 class=\"text-5xl font-bold text-center mexican-red mb-4\">Menu</h2>\n            <p class=\"text-center text-gray-600 mb-12 text-lg\">Traditional recipes, bold flavors, pure passion</p>\n\n            <div class=\"grid md:grid-cols-2 gap-8\">\n                <div>\n                    <h3 class=\"text-3xl font-bold mexican-red mb-6 pb-3 border-b-4 border-yellow-400\">Tacos</h3>\n                    <div class=\"space-y-5\">\n                        <div class=\"bg-white p-4 rounded-lg shadow border-l-4 border-red-600\">\n                            <h4 class=\"text-xl font-bold text-gray-900 mb-1\">Tacos al Pastor</h4>\n                            <p class=\"text-gray-600 text-sm mb-2\">Marinated pork, pineapple, onions (3 tacos)</p>\n                            <p class=\"mexican-red font-bold\">$14</p>\n                        </div>\n                        <div class=\"bg-white p-4 rounded-lg shadow border-l-4 border-red-600\">\n                            <h4 class=\"text-xl font-bold text-gray-900 mb-1\">Carne Asada Tacos</h4>\n                            <p class=\"text-gray-600 text-sm mb-2\">Grilled beef, cilantro, onion (3 tacos)</p>\n                            <p class=\"mexican-red font-bold\">$15</p>\n                        </div>\n                        <div class=\"bg-white p-4 rounded-lg shadow border-l-4 border-red-600\">\n                            <h4 class=\"text-xl font-bold text-gray-900 mb-1\">Fish Tacos</h4>\n                            <p class=\"text-gray-600 text-sm mb-2\">Crispy battered fish, cabbage slaw (3 tacos)</p>\n                            <p class=\"mexican-red font-bold\">$16</p>\n                        </div>\n                    </div>\n                </div>\n\n                <div>\n                    <h3 class=\"text-3xl font-bold mexican-red mb-6 pb-3 border-b-4 border-yellow-400\">Specialties</h3>\n                    <div class=\"space-y-5\">\n                        <div class=\"bg-white p-4 rounded-lg shadow border-l-4 border-red-600\">\n                            <h4 class=\"text-xl font-bold text-gray-900 mb-1\">Chile Relleno</h4>\n                            <p class=\"text-gray-600 text-sm mb-2\">Roasted poblano filled with cheese, tomato sauce</p>\n                            <p class=\"mexican-red font-bold\">$18</p>\n                        </div>\n                        <div class=\"bg-white p-4 rounded-lg shadow border-l-4 border-red-600\">\n                            <h4 class=\"text-xl font-bold text-gray-900 mb-1\">Chiles en Nogada</h4>\n                            <p class=\"text-gray-600 text-sm mb-2\">Poblano with walnut sauce & pomegranate</p>\n                            <p class=\"mexican-red font-bold\">$22</p>\n                        </div>\n                        <div class=\"bg-white p-4 rounded-lg shadow border-l-4 border-red-600\">\n                            <h4 class=\"text-xl font-bold text-gray-900 mb-1\">Mole Rojo</h4>\n                            <p class=\"text-gray-600 text-sm mb-2\">Chicken with traditional red mole sauce</p>\n                            <p class=\"mexican-red font-bold\">$24</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Specialties -->\n    <section id=\"specialties\" class=\"py-20 px-4 bg-white\">\n        <div class=\"max-w-6xl mx-auto\">\n            <h2 class=\"text-5xl font-bold text-center mexican-red mb-12\">House Specialties</h2>\n            <div class=\"grid md:grid-cols-3 gap-8\">\n                <div class=\"text-center p-6 bg-yellow-50 rounded-lg\">\n                    <i class=\"fas fa-glass-margarita text-4xl mexican-red mb-4 block\"></i>\n                    <h3 class=\"text-2xl font-bold mexican-red mb-3\">Craft Margaritas</h3>\n                    <p class=\"text-gray-700 mb-4\">Hand-crafted with premium tequila and fresh citrus. Sip perfection.\n                    </p>\n                    <p class=\"text-sm text-gray-600\">Starting at $12</p>\n                </div>\n                <div class=\"text-center p-6 bg-yellow-50 rounded-lg\">\n                    <i class=\"fas fa-fire text-4xl mexican-red mb-4 block\"></i>\n                    <h3 class=\"text-2xl font-bold mexican-red mb-3\">Salsas & Sauces</h3>\n                    <p class=\"text-gray-700 mb-4\">Made fresh daily from authentic recipes. Heat level varies!</p>\n                    <p class=\"text-sm text-gray-600\">Complimentary with chips</p>\n                </div>\n                <div class=\"text-center p-6 bg-yellow-50 rounded-lg\">\n                    <i class=\"fas fa-star text-4xl mexican-red mb-4 block\"></i>\n                    <h3 class=\"text-2xl font-bold mexican-red mb-3\">Churros</h3>\n                    <p class=\"text-gray-700 mb-4\">Crispy fried pastry with cinnamon sugar and chocolate sauce</p>\n                    <p class=\"text-sm text-gray-600\">$8</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Contact & CTA -->\n    <section id=\"contact\" class=\"py-20 px-4 bg-gradient-to-r from-red-600 to-orange-600 text-white\">\n        <div class=\"max-w-4xl mx-auto text-center\">\n            <h2 class=\"text-5xl font-bold mb-12\">Join Us for an Unforgettable Evening</h2>\n            <div class=\"grid md:grid-cols-3 gap-8 mb-12\">\n                <div>\n                    <i class=\"fas fa-map-marker-alt text-4xl mb-3 block mexican-gold\"></i>\n                    <p class=\"font-bold text-lg\">789 Fiesta Street</p>\n                    <p class=\"text-red-100\">Downtown District</p>\n                </div>\n                <div>\n                    <i class=\"fas fa-phone text-4xl mb-3 block mexican-gold\"></i>\n                    <p class=\"font-bold text-lg\">+1 (555) 456-7890</p>\n                    <p class=\"text-red-100\">Reservations</p>\n                </div>\n                <div>\n                    <i class=\"fas fa-clock text-4xl mb-3 block mexican-gold\"></i>\n                    <p class=\"font-bold text-lg\">Tue-Sun 5PM-11PM</p>\n                    <p class=\"text-red-100\">Monday: Closed</p>\n                </div>\n            </div>\n            <button onclick=\"openRes()\"\n                class=\"bg-yellow-400 text-gray-900 px-8 py-3 rounded font-bold text-lg hover:bg-yellow-300 transition\">Make\n                a Reservation</button>\n        </div>\n    </section>\n\n    <!-- Modal -->\n    <div id=\"resModal\" class=\"hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4\">\n        <div class=\"bg-white rounded-lg max-w-md w-full p-8\">\n            <h3 class=\"text-2xl font-bold mexican-red mb-6\">Reservar Mesa</h3>\n            <form onsubmit=\"submitRes(event)\" class=\"space-y-4\">\n                <input type=\"text\" placeholder=\"Nombre\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-red-600\">\n                <input type=\"email\" placeholder=\"Email\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-red-600\">\n                <input type=\"date\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-red-600\">\n                <input type=\"time\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-red-600\">\n                <input type=\"number\" min=\"1\" max=\"12\" placeholder=\"Personas\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-red-600\">\n                <button type=\"submit\"\n                    class=\"w-full mexican-red-bg text-white py-2 rounded font-bold hover:bg-red-700\">Reservar</button>\n                <button type=\"button\" onclick=\"closeRes()\"\n                    class=\"w-full border border-gray-300 py-2 rounded font-semibold text-gray-700 hover:bg-gray-50\">Cancelar</button>\n            </form>\n        </div>\n    </div>\n\n    <!-- Footer -->\n    <footer class=\"bg-gray-900 text-gray-300 py-8 px-4 text-center\">\n        <p>&copy; 2024 El Fuego. ¡Bienvenidos!</p>\n    </footer>\n\n    <script>\n        function openRes() { document.getElementById('resModal').classList.remove('hidden'); }\n        function closeRes() { document.getElementById('resModal').classList.add('hidden'); }\n        function submitRes(e) { e.preventDefault(); alert('¡Reservación confirmada!'); closeRes(); }\n    </script>\n</body>\n\n</html>",
