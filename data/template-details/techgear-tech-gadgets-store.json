                   <div id=\"faq-content-0\" class=\"hidden mt-4 text-gray-600 leading-relaxed border-t pt-4\">\n                        Yes, manufacturer warranty on all products. Extended warranty available.\n                    </div>\n                </div>\n                \n                <div class=\"bg-white rounded-xl border border-gray-200 p-8\">\n                    <button onclick=\"toggleFaq(1)\" class=\"w-full text-left flex justify-between items-center font-bold text-lg text-gray-900 hover:text-cyan-600 transition\">\n                        <span>Do you sell original products?</span>\n                        <i class=\"fas fa-chevron-down transition-transform\" id=\"faq-icon-1\"></i>\n                    </button>\n                    <div id=\"faq-content-1\" class=\"hidden mt-4 text-gray-600 leading-relaxed border-t pt-4\">\n                        100% authentic. Authorized distributor for all brands. Money-back guarantee.\n                    </div>\n                </div>\n                \n                <div class=\"bg-white rounded-xl border border-gray-200 p-8\">\n                    <button onclick=\"toggleFaq(2)\" class=\"w-full text-left flex justify-between items-center font-bold text-lg text-gray-900 hover:text-cyan-600 transition\">\n                        <span>What's the return policy?</span>\n                        <i class=\"fas fa-chevron-down transition-transform\" id=\"faq-icon-2\"></i>\n                    </button>\n                    <div id=\"faq-content-2\" class=\"hidden mt-4 text-gray-600 leading-relaxed border-t pt-4\">\n                        30-day returns. Free shipping for returns. Instant refund to account.\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <!-- CTA -->\n    <section class=\"py-24 px-4 sm:px-6 lg:px-8 bg-gradient-to-r from-cyan-500 to-blue-600\">\n        <div class=\"max-w-4xl mx-auto text-center\">\n            <h2 class=\"text-5xl md:text-6xl font-bold text-white mb-6\">Latest Tech at Best Price</h2>\n            <p class=\"text-xl text-cyan-100 mb-10\">Official distributor. Authorized seller.</p>\n            <button onclick=\"openModal()\" class=\"bg-white text-cyan-600 px-10 py-4 rounded-lg font-bold text-lg hover:bg-gray-100 transition shadow-xl\">\n                Shop Now\n            </button>\n        </div>\n    </section>\n    \n    <!-- Footer -->\n    <footer class=\"bg-gray-900 text-gray-300 py-16 px-4 sm:px-6 lg:px-8\">\n        <div class=\"max-w-7xl mx-auto grid md:grid-cols-5 gap-12 mb-12\">\n            <div>\n                <div class=\"flex items-center gap-3 mb-4\">\n                    <div class=\"w-8 h-8 bg-gradient-to-br from-cyan-500 to-blue-600 rounded-lg flex items-center justify-center\">\n                        <i class=\"fas fa-microchip text-white text-sm\"></i>\n                    </div>\n                    <span class=\"text-lg font-bold text-white\">TechGear</span>\n                </div>\n            </div>\n            <div>\n                <h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Shop</h4>\n                <ul class=\"space-y-2 text-sm\">\n                    <li><a href=\"#\" class=\"hover:text-cyan-400 transition\">Phones</a></li>\n                    <li><a href=\"#\" class=\"hover:text-cyan-400 transition\">Laptops</a></li>\n                </ul>\n            </div>\n            <div>\n                <h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Support</h4>\n                <ul class=\"space-y-2 text-sm\">\n                    <li><a href=\"#\" class=\"hover:text-cyan-400 transition\">Help</a></li>\n                    <li><a href=\"#\" class=\"hover:text-cyan-400 transition\">Warranty</a></li>\n                </ul>\n            </div>\n            <div>\n                <h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Company</h4>\n                <ul class=\"space-y-2 text-sm\">\n                    