  "previewHtml": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"description\" content=\"TechGear - Electronics store for gadgets and tech accessories\">\n    <meta name=\"keywords\" content=\"electronics, gadgets, tech, smartphones, computers\">\n    <title>TechGear - Tech Gadgets Store</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Roboto+Mono:wght@400;700&display=swap\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n    <style>\n        * { font-family: 'Outfit', sans-serif; }\n        h1, h2, h3, h4, h5, h6 { font-family: 'Outfit', sans-serif; font-weight: 800; }\n        .gradient-tech { background: linear-gradient(135deg, #06b6d4 0%, #0284c7 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }\n        .tech-glow { box-shadow: 0 0 50px rgba(6, 182, 212, 0.3); animation: techGlow 2.3s ease-in-out infinite; }\n        @keyframes techGlow { 0%, 100% { box-shadow: 0 0 50px rgba(6, 182, 212, 0.3); } 50% { box-shadow: 0 0 70px rgba(2, 132, 199, 0.45); } }\n        .modal-hidden { display: none !important; }\n        .modal-hidden.show { display: flex !important; }\n        .tech-card { transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }\n        .tech-card:hover { transform: translateY(-8px); box-shadow: 0 20px 60px rgba(6, 182, 212, 0.2); }\n    </style>\n    <!-- Page Loader -->\n    \n</head>\n<body class=\"bg-white\">\n    <!-- Header -->\n    <header class=\"fixed top-0 w-full bg-white z-50 border-b border-gray-100\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex justify-between items-center\">\n            <div class=\"flex items-center gap-3\">\n                <div class=\"w-12 h-12 bg-gradient-to-br from-cyan-500 to-blue-600 rounded-xl flex items-center justify-center shadow-lg\">\n                    <i class=\"fas fa-microchip text-white text-xl\"></i>\n                </div>\n                <span class=\"text-2xl font-bold text-gray-900\">TechGear</span>\n            </div>\n            \n            <nav class=\"hidden lg:flex gap-12 items-center\">\n                <a href=\"#products\" class=\"text-gray-700 font-medium hover:text-cyan-600 transition\">Products</a>\n                <a href=\"#categories\" class=\"text-gray-700 font-medium hover:text-cyan-600 transition\">Categories</a>\n                <a href=\"#deals\" class=\"text-gray-700 font-medium hover:text-cyan-600 transition\">Hot Deals</a>\n                <a href=\"#faq\" class=\"text-gray-700 font-medium hover:text-cyan-600 transition\">Help</a>\n                <button onclick=\"openModal()\" class=\"bg-gradient-to-r from-cyan-500 to-blue-600 text-white px-6 py-3 rounded-lg font-bold hover:shadow-lg transition shadow-md\">Shop</button>\n            </nav>\n            \n            <button id=\"mobileToggleBtn\" class=\"lg:hidden text-gray-700\" onclick=\"toggleMobileMenu()\">\n                <i class=\"fas fa-bars text-2xl\"></i>\n            </button>\n        </div>\n        \n        <div id=\"mobileMenu\" class=\"hidden lg:hidden border-t bg-white\">\n            <div class=\"px-4 py-4 space-y-4\">\n                <a href=\"#products\" class=\"block text-gray-700 font-medium py-2\">Products</a>\n                <a href=\"#categories\" class=\"block text-gray-700 font-medium py-2\">Categories</a>\n                <a href=\"#deals\" class=\"block text-gray-700 font-medium py-2\">Hot Deals</a>\n                <a href=\"#faq\" class=\"block text-gray-700 font-medium py-2\">Help</a>\n                <button onclick=\"openModal()\" class=\"w-full bg-gradient-to-r from-cyan-500 to-blue-600 text-white px-6 py-3 rounded-lg font-bold\">Shop</button>\n            </div>\n        </div>\n    </header>\n    \n    <!-- Hero -->\n    <section class=\"pt-32 pb-24 px-4 sm:px-6 lg:px-8 bg-gradient-to-br from-cyan-50 to-blue-50\">\n        <div class=\"max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center\">\n            <div>\n                <div class=\"inline-block bg-cyan-100 text-cyan-700 px-4 py-2 rounded-full text-sm font-bold mb-8 flex items-center gap-2\">\n                    <i class=\"fas fa-zap\"></i> Latest Tech\n                </div>\n                <h1 class=\"text-6xl lg:text-7xl font-bold text-gray-900 mb-6 leading-tight\">\n                    Cutting Edge<br/><span class=\"gradient-tech\">Technology</span>\n                </h1>\n                <p class=\"text-xl text-gray-600 mb-8 leading-relaxed\">\n                    Latest gadgets. Best prices. Expert advice. Free tech support.\n                </p>\n                <div class=\"flex flex-col sm:flex-row gap-4 mb-8\">\n                    <button onclick=\"openModal()\" class=\"bg-gradient-to-r from-cyan-500 to-blue-600 text-white px-8 py-4 rounded-lg font-bold text-lg hover:shadow-xl transition shadow-lg\">\n                        Browse Now\n                    </button>\n                    <button class=\"border-2 border-cyan-300 text-cyan-600 px-8 py-4 rounded-lg font-bold hover:bg-cyan-50 transition\">\n                        View Deals\n                    </button>\n                </div>\n                <div class=\"flex gap-8 text-sm\">\n                    <div>\n                        <p class=\"text-3xl font-bold text-cyan-600\">15K+</p>\n                        <p class=\"text-gray-600\">Products</p>\n                    </div>\n                    <div>\n                        <p class=\"text-3xl font-bold text-cyan-600\">2 Year</p>\n                        <p class=\"text-gray-600\">Warranty</p>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"hidden lg:flex items-center justify-center\">\n                <div class=\"tech-glow w-80 h-80 bg-gradient-to-br from-cyan-100 to-blue-100 rounded-3xl flex items-center justify-center\">\n                    <i class=\"fas fa-laptop text-7xl text-cyan-200 opacity-40\"></i>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <!-- Products -->\n    <section id=\"products\" class=\"py-24 px-4 sm:px-6 lg:px-8 bg-gray-50\">\n        <div class=\"max-w-7xl mx-auto\">\n            <h2 class=\"text-5xl font-bold text-center text-gray-900 mb-16\">Top Products</h2>\n            \n            <div class=\"grid md:grid-cols-3 gap-8\">\n                <div class=\"tech-card bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm\">\n                    <div class=\"w-full h-48 bg-gradient-to-br from-cyan-200 to-blue-200 flex items-center justify-center\">\n                        <i class=\"fas fa-mobile text-cyan-300 text-8xl opacity-30\"></i>\n                    </div>\n                    <div class=\"p-6\">\n                        <h3 class=\"text-lg font-bold text-gray-900 mb-2\">Smartphone Pro</h3>\n                        <p class=\"text-sm text-gray-600 mb-4\">5G, 120Hz display, 5000mAh battery</p>\n                        <span class=\"text-2xl font-bold text-cyan-600\">&#8377;34,999</span>\n                        <button onclick=\"openModal()\" class=\"w-full mt-4 bg-cyan-100 text-cyan-700 py-2 rounded-lg font-bold hover:bg-cyan-200 transition\">Add to Cart</button>\n                    </div>\n                </div>\n                \n                <div class=\"tech-card bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm\">\n                    <div class=\"w-full h-48 bg-gradient-to-br from-cyan-200 to-blue-200 flex items-center justify-center\">\n                        <i class=\"fas fa-laptop text-cyan-300 text-8xl opacity-30\"></i>\n                    </div>\n                    <div class=\"p-6\">\n                        <h3 class=\"text-lg font-bold text-gray-900 mb-2\">Gaming Laptop</h3>\n                        <p class=\"text-sm text-gray-600 mb-4\">RTX 4060, 16GB RAM, 512GB SSD</p>\n                        <span class=\"text-2xl font-bold text-cyan-600\">&#8377;89,999</span>\n                        <button onclick=\"openModal()\" class=\"w-full mt-4 bg-cyan-100 text-cyan-700 py-2 rounded-lg font-bold hover:bg-cyan-200 transition\">Add to Cart</button>\n                    </div>\n                </div>\n                \n                <div class=\"tech-card bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm\">\n                    <div class=\"w-full h-48 bg-gradient-to-br from-cyan-200 to-blue-200 flex items-center justify-center\">\n                        <i class=\"fas fa-headphones text-cyan-300 text-8xl opacity-30\"></i>\n                    </div>\n                    <div class=\"p-6\">\n                        <h3 class=\"text-lg font-bold text-gray-900 mb-2\">Wireless Earbuds</h3>\n                        <p class=\"text-sm text-gray-600 mb-4\">Noise cancelling, 48hr battery</p>\n                        <span class=\"text-2xl font-bold text-cyan-600\">&#8377;12,999</span>\n                        <button onclick=\"openModal()\" class=\"w-full mt-4 bg-cyan-100 text-cyan-700 py-2 rounded-lg font-bold hover:bg-cyan-200 transition\">Add to Cart</button>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <!-- Categories -->\n    <section id=\"categories\" class=\"py-24 px-4 sm:px-6 lg:px-8\">\n        <div class=\"max-w-7xl mx-auto\">\n            <h2 class=\"text-5xl font-bold text-center text-gray-900 mb-16\">Shop by Category</h2>\n            \n            <div class=\"grid md:grid-cols-4 gap-6\">\n                <div class=\"bg-white rounded-2xl border border-gray-200 p-8 text-center hover:shadow-lg transition cursor-pointer\">\n                    <i class=\"fas fa-mobile text-cyan-600 text-4xl mb-4\"></i>\n                    <h3 class=\"font-bold text-gray-900 mb-2\">Phones</h3>\n                    <p class=\"text-sm text-gray-600\">2000+ models</p>\n                </div>\n                \n                <div class=\"bg-white rounded-2xl border border-gray-200 p-8 text-center hover:shadow-lg transition cursor-pointer\">\n                    <i class=\"fas fa-laptop text-cyan-600 text-4xl mb-4\"></i>\n                    <h3 class=\"font-bold text-gray-900 mb-2\">Laptops</h3>\n                    <p class=\"text-sm text-gray-600\">1500+ options</p>\n                </div>\n                \n                <div class=\"bg-white rounded-2xl border border-gray-200 p-8 text-center hover:shadow-lg transition cursor-pointer\">\n                    <i class=\"fas fa-gamepad text-cyan-600 text-4xl mb-4\"></i>\n                    <h3 class=\"font-bold text-gray-900 mb-2\">Accessories</h3>\n                    <p class=\"text-sm text-gray-600\">5000+ items</p>\n                </div>\n                \n                <div class=\"bg-white rounded-2xl border border-gray-200 p-8 text-center hover:shadow-lg transition cursor-pointer\">\n                    <i class=\"fas fa-tv text-cyan-600 text-4xl mb-4\"></i>\n                    <h3 class=\"font-bold text-gray-900 mb-2\">Displays</h3>\n                    <p class=\"text-sm text-gray-600\">800+ monitors</p>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <!-- Deals -->\n    <section id=\"deals\" class=\"py-24 px-4 sm:px-6 lg:px-8 bg-cyan-50\">\n        <div class=\"max-w-7xl mx-auto\">\n            <h2 class=\"text-5xl font-bold text-center text-gray-900 mb-16\">Hot Deals</h2>\n            \n            <div class=\"grid md:grid-cols-2 gap-8 max-w-4xl mx-auto\">\n                <div class=\"bg-white rounded-2xl border border-gray-200 p-8\">\n                    <div class=\"flex items-start gap-4\">\n                        <div class=\"w-12 h-12 bg-cyan-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-1\">\n                            <i class=\"fas fa-bolt text-cyan-600 text-xl\"></i>\n                        </div>\n                        <div>\n                            <h3 class=\"text-xl font-bold text-gray-900 mb-2\">Flash Sales</h3>\n                            <p class=\"text-gray-600\">Daily deals. Limited quantity.</p>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"bg-white rounded-2xl border border-gray-200 p-8\">\n                    <div class=\"flex items-start gap-4\">\n                        <div class=\"w-12 h-12 bg-cyan-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-1\">\n                            <i class=\"fas fa-gift text-cyan-600 text-xl\"></i>\n                        </div>\n                        <div>\n                            <h3 class=\"text-xl font-bold text-gray-900 mb-2\">Bundle Offers</h3>\n                            <p class=\"text-gray-600\">Save more when you buy together.</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <!-- FAQ -->\n    <section id=\"faq\" class=\"py-24 px-4 sm:px-6 lg:px-8\">\n        <div class=\"max-w-4xl mx-auto\">\n            <h2 class=\"text-5xl font-bold text-center text-gray-900 mb-16\">Questions?</h2>\n            \n            <div class=\"space-y-6\">\n                <div class=\"bg-white rounded-xl border border-gray-200 p-8\">\n                    <button onclick=\"toggleFaq(0)\" class=\"w-full text-left flex justify-between items-center font-bold text-lg text-gray-900 hover:text-cyan-600 transition\">\n                        <span>Is warranty provided?</span>\n                        <i class=\"fas fa-chevron-down transition-transform\" id=\"faq-icon-0\"></i>\n                    </button>\n                    <div id=\"faq-content-0\" class=\"hidden mt-4 text-gray-600 leading-relaxed border-t pt-4\">\n                        Yes, manufacturer warranty on all products. Extended warranty available.\n                    </div>\n                </div>\n                \n                <div class=\"bg-white rounded-xl border border-gray-200 p-8\">\n                    <button onclick=\"toggleFaq(1)\" class=\"w-full text-left flex justify-between items-center font-bold text-lg text-gray-900 hover:text-cyan-600 transition\">\n                        <span>Do you sell original products?</span>\n                        <i class=\"fas fa-chevron-down transition-transform\" id=\"faq-icon-1\"></i>\n                    </button>\n                    <div id=\"faq-content-1\" class=\"hidden mt-4 text-gray-600 leading-relaxed border-t pt-4\">\n                        100% authentic. Authorized distributor for all brands. Money-back guarantee.\n                    </div>\n                </div>\n                \n                <div class=\"bg-white rounded-xl border border-gray-200 p-8\">\n                    <button onclick=\"toggleFaq(2)\" class=\"w-full text-left flex justify-between items-center font-bold text-lg text-gray-900 hover:text-cyan-600 transition\">\n                        <span>What's the return policy?</span>\n                        <i class=\"fas fa-chevron-down transition-transform\" id=\"faq-icon-2\"></i>\n                    </button>\n                    <div id=\"faq-content-2\" class=\"hidden mt-4 text-gray-600 leading-relaxed border-t pt-4\">\n                        30-day returns. Free shipping for returns. Instant refund to account.\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <!-- CTA -->\n    <section class=\"py-24 px-4 sm:px-6 lg:px-8 bg-gradient-to-r from-cyan-500 to-blue-600\">\n        <div class=\"max-w-4xl mx-auto text-center\">\n            <h2 class=\"text-5xl md:text-6xl font-bold text-white mb-6\">Latest Tech at Best Price</h2>\n            <p class=\"text-xl text-cyan-100 mb-10\">Official distributor. Authorized seller.</p>\n            <button onclick=\"openModal()\" class=\"bg-white text-cyan-600 px-10 py-4 rounded-lg font-bold text-lg hover:bg-gray-100 transition shadow-xl\">\n                Shop Now\n            </button>\n        </div>\n    </section>\n    \n    <!-- Footer -->\n    <footer class=\"bg-gray-900 text-gray-300 py-16 px-4 sm:px-6 lg:px-8\">\n        <div class=\"max-w-7xl mx-auto grid md:grid-cols-5 gap-12 mb-12\">\n            <div>\n                <div class=\"flex items-center gap-3 mb-4\">\n                    <div class=\"w-8 h-8 bg-gradient-to-br from-cyan-500 to-blue-600 rounded-lg flex items-center justify-center\">\n                        <i class=\"fas fa-microchip text-white text-sm\"></i>\n                    </div>\n                    <span class=\"text-lg font-bold text-white\">TechGear</span>\n                </div>\n            </div>\n            <div>\n                <h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Shop</h4>\n                <ul class=\"space-y-2 text-sm\">\n                    <li><a href=\"#\" class=\"hover:text-cyan-400 transition\">Phones</a></li>\n                    <li><a href=\"#\" class=\"hover:text-cyan-400 transition\">Laptops</a></li>\n                </ul>\n            </div>\n            <div>\n                <h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Support</h4>\n                <ul class=\"space-y-2 text-sm\">\n                    <li><a href=\"#\" class=\"hover:text-cyan-400 transition\">Help</a></li>\n                    <li><a href=\"#\" class=\"hover:text-cyan-400 transition\">Warranty</a></li>\n                </ul>\n            </div>\n            <div>\n                <h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Company</h4>\n                <ul class=\"space-y-2 text-sm\">\n                    <li><a href=\"#\" class=\"hover:text-cyan-400 transition\">About</a></li>\n                    <li><a href=\"#\" class=\"hover:text-cyan-400 transition\">Blog</a></li>\n                </ul>\n            </div>\n            <div>\n                <h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Legal</h4>\n                <ul class=\"space-y-2 text-sm\">\n                    <li><a href=\"#\" class=\"hover:text-cyan-400 transition\">Privacy</a></li>\n                    <li><a href=\"#\" class=\"hover:text-cyan-400 transition\">Terms</a></li>\n                </ul>\n            </div>\n        </div>\n        \n        <div class=\"border-t border-gray-800 pt-8\">\n            <p class=\"text-center text-gray-400 text-sm\">Created by <a href=\"https://devweavex.netlify.app/\" class=\"text-gray-300 hover:text-white transition\">DevWeaveX</a> — <a href=\"https://faizyab-hussain.vercel.app/\" class=\"text-gray-300 hover:text-white transition\">Syed Faizyab Hussain</a> & <a href=\"https://www.linkedin.com/in/syed-danish-raza/\" class=\"text-gray-300 hover:text-white transition\">Syed Danish Raza</a></p>\n        </div>\n    </footer>\n    \n    <!-- Modal -->\n    <div id=\"modal\" class=\"modal-hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center px-4\">\n        <div class=\"bg-white rounded-2xl shadow-2xl max-w-md w-full\">\n            <div class=\"flex justify-between items-center p-6 border-b border-gray-200\">\n                <h3 class=\"text-2xl font-bold text-gray-900\">Shop Products</h3>\n                <button onclick=\"closeModal()\" class=\"text-gray-400 hover:text-gray-600\">\n                    <i class=\"fas fa-times text-xl\"></i>\n                </button>\n            </div>\n            \n            <div class=\"p-6\">\n                <form class=\"space-y-4\">\n                    <div>\n                        <label class=\"block text-sm font-semibold text-gray-700 mb-2\">Product Category</label>\n                        <select class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-cyan-600 focus:ring-2 focus:ring-cyan-100\">\n                            <option>Smartphones</option>\n                            <option>Laptops</option>\n                            <option>Accessories</option>\n                        </select>\n                    </div>\n                    \n                    <button type=\"button\" onclick=\"closeModal()\" class=\"w-full bg-gradient-to-r from-cyan-500 to-blue-600 text-white py-3 rounded-lg font-bold hover:shadow-lg transition\">\n                        Browse Now\n                    </button>\n                </form>\n            </div>\n        </div>\n    </div>\n    \n    <script>\n        function toggleMobileMenu() {\n            document.getElementById('mobileMenu').classList.toggle('hidden');\n        }\n        \n        function openModal() {\n            document.getElementById('modal').classList.add('show');\n            document.body.style.overflow = 'hidden';\n        }\n        \n        function closeModal() {\n            document.getElementById('modal').classList.remove('show');\n            document.body.style.overflow = 'auto';\n        }\n        \n        function toggleFaq(index) {\n            const content = document.getElementById(`faq-content-${index}`);\n            const icon = document.getElementById(`faq-icon-${index}`);\n            \n            content.classList.toggle('hidden');\n            icon.style.transform = content.classList.contains('hidden') ? 'rotate(0)' : 'rotate(180deg)';\n        }\n        \n        window.onclick = function(event) {\n            const modal = document.getElementById('modal');\n            if (event.target === modal) {\n                closeModal();\n            }\n        }\n    </script>\n</body>\n</html>",
