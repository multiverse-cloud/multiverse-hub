>\n            </div>\n        </div>\n    </header>\n    \n    <!-- Hero -->\n    <section class=\"pt-32 pb-24 px-4 sm:px-6 lg:px-8 bg-gradient-to-br from-cyan-50 to-blue-50\">\n        <div class=\"max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center\">\n            <div>\n                <div class=\"inline-block bg-cyan-100 text-cyan-700 px-4 py-2 rounded-full text-sm font-bold mb-8 flex items-center gap-2\">\n                    <i class=\"fas fa-zap\"></i> Latest Tech\n                </div>\n                <h1 class=\"text-6xl lg:text-7xl font-bold text-gray-900 mb-6 leading-tight\">\n                    Cutting Edge<br/><span class=\"gradient-tech\">Technology</span>\n                </h1>\n                <p class=\"text-xl text-gray-600 mb-8 leading-relaxed\">\n                    Latest gadgets. Best prices. Expert advice. Free tech support.\n                </p>\n                <div class=\"flex flex-col sm:flex-row gap-4 mb-8\">\n                    <button onclick=\"openModal()\" class=\"bg-gradient-to-r from-cyan-500 to-blue-600 text-white px-8 py-4 rounded-lg font-bold text-lg hover:shadow-xl transition shadow-lg\">\n                        Browse Now\n                    </button>\n                    <button class=\"border-2 border-cyan-300 text-cyan-600 px-8 py-4 rounded-lg font-bold hover:bg-cyan-50 transition\">\n                        View Deals\n                    </button>\n                </div>\n                <div class=\"flex gap-8 text-sm\">\n                    <div>\n                        <p class=\"text-3xl font-bold text-cyan-600\">15K+</p>\n                        <p class=\"text-gray-600\">Products</p>\n                    </div>\n                    <div>\n                        <p class=\"text-3xl font-bold text-cyan-600\">2 Year</p>\n                        <p class=\"text-gray-600\">Warranty</p>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"hidden lg