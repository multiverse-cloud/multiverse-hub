s=\"text-gray-300 hover:prime-gold transition font-semibold\">Wines</a></li>\n                <li><a href=\"#reservations\" class=\"text-gray-300 hover:prime-gold transition font-semibold\">Reservations</a></li>\n                <li><button onclick=\"openReserve()\" class=\"wood-accent text-white px-6 py-2 rounded hover:opacity-90 transition font-bold\">Book</button></li>\n            </ul>\n        </div>\n    </nav>\n\n    <!-- Hero -->\n    <section class=\"relative py-48 px-4\" style=\"background-image: url('https://images.unsplash.com/photo-1555939594-58d7cb561631?w=1200&h=600&fit=crop'); background-size: cover; background-position: center; background-attachment: fixed;\">\n        <div class=\"absolute inset-0 bg-black/70\"></div>\n        <div class=\"max-w-5xl mx-auto text-center relative z-10\">\n            <h1 class=\"text-7xl font-bold prime-gold mb-4\">TIMBER CREEK</h1>\n            <p class=\"text-3xl mb-4 text-gray-200 font-light\">Premium Steakhouse</p>\n            <p class=\"text-xl mb-8 max-w-2xl mx-auto text-gray-300\">Where USDA Prime beef meets rustic elegance. Aged 28 days for peak flavor. Seared to perfection in our wood-fired kitchen.</p>\n            <button onclick=\"openReserve()\" class=\"wood-accent text-white px-8 py-3 rounded font-bold text-lg hover:opacity-90 transition mr-4\">Reserve Now</button>\n            <button onclick=\"document.getElementById('steaks').scrollIntoView()\" class=\"border-2 border-yellow-600 text-yellow-600 px-8 py-3 rounded font-bold hover:bg-yellow-600 hover:text-black transition\">View Menu</button>\n        </div>\n    </section>\n\n    <!-- Experience -->\n    <section id=\"experience\" class=\"py-24 px-4 bg-black\">\n        <div class=\"max-w-6xl mx-auto\">\n            <h2 class=\"text-5xl font-bold prime-gold text-center mb-16\">The Timber Creek Experience</h2>\n            <div class=\"grid md:grid-cols-3 gap-12\">\n                <div class=\"text-center\">\n                    <div class=\"w-20 h-20 wood-accent rounded-full flex items-center justify-center mx-auto mb-6\">\n                        <i class=\"fas fa-fire text-white text-3xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-100 mb-3\">Wood-Fired Excellence</h3>\n                    <p class=\"text-gray-400\">Our custom-built wood-fired grill reaches 900°F, creating an incomparable crust and smoky depth to every steak.</p>\n                </div>\n                <div class=\"text-center\">\n                    <div class=\"w-20 h-20 wood-accent rounded-full flex items-center justify-center mx-auto mb-6\">\n                        <i class=\"fas fa-dumbbell text-white text-3xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-100 mb-3\">Prime Aging Process</h3>\n                    <p class=\"text-gray-400\">Every cut is dry-aged for exactly 28 days, concentrating flavor and creating the most tender beef possible.</p>\n                </div>\n                <div class=\"text-center\">\n                    <div class=\"w-20 h-20 wood-accent rounded-full flex items-center justify-center mx-auto mb-6\">\n                        <i class=\"fas fa-wine-bottle text-white text-3xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-100 mb-3\">Sommelier's Selection</h3>\n                    <p class=\"text-gray-400\">Our award-winning wine collection features premium vintages curated to complement our steaks perfectly.</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Steaks -->\n    <section id=\"steaks\" class=\"py-24 px-4 bg-gray-900\">\n        <div class=\"max-w-6xl mx-auto\">\n            <h2 class=\"text-5xl font-bold prime-gold text-center mb-4\">Our Steaks</h2>\n            <p class=\"text-center text-gray-400 mb-16 text-lg\">USDA Prime • 28-Day Dry Aged • Wood-Fired to Order</p>\n\n            <div class=\"grid md:grid-cols-2 gap-8\">\n                <div class=\"bg-gray-800 p-8 rounded-lg border border-yellow-600\">\n                    <h3 class=\"text-3xl font-bold prime-gold mb-6\">Classic Cuts</h3>\n                    <div class=\"space-y-6\">\n                        <div>\n                            <h4 class=\"text-xl font-bold text-gray-100 mb-1\">New York Strip</h4>\n                            <p class=\"text-gray-400 text-sm mb-2\">14 oz | Classic bold beef flavor with beautiful marbling</p>\n                            <p class=\"prime-gold font-bold text-lg\">$58</p>\n                        </div>\n                        <div>\n                            <h4 class=\"text-xl font-bold text-gray-100 mb-1\">Ribeye</h4>\n                            <p class=\"text-gray-400 text-sm mb-2\">16 oz | Premium marbling, butter-tender and succulent</p>\n                            <p class=\"prime-gold font-bold text-lg\">$62</p>\n                        </div>\n                        <div>\n                            <h4 class=\"text-xl font-bold text-gray-100 mb-1\">Filet Mignon</h4>\n                            <p class=\"text-gray-400 text-sm mb-2\">8 oz | Most tender cut, mild and elegant</p>\n                            <p class=\"prime-gold font-bold text-lg\">$68</p>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"bg-gray-800 p-8 rounded-lg border border-yellow-600\">\n                    <h3 class=\"text-3xl font-bold prime-gold mb-6\">Signature Selections</h3>\n                    <div class=\"space-y-6\">\n                        <div>\n                            <h4 class=\"text-xl font-bold text-gray-100 mb-1\">Porterhouse</h4>\n                            <p class=\"text-gray-400 text-sm mb-2\">20 oz | Strip & tenderloin combo, the ultimate experience</p>\n                            <p class=\"prime-gold font-bold text-lg\">$74</p>\n                        </div>\n                        <div>\n                            <h4 class=\"text-xl font-bold text-gray-100 mb-1\">Dry-Aged Prime Grade</h4>\n                            <p class=\"text-gray-400 text-sm mb-2\">24 oz | Our signature cut, peak marbling and aging</p>\n                            <p class=\"prime-gold font-bold text-lg\">$82</p>\n                        </div>\n                        <div>\n                            <h4 class=\"text-xl font-bold text-gray-100 mb-1\">Wagyu A5 Japan</h4>\n                            <p class=\"text-gray-400 text-sm mb-2\">8 oz | World's most luxurious beef, ultra-marbled</p>\n                            <p class=\"prime-gold font-bold text-lg\">$125</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"mt-12 p-8 bg-gray-800 rounded-lg border border-yellow-600 text-center\">\n                <p class=\"text-gray-300 text-lg\">All steaks include: House salad, seasonal vegetables & your choice of starch</p>\n                <p class=\"text-gray-500 text-sm mt-3\">Add premium toppings: Truffle butter • Foie gras • King crab • Lobster tail</p>\n            </div>\n        </div>\n    </section>\n\n    <!-- Wines -->\n    <section id=\"wines\" class=\"py-24 px-4 bg-black\">\n        <div class=\"max-w-4xl mx-auto\">\n            <h2 class=\"text-5xl font-bold prime-gold text-center mb-12\">Wine Cellar</h2>\n            <div class=\"grid md:grid-cols-3 gap-8\">\n                <div class=\"text-center p-6 bg-gray-900 rounded-lg\">\n                    <i class=\"fas fa-wine-bottle text-4xl prime-gold mb-4 block\"></i>\n                    <h3 class=\"text-xl font-bold text-gray-100 mb-2\">Cabernet Sauvignon</h3>\n                    <p class=\"text-gray-400 text-sm\">Premium Napa Valley & Bordeaux selections</p>\n                    <p class=\"text-gray-500 text-xs mt-3\">Starting at $85</p>\n                </div>\n                <div class=\"text-center p-6 bg-gray-900 rounded-lg\">\n                    <i class=\"fas fa-wine-bottle text-4xl prime-gold mb-4 block\"></i>\n                    <h3 class=\"text-xl font-bold text-gray-100 mb-2\">Burgundy Reds</h3>\n                    <p class=\"text-gray-400 text-sm\">Elegant Pinot Noir & Côtes du Rhône</p>\n                    <p class=\"text-gray-500 text-xs mt-3\">Starting at $72</p>\n                </div>\n                <div class=\"text-center p-6 bg-gray-900 rounded-lg\">\n                    <i class=\"fas fa-champagne-glass text-4xl prime-gold mb-4 block\"></i>\n                    <h3 class=\"text-xl font-bold text-gray-100 mb-2\">Premium Champagne</h3>\n                    <p class=\"text-gray-400 text-sm\">Prestigious houses & prestigious vintages</p>\n                    <p class=\"text-gray-500 text-xs mt-3\">Starting at $98</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Reservations -->\n    <section id=\"reservations\" class=\"py-24 px-4 bg-gray-900\">\n        <div class=\"max-w-4xl mx-auto text-center\">\n            <h2 class=\"text-5xl font-bold prime-gold mb-12\">Plan Your Visit</h2>\n            <div class=\"grid md:grid-cols-3 gap-8 mb-12\">\n                <div>\n                    <i class=\"fas fa-map-marker-alt text-4xl prime-gold mb-4 block\"></i>\n                    <p class=\"font-bold text-gray-100 text-lg\">123 Timber Ridge Drive</p>\n                    <p class=\"text-gray-400\">Mountain View District</p>\n                </div>\n                <div>\n                    <i class=\"fas fa-phone text-4xl prime-gold mb-4 block\"></i>\n                    <p class=\"font-bold text-gray-100 text-lg\">+1 (555) 567-8901</p>\n                    <p class=\"text-gray-400\">Reservations Only</p>\n                </div>\n                <div>\n                    <i class=\"fas fa-clock text-4xl prime-gold mb-4 block\"></i>\n                    <p class=\"font-bold text-gray-100 text-lg\">Tue-Sun 5PM-11PM</p>\n                    <p class=\"text-gray-400\">Monday: Closed</p>\n                </div>\n            </div>\n            <button onclick=\"openReserve()\" class=\"wood-accent text-white px-10 py-3 rounded font-bold text-lg hover:opacity-90 transition\">Make a Reservation</button>\n        </div>\n    </section>\n\n    <!-- Modal -->\n    <div id=\"reserveModal\" class=\"hidden fixed inset-0 bg-black bg-opacity-80 z-50 flex items-center justify-center p-4\">\n        <div class=\"bg-gray-900 rounded-lg max-w-md w-full p-8 border border-yellow-600\">\n            <h3 class=\"text-2xl font-bold prime-gold mb-6\">Reserve Your Table</h3>\n            <form onsubmit=\"submitReserve(event)\" class=\"space-y-4\">\n                <input type=\"text\" placeholder=\"Name\" required class=\"w-full bg-gray-800 border border-gray-700 px-4 py-2 rounded text-gray-100 focus:outline-none focus:border-yellow-600\">\n                <input type=\"email\" placeholder=\"Email\" required class=\"w-full bg-gray-800 border border-gray-700 px-4 py-2 rounded text-gray-100 focus:outline-none focus:border-yellow-600\">\n                <input type=\"date\" required class=\"w-full bg-gray-800 border border-gray-700 px-4 py-2 rounded text-gray-100 focus:outline-none focus:border-yellow-600\">\n                <input type=\"time\" required class=\"w-full bg-gray-800 border border-gray-700 px-4 py-2 rounded text-gray-100 focus:outline-none focus:border-yellow-600\">\n                <input type=\"number\" min=\"1\" max=\"12\" placeholder=\"Guests\" required class=\"w-full bg-gray-800 border border-gray-700 px-4 py-2 rounded text-gray-100 focus:outline-none focus:border-yellow-600\">\n                <button type=\"submit\" class=\"w-full wood-accent text-white py-2 rounded font-bold hover:opacity-90\">Reserve</button>\n                <button type=\"button\" onclick=\"closeReserve()\" class=\"w-full border border-gray-700 py-2 rounded font-semibold text-gray-300 hover:bg-gray-800\">Cancel</button>\n            </form>\n        </div>\n    </div>\n\n    <!-- Footer -->\n    <footer class=\"bg-black text-gray-500 py-8 px-4 text-center border-t border-yellow-600\">\n        <p>&copy; 2024 Timber Creek Steakhouse. Prime. Aged. Perfect.</p>\n    </footer>\n\n    <script>\n        function toggleMenu() { const modal = document.getElementById('reserveModal'); modal ? modal.classList.toggle('hidden') : null; }\n        function openReserve() { document.getElementById('reserveModal').classList.remove('hidden'); }\n        function closeReserve() { document.getElementById('reserveModal').classList.add('hidden'); }\n        function submitReserve(e) { e.preventDefault(); alert('Reservation confirmed!'); closeReserve(); }\n    </script>\n</body>\n</html>",
