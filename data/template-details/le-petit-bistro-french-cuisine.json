8 items-center\">\n                <li><a href=\"#about\" class=\"text-gray-900 hover:text-yellow-600 transition font-semibold\">About</a></li>\n                <li><a href=\"#menu\" class=\"text-gray-900 hover:text-yellow-600 transition font-semibold\">Menu</a></li>\n                <li><a href=\"#wine\" class=\"text-gray-900 hover:text-yellow-600 transition font-semibold\">Wine</a></li>\n                <li><a href=\"#contact\" class=\"text-gray-900 hover:text-yellow-600 transition font-semibold\">Contact</a></li>\n                <li><button onclick=\"openReserve()\" class=\"navyy text-white px-6 py-2 rounded hover:bg-blue-900 transition font-bold\">Reserve</button></li>\n            </ul>\n        </div>\n    </nav>\n    <div id=\"mobileNavMenu\" class=\"hidden md:hidden bg-white border-b border-gray-200 shadow-lg\">\n        <ul class=\"flex flex-col gap-0 py-2\">\n            <li><a href=\"#about\" class=\"text-gray-900 hover:text-yellow-600 transition font-semibold block py-3 px-4\">About</a></li>\n            <li><a href=\"#menu\" class=\"text-gray-900 hover:text-yellow-600 transition font-semibold block py-3 px-4\">Menu</a></li>\n            <li><a href=\"#wine\" class=\"text-gray-900 hover:text-yellow-600 transition font-semibold block py-3 px-4\">Wine</a></li>\n            <li><a href=\"#contact\" class=\"text-gray-900 hover:text-yellow-600 transition font-semibold block py-3 px-4\">Contact</a></li>\n            <li class=\"px-4 py-2\"><button onclick=\"openReserve()\" class=\"navy text-white px-6 py-2 rounded hover:bg-blue-900 transition font-bold w-full\">Reserve</button></li>\n        </ul>\n    </div>\n    <script>\n        function toggleMobileNav() { document.getElementById('mobileNavMenu').classList.toggle('hidden'); }\n    </script>\n\n    <!-- Hero -->\n    <section class=\"relative py-32 px-4\"\n        style=\"background-image: url('https://images.unsplash.com/photo-1504674900152-b8b35e7fc369?w=1200&h=600&fit=crop'); background-size: cover; background-position: center; background-attachment: fixed;\">\n        <div class=\"absolute inset-0 bg-black/40\"></div>\n        <div class=\"max-w-4xl mx-auto text-center relative z-10 text-white\">\n            <h1 class=\"text-7xl mb-4 font-bold\">LE PETIT BISTRO</h1>\n            <p class=\"text-2xl mb-4 font-light\">Classical French Dining</p>\n            <p class=\"text-lg mb-8 max-w-2xl mx-auto\">Discover the elegance of French bistro culture in our intimate\n                1920s-inspired restaurant</p>\n            <button onclick=\"openReserve()\"\n                class=\"bg-yellow-500 text-black px-8 py-3 rounded font-bold text-lg hover:bg-yellow-400 transition mr-4\">Réserver</button>\n            <button onclick=\"document.getElementById('menu').scrollIntoView()\"\n                class=\"border-2 border-yellow-500 text-yellow-500 px-8 py-3 rounded font-bold hover:bg-yellow-500 hover:text-black transition\">Carte</button>\n        </div>\n    </section>\n\n    <!-- About -->\n    <section id=\"about\" class=\"py-20 px-4 bg-white\">\n        <div class=\"max-w-6xl mx-auto\">\n            <div class=\"grid md:grid-cols-2 gap-12 items-center\">\n                <div>\n                    <h2 class=\"text-5xl font-bold navy mb-6\">Our Heritage</h2>\n                    <p class=\"text-gray-700 text-lg mb-4 leading-relaxed\">Founded in 1985, Le Petit Bistro brings\n                        authentic Parisian bistro culture to the heart of our city. Our chef trained in Lyon and Paris,\n                        mastering the classical techniques of French cuisine.</p>\n                    <p class=\"text-gray-700 text-lg mb-4 leading-relaxed\">We honor traditions while celebrating the best\n                        of seasonal ingredients. From coq au vin to duck confit, every dish is prepared with precision\n                        and passion.</p>\n                    <div class=\"space-y-2 text-gray-700\">\n                        <p><i class=\"fas fa-check gold-accent mr-2\"></i> Chef-Trained in Paris & Lyon</p>\n                        <p><i class=\"fas fa-check gold-accent mr-2\"></i> Extensive French Wine List</p>\n                        <p><i class=\"fas fa-check gold-accent mr-2\"></i> Seasonal Menu</p>\n                        <p><i class=\"fas fa-check gold-accent mr-2\"></i> Private Dining</p>\n                    </div>\n                </div>\n                <div\n                    class=\"bg-gradient-to-br from-yellow-100 to-orange-100 h-96 rounded-lg flex items-center justify-center text-5xl text-gray-700\">\n                    <img src=\"https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=500&h=500&fit=crop\"\n                        alt=\"French Cuisine\" class=\"w-full h-full object-cover rounded-lg shadow-lg\">\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Menu -->\n    <section id=\"menu\" class=\"py-20 px-4 bg-gray-50\">\n        <div class=\"max-w-6xl mx-auto\">\n            <h2 class=\"text-5xl font-bold navy text-center mb-4\">Carte du Jour</h2>\n            <p class=\"text-center text-gray-600 mb-12 text-lg\">Daily selections from our classical French kitchen</p>\n\n            <div class=\"grid md:grid-cols-2 gap-8\">\n                <!-- Starters -->\n                <div>\n                    <h3 class=\"text-3xl font-bold navy mb-6 pb-3 border-b-2 border-yellow-500\">Entrées</h3>\n                    <div class=\"space-y-6\">\n                        <div class=\"bg-white p-4 rounded border-l-4 border-yellow-500\">\n                            <h4 class=\"text-xl font-bold text-gray-900 mb-1\">Soupe à l'Oignon</h4>\n                            <p class=\"text-gray-600 text-sm mb-2\">French onion soup with Gruyère</p>\n                            <p class=\"gold-accent font-bold\">$14</p>\n                        </div>\n                        <div class=\"bg-white p-4 rounded border-l-4 border-yellow-500\">\n                            <h4 class=\"text-xl font-bold text-gray-900 mb-1\">Escargots de Bourgogne</h4>\n                            <p class=\"text-gray-600 text-sm mb-2\">Snails in herb butter</p>\n                            <p class=\"gold-accent font-bold\">$18</p>\n                        </div>\n                        <div class=\"bg-white p-4 rounded border-l-4 border-yellow-500\">\n                            <h4 class=\"text-xl font-bold text-gray-900 mb-1\">Salade Niçoise</h4>\n                            <p class=\"text-gray-600 text-sm mb-2\">Tuna, eggs, anchovies, olives</p>\n                            <p class=\"gold-accent font-bold\">$16</p>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Mains -->\n                <div>\n                    <h3 class=\"text-3xl font-bold navy mb-6 pb-3 border-b-2 border-yellow-500\">Plats Principaux</h3>\n                    <div class=\"space-y-6\">\n                        <div class=\"bg-white p-4 rounded border-l-4 border-yellow-500\">\n                            <h4 class=\"text-xl font-bold text-gray-900 mb-1\">Coq au Vin</h4>\n                            <p class=\"text-gray-600 text-sm mb-2\">Chicken braised in Burgundy wine</p>\n                            <p class=\"gold-accent font-bold\">$32</p>\n                        </div>\n                        <div class=\"bg-white p-4 rounded border-l-4 border-yellow-500\">\n                            <h4 class=\"text-xl font-bold text-gray-900 mb-1\">Duck Confit</h4>\n                            <p class=\"text-gray-600 text-sm mb-2\">Slow-roasted duck leg with seasonal vegetables</p>\n                            <p class=\"gold-accent font-bold\">$36</p>\n                        </div>\n                        <div class=\"bg-white p-4 rounded border-l-4 border-yellow-500\">\n                            <h4 class=\"text-xl font-bold text-gray-900 mb-1\">Bouillabaisse</h4>\n                            <p class=\"text-gray-600 text-sm mb-2\">Provençal fish stew with rouille</p>\n                            <p class=\"gold-accent font-bold\">$38</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Wine -->\n    <section id=\"wine\" class=\"py-20 px-4 bg-white\">\n        <div class=\"max-w-4xl mx-auto text-center\">\n            <h2 class=\"text-5xl font-bold navy mb-6\">Our Wine Cellar</h2>\n            <p class=\"text-gray-600 text-lg mb-12\">Curated selection from France's finest regions</p>\n            <div class=\"grid md:grid-cols-3 gap-8\">\n                <div class=\"p-6 bg-gray-50 rounded\">\n                    <i class=\"fas fa-wine-glass text-4xl gold-accent mb-4 block\"></i>\n                    <h3 class=\"text-xl font-bold navy mb-2\">Burgundy</h3>\n                    <p class=\"text-gray-600\">Pinot Noir and Chardonnay excellence</p>\n                </div>\n                <div class=\"p-6 bg-gray-50 rounded\">\n                    <i class=\"fas fa-wine-bottle text-4xl gold-accent mb-4 block\"></i>\n                    <h3 class=\"text-xl font-bold navy mb-2\">Bordeaux</h3>\n                    <p class=\"text-gray-600\">Bold reds and elegant blends</p>\n                </div>\n                <div class=\"p-6 bg-gray-50 rounded\">\n                    <i class=\"fas fa-champagne-glass text-4xl gold-accent mb-4 block\"></i>\n                    <h3 class=\"text-xl font-bold navy mb-2\">Champagne</h3>\n                    <p class=\"text-gray-600\">Premium selections for celebration</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Contact & CTA -->\n    <section id=\"contact\" class=\"py-20 px-4 navyy text-white\">\n        <div class=\"max-w-4xl mx-auto text-center\">\n            <h2 class=\"text-5xl font-bold mb-12\">Visit Us</h2>\n            <div class=\"grid md:grid-cols-3 gap-8 mb-12\">\n                <div>\n                    <i class=\"fas fa-map-marker-alt text-3xl gold-accent mb-4 block\"></i>\n                    <p class=\"font-semibold\">456 Seine Street</p>\n                    <p class=\"text-gray-300\">Paris District</p>\n                </div>\n                <div>\n                    <i class=\"fas fa-phone text-3xl gold-accent mb-4 block\"></i>\n                    <p class=\"font-semibold\">+1 (555) 345-6789</p>\n                    <p class=\"text-gray-300\">Call for reservations</p>\n                </div>\n                <div>\n                    <i class=\"fas fa-clock text-3xl gold-accent mb-4 block\"></i>\n                    <p class=\"font-semibold\">Tue-Sun 6PM-11PM</p>\n                    <p class=\"text-gray-300\">Monday: Closed</p>\n                </div>\n            </div>\n            <button onclick=\"openReserve()\"\n                class=\"bg-yellow-500 text-black px-10 py-3 rounded font-bold text-lg hover:bg-yellow-400 transition\">Make\n                a Reservation</button>\n        </div>\n    </section>\n\n    <!-- Modal -->\n    <div id=\"reserveModal\"\n        class=\"hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4\">\n        <div class=\"bg-white rounded-lg max-w-md w-full p-8\">\n            <h3 class=\"text-2xl font-bold navy mb-6\">Réserver Une Table</h3>\n            <form onsubmit=\"submitReserve(event)\" class=\"space-y-4\">\n                <input type=\"text\" placeholder=\"Name\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-yellow-500\">\n                <input type=\"email\" placeholder=\"Email\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-yellow-500\">\n                <input type=\"date\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-yellow-500\">\n                <input type=\"time\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-yellow-500\">\n                <input type=\"number\" min=\"1\" max=\"10\" placeholder=\"Guests\" required\n                    class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-yellow-500\">\n                <button type=\"submit\"\n                    class=\"w-full navyy text-white py-2 rounded font-bold hover:bg-blue-900\">Reserve</button>\n                <button type=\"button\" onclick=\"closeReserve()\"\n                    class=\"w-full border border-gray-300 py-2 rounded font-semibold text-gray-700 hover:bg-gray-50\">Cancel</button>\n            </form>\n        </div>\n    </div>\n\n    <!-- Footer -->\n    <footer class=\"navyy text-gray-300 py-8 px-4 text-center\">\n        <p>&copy; 2024 Le Petit Bistro. Bonjour et Bon Appétit!</p>\n    </footer>\n\n    <script>\n        function openReserve() { document.getElementById('reserveModal').classList.remove('hidden'); }\n        function closeReserve() { document.getElementById('reserveModal').classList.add('hidden'); }\n        function submitReserve(e) { e.preventDefault(); alert('Reservation confirmed!'); closeReserve(); }\n    </script>\n</body>\n\n</html>",
