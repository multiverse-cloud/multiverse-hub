700 hover:text-orange-600 transition font-medium\">Results</a>\n                <a href=\"#team\" class=\"text-gray-700 hover:text-orange-600 transition font-medium\">Team</a>\n                <a href=\"#contact\" class=\"text-gray-700 hover:text-orange-600 transition font-medium\">Contact</a>\n                <button onclick=\"openModal()\" class=\"gradient-forge text-white px-6 py-2 rounded-lg font-bold hover:shadow-lg transition\">Get Proposal</button>\n            </nav>\n            <button id=\"mobileMenuBtn\" class=\"lg:hidden text-gray-900\" onclick=\"toggleMobileMenu()\">\n                <i class=\"fas fa-bars text-2xl\"></i>\n            </button>\n        </div>\n        <div id=\"mobileMenu\" class=\"hidden lg:hidden bg-white border-t border-gray-200\">\n            <div class=\"px-4 py-4 space-y-3\">\n                <a href=\"#services\" class=\"block text-gray-700 hover:text-orange-600 py-2 font-medium\">Services</a>\n                <a href=\"#results\" class=\"block text-gray-700 hover:text-orange-600 py-2 font-medium\">Results</a>\n                <a href=\"#team\" class=\"block text-gray-700 hover:text-orange-600 py-2 font-medium\">Team</a>\n                <a href=\"#contact\" class=\"block text-gray-700 hover:text-orange-600 py-2 font-medium\">Contact</a>\n                <button onclick=\"openModal()\" class=\"w-full gradient-forge text-white py-2 rounded-lg font-bold\">Get Proposal</button>\n            </div>\n        </div>\n    </header>\n\n    <section class=\"pt-32 pb-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-br from-orange-50 to-amber-50\">\n        <div class=\"max-w-7xl mx-auto\">\n            <div class=\"grid lg:grid-cols-2 gap-12 items-center\">\n                <div>\n                    <span class=\"inline-block px-4 py-2 bg-orange-100 text-orange-700 rounded-full text-sm font-bold mb-6\">Growth Marketing Experts</span>\n                    <h1 class=\"text-6xl lg:text-7xl font-bold text-gray-900 mb-6 leading-tight\">\n            