d mb-4\">Contact</h4>\n                    <ul class=\"space-y-2 text-sm\">\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Email</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Phone</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Address</a></li>\n                    </ul>\n                </div>\n            </div>\n            <div class=\"border-t border-gray-700 pt-8 text-center text-sm\">\n                <p class=\"text-center text-gray-400 text-sm\">Created by <a href=\"https://devweavex.netlify.app/\" class=\"text-gray-300 hover:text-white transition\">DevWeaveX</a> — <a href=\"https://faizyab-hussain.vercel.app/\" class=\"text-gray-300 hover:text-white transition\">Syed Faizyab Hussain</a> & <a href=\"https://www.linkedin.com/in/syed-danish-raza/\" class=\"text-gray-300 hover:text-white transition\">Syed Danish Raza</a></p>\n                <p>&copy; 2026 BrandForge. All rights reserved.</p>\n            </div>\n        </div>\n    </footer>\n\n    <div id=\"proposalModal\" class=\"modal-hide fixed inset-0 bg-black bg-opacity-50 z-50 items-center justify-center p-4\">\n        <div class=\"bg-white rounded-xl shadow-2xl max-w-md w-full p-8\">\n            <div class=\"flex justify-between items-center mb-6\">\n                <h3 class=\"text-2xl font-bold text-gray-900\">Get Your Proposal</h3>\n                <button onclick=\"closeModal()\" class=\"text-gray-600 hover:text-gray-900\">\n                    <i class=\"fas fa-times text-2xl\"></i>\n                </button>\n            </div>\n            <form class=\"space-y-4\">\n                <input type=\"text\" placeholder=\"Your Name\" class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-orange-600 focus:ring-1 focus:ring-orange-600\">\n                <input type=\"email\" placeholder=\"Email\" class=\"w-full px-4 py-3 border border-gray-300 