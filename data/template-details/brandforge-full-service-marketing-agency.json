  "previewHtml": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"description\" content=\"BrandForge - Full-service marketing agency. Digital marketing, content, social media, SEO, paid ads.\">\n    <meta name=\"keywords\" content=\"marketing agency, digital marketing, SEO, social media marketing, content marketing\">\n    <title>BrandForge - Full-Service Marketing Agency</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Sora:wght@400;600&display=swap\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n    <style>\n        * { font-family: 'Outfit', sans-serif; }\n        h1, h2, h3 { font-family: 'Sora', sans-serif; }\n        .gradient-forge { background: linear-gradient(135deg, #f97316 0%, #fb923c 100%); }\n        .modal-hide { display: none; }\n        .modal-hide.open { display: flex; }\n    </style>\n    <!-- Page Loader -->\n    \n</head>\n<body class=\"bg-white\">\n    <header class=\"fixed top-0 w-full bg-white z-50 border-b border-gray-200 shadow-sm\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center\">\n            <div class=\"flex items-center gap-3\">\n                <div class=\"w-10 h-10 gradient-forge rounded-lg flex items-center justify-center\">\n                    <i class=\"fas fa-fire text-white font-bold\"></i>\n                </div>\n                <span class=\"text-xl font-bold text-gray-900\">BrandForge</span>\n            </div>\n            <nav class=\"hidden lg:flex gap-10 items-center\">\n                <a href=\"#services\" class=\"text-gray-700 hover:text-orange-600 transition font-medium\">Services</a>\n                <a href=\"#results\" class=\"text-gray-700 hover:text-orange-600 transition font-medium\">Results</a>\n                <a href=\"#team\" class=\"text-gray-700 hover:text-orange-600 transition font-medium\">Team</a>\n                <a href=\"#contact\" class=\"text-gray-700 hover:text-orange-600 transition font-medium\">Contact</a>\n                <button onclick=\"openModal()\" class=\"gradient-forge text-white px-6 py-2 rounded-lg font-bold hover:shadow-lg transition\">Get Proposal</button>\n            </nav>\n            <button id=\"mobileMenuBtn\" class=\"lg:hidden text-gray-900\" onclick=\"toggleMobileMenu()\">\n                <i class=\"fas fa-bars text-2xl\"></i>\n            </button>\n        </div>\n        <div id=\"mobileMenu\" class=\"hidden lg:hidden bg-white border-t border-gray-200\">\n            <div class=\"px-4 py-4 space-y-3\">\n                <a href=\"#services\" class=\"block text-gray-700 hover:text-orange-600 py-2 font-medium\">Services</a>\n                <a href=\"#results\" class=\"block text-gray-700 hover:text-orange-600 py-2 font-medium\">Results</a>\n                <a href=\"#team\" class=\"block text-gray-700 hover:text-orange-600 py-2 font-medium\">Team</a>\n                <a href=\"#contact\" class=\"block text-gray-700 hover:text-orange-600 py-2 font-medium\">Contact</a>\n                <button onclick=\"openModal()\" class=\"w-full gradient-forge text-white py-2 rounded-lg font-bold\">Get Proposal</button>\n            </div>\n        </div>\n    </header>\n\n    <section class=\"pt-32 pb-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-br from-orange-50 to-amber-50\">\n        <div class=\"max-w-7xl mx-auto\">\n            <div class=\"grid lg:grid-cols-2 gap-12 items-center\">\n                <div>\n                    <span class=\"inline-block px-4 py-2 bg-orange-100 text-orange-700 rounded-full text-sm font-bold mb-6\">Growth Marketing Experts</span>\n                    <h1 class=\"text-6xl lg:text-7xl font-bold text-gray-900 mb-6 leading-tight\">\n                        Grow Your\n                        <span class=\"gradient-forge bg-clip-text text-transparent\"> Brand</span>\n                    </h1>\n                    <p class=\"text-xl text-gray-600 mb-10 leading-relaxed\">\n                        Data-driven marketing strategies that increase leads, sales, and brand awareness.\n                    </p>\n                    <div class=\"flex flex-col sm:flex-row gap-4\">\n                        <button onclick=\"openModal()\" class=\"gradient-forge text-white px-8 py-4 rounded-lg font-bold hover:shadow-xl transition text-lg\">\n                            Get Free Strategy\n                        </button>\n                        <button class=\"border-2 border-orange-600 text-orange-600 px-8 py-4 rounded-lg font-bold hover:bg-orange-50 transition text-lg\">\n                            View Case Studies\n                        </button>\n                    </div>\n                    <div class=\"mt-12 space-y-4\">\n                        <div class=\"flex gap-3\">\n                            <i class=\"fas fa-check text-orange-600 text-2xl\"></i>\n                            <div>\n                                <p class=\"font-bold text-gray-900\">80+ Successful Campaigns</p>\n                                <p class=\"text-sm text-gray-600\">Delivered across all industries</p>\n                            </div>\n                        </div>\n                        <div class=\"flex gap-3\">\n                            <i class=\"fas fa-check text-orange-600 text-2xl\"></i>\n                            <div>\n                                <p class=\"font-bold text-gray-900\">Avg 3.5x ROI</p>\n                                <p class=\"text-sm text-gray-600\">On marketing investments</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"hidden lg:block relative\">\n                    <img src=\"https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=500&h=400&fit=crop\" alt=\"Marketing\" class=\"rounded-xl shadow-2xl\">\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <section id=\"services\" class=\"py-20 px-4 sm:px-6 lg:px-8 bg-white\">\n        <div class=\"max-w-6xl mx-auto\">\n            <h2 class=\"text-4xl lg:text-5xl font-bold text-gray-900 mb-16 text-center\">Our Services</h2>\n            <div class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-8\">\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-orange-500 transition\">\n                    <div class=\"w-12 h-12 gradient-forge rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-search text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">SEO & Content</h3>\n                    <p class=\"text-gray-600 mb-6\">Organic search optimization. Keyword research, content strategy, link building.</p>\n                    <ul class=\"space-y-2 text-sm text-gray-700\">\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>Technical SEO</li>\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>Content marketing</li>\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>Link building</li>\n                    </ul>\n                </div>\n\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-orange-500 transition\">\n                    <div class=\"w-12 h-12 gradient-forge rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-ad text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Paid Advertising</h3>\n                    <p class=\"text-gray-600 mb-6\">Google Ads, Facebook, Instagram, LinkedIn campaigns. Optimized for conversions.</p>\n                    <ul class=\"space-y-2 text-sm text-gray-700\">\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>Google Ads</li>\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>Social ads</li>\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>Retargeting</li>\n                    </ul>\n                </div>\n\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-orange-500 transition\">\n                    <div class=\"w-12 h-12 gradient-forge rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-share-alt text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Social Media</h3>\n                    <p class=\"text-gray-600 mb-6\">Content creation, community management, influencer partnerships. Brand growth.</p>\n                    <ul class=\"space-y-2 text-sm text-gray-700\">\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>Content calendar</li>\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>Community mgmt</li>\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>Analytics</li>\n                    </ul>\n                </div>\n\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-orange-500 transition\">\n                    <div class=\"w-12 h-12 gradient-forge rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-envelope text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Email Marketing</h3>\n                    <p class=\"text-gray-600 mb-6\">Campaigns, automation, segmentation. High conversion rates and engagement.</p>\n                    <ul class=\"space-y-2 text-sm text-gray-700\">\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>Campaign design</li>\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>Automation</li>\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>A/B testing</li>\n                    </ul>\n                </div>\n\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-orange-500 transition\">\n                    <div class=\"w-12 h-12 gradient-forge rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-chart-bar text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Analytics & Reporting</h3>\n                    <p class=\"text-gray-600 mb-6\">Data analysis, performance tracking, insights, and strategic recommendations.</p>\n                    <ul class=\"space-y-2 text-sm text-gray-700\">\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>GA4 setup</li>\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>Monthly reports</li>\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>Optimization</li>\n                    </ul>\n                </div>\n\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-orange-500 transition\">\n                    <div class=\"w-12 h-12 gradient-forge rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-strategy text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Strategy & Consulting</h3>\n                    <p class=\"text-gray-600 mb-6\">Market analysis, competitor research, growth planning, brand positioning.</p>\n                    <ul class=\"space-y-2 text-sm text-gray-700\">\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>Market analysis</li>\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>Strategy planning</li>\n                        <li><i class=\"fas fa-check text-orange-600 mr-2\"></i>Roadmapping</li>\n                    </ul>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <section id=\"results\" class=\"py-20 px-4 sm:px-6 lg:px-8 bg-gray-50\">\n        <div class=\"max-w-6xl mx-auto\">\n            <h2 class=\"text-4xl lg:text-5xl font-bold text-gray-900 mb-16 text-center\">Results We Deliver</h2>\n            <div class=\"grid md:grid-cols-4 gap-8\">\n                <div class=\"bg-white p-8 rounded-xl shadow-md text-center\">\n                    <div class=\"text-4xl font-bold text-orange-600 mb-2\">350%</div>\n                    <p class=\"text-gray-600\">Avg lead increase</p>\n                </div>\n                <div class=\"bg-white p-8 rounded-xl shadow-md text-center\">\n                    <div class=\"text-4xl font-bold text-orange-600 mb-2\">2.8x</div>\n                    <p class=\"text-gray-600\">Avg ROI within 6 months</p>\n                </div>\n                <div class=\"bg-white p-8 rounded-xl shadow-md text-center\">\n                    <div class=\"text-4xl font-bold text-orange-600 mb-2\">80+</div>\n                    <p class=\"text-gray-600\">Successful campaigns</p>\n                </div>\n                <div class=\"bg-white p-8 rounded-xl shadow-md text-center\">\n                    <div class=\"text-4xl font-bold text-orange-600 mb-2\">98%</div>\n                    <p class=\"text-gray-600\">Client retention rate</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <section id=\"team\" class=\"py-20 px-4 sm:px-6 lg:px-8 bg-white\">\n        <div class=\"max-w-6xl mx-auto\">\n            <h2 class=\"text-4xl lg:text-5xl font-bold text-gray-900 mb-16 text-center\">Meet Our Team</h2>\n            <div class=\"grid md:grid-cols-2 lg:grid-cols-4 gap-8\">\n                <div class=\"text-center\">\n                    <div class=\"w-24 h-24 bg-orange-300 rounded-full mx-auto mb-4\"></div>\n                    <h3 class=\"text-lg font-bold text-gray-900 mb-1\">Lisa Chen</h3>\n                    <p class=\"text-orange-600 font-bold text-sm mb-2\">Founder & CEO</p>\n                    <p class=\"text-gray-600 text-sm\">15+ years in marketing</p>\n                </div>\n                <div class=\"text-center\">\n                    <div class=\"w-24 h-24 bg-orange-400 rounded-full mx-auto mb-4\"></div>\n                    <h3 class=\"text-lg font-bold text-gray-900 mb-1\">David Park</h3>\n                    <p class=\"text-orange-600 font-bold text-sm mb-2\">SEO & Content Lead</p>\n                    <p class=\"text-gray-600 text-sm\">Organic growth specialist</p>\n                </div>\n                <div class=\"text-center\">\n                    <div class=\"w-24 h-24 bg-orange-500 rounded-full mx-auto mb-4\"></div>\n                    <h3 class=\"text-lg font-bold text-gray-900 mb-1\">Jennifer Lee</h3>\n                    <p class=\"text-orange-600 font-bold text-sm mb-2\">Paid Ads Strategist</p>\n                    <p class=\"text-gray-600 text-sm\">PPC & conversion expert</p>\n                </div>\n                <div class=\"text-center\">\n                    <div class=\"w-24 h-24 bg-orange-600 rounded-full mx-auto mb-4\"></div>\n                    <h3 class=\"text-lg font-bold text-gray-900 mb-1\">Marcus Brown</h3>\n                    <p class=\"text-orange-600 font-bold text-sm mb-2\">Analytics Manager</p>\n                    <p class=\"text-gray-600 text-sm\">Data-driven insights</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <section id=\"contact\" class=\"py-20 px-4 sm:px-6 lg:px-8 gradient-forge text-white\">\n        <div class=\"max-w-4xl mx-auto text-center\">\n            <h2 class=\"text-4xl lg:text-5xl font-bold mb-6\">Ready to Grow?</h2>\n            <p class=\"text-xl mb-10 opacity-90\">Get your free marketing strategy proposal today.</p>\n            <button onclick=\"openModal()\" class=\"bg-white text-orange-600 px-10 py-4 rounded-lg font-bold hover:shadow-2xl transition text-lg hover:bg-gray-100\">\n                Get Free Proposal\n            </button>\n        </div>\n    </section>\n\n    <footer class=\"bg-gray-900 text-gray-400 py-12 px-4 sm:px-6 lg:px-8\">\n        <div class=\"max-w-6xl mx-auto\">\n            <div class=\"grid md:grid-cols-4 gap-8 mb-8\">\n                <div>\n                    <h4 class=\"text-white font-bold mb-4\">BrandForge</h4>\n                    <p class=\"text-sm\">Growth marketing agency. Data-driven results.</p>\n                </div>\n                <div>\n                    <h4 class=\"text-white font-bold mb-4\">Services</h4>\n                    <ul class=\"space-y-2 text-sm\">\n                        <li><a href=\"#\" class=\"hover:text-white transition\">SEO</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Paid Ads</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Social</a></li>\n                    </ul>\n                </div>\n                <div>\n                    <h4 class=\"text-white font-bold mb-4\">Company</h4>\n                    <ul class=\"space-y-2 text-sm\">\n                        <li><a href=\"#\" class=\"hover:text-white transition\">About</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Blog</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Careers</a></li>\n                    </ul>\n                </div>\n                <div>\n                    <h4 class=\"text-white font-bold mb-4\">Contact</h4>\n                    <ul class=\"space-y-2 text-sm\">\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Email</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Phone</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Address</a></li>\n                    </ul>\n                </div>\n            </div>\n            <div class=\"border-t border-gray-700 pt-8 text-center text-sm\">\n                <p class=\"text-center text-gray-400 text-sm\">Created by <a href=\"https://devweavex.netlify.app/\" class=\"text-gray-300 hover:text-white transition\">DevWeaveX</a> — <a href=\"https://faizyab-hussain.vercel.app/\" class=\"text-gray-300 hover:text-white transition\">Syed Faizyab Hussain</a> & <a href=\"https://www.linkedin.com/in/syed-danish-raza/\" class=\"text-gray-300 hover:text-white transition\">Syed Danish Raza</a></p>\n                <p>&copy; 2026 BrandForge. All rights reserved.</p>\n            </div>\n        </div>\n    </footer>\n\n    <div id=\"proposalModal\" class=\"modal-hide fixed inset-0 bg-black bg-opacity-50 z-50 items-center justify-center p-4\">\n        <div class=\"bg-white rounded-xl shadow-2xl max-w-md w-full p-8\">\n            <div class=\"flex justify-between items-center mb-6\">\n                <h3 class=\"text-2xl font-bold text-gray-900\">Get Your Proposal</h3>\n                <button onclick=\"closeModal()\" class=\"text-gray-600 hover:text-gray-900\">\n                    <i class=\"fas fa-times text-2xl\"></i>\n                </button>\n            </div>\n            <form class=\"space-y-4\">\n                <input type=\"text\" placeholder=\"Your Name\" class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-orange-600 focus:ring-1 focus:ring-orange-600\">\n                <input type=\"email\" placeholder=\"Email\" class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-orange-600 focus:ring-1 focus:ring-orange-600\">\n                <input type=\"tel\" placeholder=\"Phone\" class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-orange-600 focus:ring-1 focus:ring-orange-600\">\n                <select class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-orange-600 focus:ring-1 focus:ring-orange-600\">\n                    <option>Primary Interest</option>\n                    <option>SEO</option>\n                    <option>Paid Ads</option>\n                    <option>Social Media</option>\n                    <option>Full Service</option>\n                </select>\n                <button type=\"submit\" class=\"w-full gradient-forge text-white py-3 rounded-lg font-bold hover:shadow-lg transition\">\n                    Get Proposal\n                </button>\n            </form>\n        </div>\n    </div>\n\n    <script>\n        function toggleMobileMenu() {\n            document.getElementById('mobileMenu').classList.toggle('hidden');\n        }\n        function openModal() {\n            document.getElementById('proposalModal').classList.add('open');\n        }\n        function closeModal() {\n            document.getElementById('proposalModal').classList.remove('open');\n        }\n        document.addEventListener('click', (e) => {\n            const modal = document.getElementById('proposalModal');\n            if (e.target === modal) closeModal();\n        });\n        document.querySelectorAll('a[href^=\"#\"]').forEach(anchor => {\n            anchor.addEventListener('click', function (e) {\n                e.preventDefault();\n                const target = document.querySelector(this.getAttribute('href'));\n                if (target) {\n                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });\n                    document.getElementById('mobileMenu').classList.add('hidden');\n                }\n            });\n        });\n    </script>\n</body>\n</html>",
