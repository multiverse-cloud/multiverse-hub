      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"description\" content=\"CreativeStudio - Branding and design agency. Logo design, brand identity, visual content creation.\">\n    <meta name=\"keywords\" content=\"branding, logo design, graphic design, brand identity, creative agency\">\n    <title>CreativeStudio - Branding & Design Agency</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700;800&family=Cormorant+Garamond:wght@400;600&display=swap\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n    <style>\n        * { font-family: 'Raleway', sans-serif; }\n        h1, h2, h3 { font-family: 'Cormorant Garamond', serif; }\n        .gradient-creative { background: linear-gradient(135deg, #ec4899 0%, #f59e0b 100%); }\n        .modal-hide { display: none; }\n        .modal-hide.open { display: flex; }\n    </style>\n    <!-- Page Loader -->\n    \n</head>\n<body class=\"bg-white\">\n    <header class=\"fixed top-0 w-full bg-white z-50 border-b border-gray-200 shadow-sm\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center\">\n            <div class=\"flex items-center gap-3\">\n                <div class=\"w-10 h-10 gradient-creative rounded-lg flex items-center justify-center\">\n                    <i class=\"fas fa-palette text-white font-bold\"></i>\n                </div>\n                <span class=\"text-xl font-bold text-gray-900\">CreativeStudio</span>\n            </div>\n            <nav class=\"hidden lg:flex gap-10 items-center\">\n                <a href=\"#services\" class=\"text-gray-700 hover:text-pink-600 transition font-medium\">Services</a>\n                <a href=\"#work\" class=\"text-gray-700 hover:text-pink-600 transition font-medium\">Work</a>\n                <a href=\"#process\" class=\"text-gray-700 hover:text-pink-600 transition font-medium\">Process</a>\n                <a href=\"#testimonials\" class=\"text-gray-700 hover:text-pink-600 transition font-medium\">Testimonials</a>\n                <button onclick=\"openModal()\" class=\"gradient-creative text-white px-6 py-2 rounded-lg font-bold hover:shadow-lg transition\">Inquire</button>\n            </nav>\n            <button id=\"mobileMenuBtn\" class=\"lg:hidden text-gray-900\" onclick=\"toggleMobileMenu()\">\n                <i class=\"fas fa-bars text-2xl\"></i>\n            </button>\n        </div>\n        <div id=\"mobileMenu\" class=\"hidden lg:hidden bg-white border-t border-gray-200\">\n            <div class=\"px-4 py-4 space-y-3\">\n                <a href=\"#services\" class=\"block text-gray-700 hover:text-pink-600 py-2 font-medium\">Services</a>\n                <a href=\"#work\" class=\"block text-gray-700 hover:text-pink-600 py-2 font-medium\">Work</a>\n                <a href=\"#process\" class=\"block text-gray-700 hover:text-pink-600 py-2 font-medium\">Process</a>\n                <a href=\"#testimonials\" class=\"block text-gray-700 hover:text-pink-600 py-2 font-medium\">Testimonials</a>\n                <button onclick=\"openModal()\" class=\"w-full gradient-creative text-white py-2 rounded-lg font-bold\">Inquire</button>\n            </div>\n        </div>\n    </header>\n\n    <section class=\"pt-32 pb-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-br from-pink-50 to-amber-50\">\n        <div class=\"max-w-7xl mx-auto\">\n            <div class=\"grid lg:grid-cols-2 gap-12 items-center\">\n                <div>\n                    <span class=\"inline-block px-4 py-2 bg-pink-100 text-pink-700 rounded-full text-sm font-bold mb-6\">Creative Excellence</span>\n                    <h1 class=\"text-6xl lg:text-7xl font-bold text-gray-900 mb-6 leading-tight\">\n                        Design That\n                        <span class=\"gradient-creative bg-clip-text text-transparent\"> Tells Your Story</span>\n                    </h1>\n                    <p class=\"text-xl text-gray-600 mb-10 leading-relaxed\">\n                        Award-winning branding and design studio. Transforming ideas into visual masterpieces.\n                    </p>\n                    <div class=\"flex flex-col sm:flex-row gap-4\">\n                        <button onclick=\"openModal()\" class=\"gradient-creative text-white px-8 py-4 rounded-lg font-bold hover:shadow-xl transition text-lg\">\n                            Start Your Project\n                        </button>\n                        <button class=\"border-2 border-pink-600 text-pink-600 px-8 py-4 rounded-lg font-bold hover:bg-pink-50 transition text-lg\">\n                            View Portfolio\n                        </button>\n                    </div>\n                    <div class=\"mt-12 space-y-4\">\n                        <div class=\"flex gap-3\">\n                            <i class=\"fas fa-check text-pink-600 text-2xl\"></i>\n                            <div>\n                                <p class=\"font-bold text-gray-900\">100+ Brands Designed</p>\n                                <p class=\"text-sm text-gray-600\">From startups to Fortune 500</p>\n                            </div>\n                        </div>\n                        <div class=\"flex gap-3\">\n                            <i class=\"fas fa-check text-pink-600 text-2xl\"></i>\n                            <div>\n                                <p class=\"font-bold text-gray-900\">Award-Winning Work</p>\n                                <p class=\"text-sm text-gray-600\">International design awards</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"hidden lg:block relative\">\n                    <img src=\"https://images.unsplash.com/photo-1561070791-2526d30994b5?w=500&h=400&fit=crop\" alt=\"Design\" class=\"rounded-xl shadow-2xl\">\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <section id=\"services\" class=\"py-20 px-4 sm:px-6 lg:px-8 bg-white\">\n        <div class=\"max-w-6xl mx-auto\">\n            <h2 class=\"text-4xl lg:text-5xl font-bold text-gray-900 mb-16 text-center\">What We Create</h2>\n            <div class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-8\">\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-pink-500 transition\">\n                    <div class=\"w-12 h-12 gradient-creative rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-pen-tool text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Brand Identity</h3>\n                    <p class=\"text-gray-600 mb-6\">Complete brand development from concept to execution. Logo, colors, typography, guidelines.</p>\n                </div>\n\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-pink-500 transition\">\n                    <div class=\"w-12 h-12 gradient-creative rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-image text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Visual Design</h3>\n                    <p class=\"text-gray-600 mb-6\">Stunning graphics, illustrations, and visual content. Print and digital design.</p>\n                </div>\n\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-pink-500 transition\">\n                    <div class=\"w-12 h-12 gradient-creative rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-newspaper text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Marketing Design</h3>\n                    <p class=\"text-gray-600 mb-6\">Brochures, posters, social media templates, packaging design, and advertising materials.</p>\n                </div>\n\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-pink-500 transition\">\n                    <div class=\"w-12 h-12 gradient-creative rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-film text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Motion Graphics</h3>\n                    <p class=\"text-gray-600 mb-6\">Animated logos, explainer videos, video content, and visual storytelling.</p>\n                </div>\n\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-pink-500 transition\">\n                    <div class=\"w-12 h-12 gradient-creative rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-mobile-alt text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">UI/UX Design</h3>\n                    <p class=\"text-gray-600 mb-6\">App and website interfaces. User-centered design with stunning aesthetics.</p>\n                </div>\n\n                <div class=\"bg-white p-8 rounded-xl shadow-md border border-gray-200 hover:border-pink-500 transition\">\n                    <div class=\"w-12 h-12 gradient-creative rounded-lg flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-retweet text-white text-xl\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Rebranding</h3>\n                    <p class=\"text-gray-600 mb-6\">Complete brand refresh and repositioning. Transform your visual identity.</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <section id=\"work\" class=\"py-20 px-4 sm:px-6 lg:px-8 bg-gray-50\">\n        <div class=\"max-w-6xl mx-auto\">\n            <h2 class=\"text-4xl lg:text-5xl font-bold text-gray-900 mb-16 text-center\">Featured Work</h2>\n            <div class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-8\">\n                <div class=\"bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition\">\n                    <img src=\"https://images.unsplash.com/photo-1522869635100-ce8e12434e5f?w=400&h=300&fit=crop\" alt=\"Work\" class=\"w-full h-48 object-cover\">\n                    <div class=\"p-6\">\n                        <h3 class=\"text-xl font-bold text-gray-900 mb-2\">Tech Startup Branding</h3>\n                        <p class=\"text-gray-600 text-sm\">Complete brand identity for AI startup</p>\n                    </div>\n                </div>\n                <div class=\"bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition\">\n                    <img src=\"https://images.unsplash.com/photo-1561070791-2526d30994b5?w=400&h=300&fit=crop\" alt=\"Work\" class=\"w-full h-48 object-cover\">\n                    <div class=\"p-6\">\n                        <h3 class=\"text-xl font-bold text-gray-900 mb-2\">Luxury Brand Campaign</h3>\n                        <p class=\"text-gray-600 text-sm\">High-end visual design and photography</p>\n                    </div>\n                </div>\n                <div class=\"bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition\">\n                    <img src=\"https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=400&h=300&fit=crop\" alt=\"Work\" class=\"w-full h-48 object-cover\">\n                    <div class=\"p-6\">\n                        <h3 class=\"text-xl font-bold text-gray-900 mb-2\">App Redesign</h3>\n                        <p class=\"text-gray-600 text-sm\">Complete UI/UX overhaul and redesign</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <section id=\"process\" class=\"py-20 px-4 sm:px-6 lg:px-8 bg-white\">\n        <div class=\"max-w-4xl mx-auto\">\n            <h2 class=\"text-4xl lg:text-5xl font-bold text-gray-900 mb-16 text-center\">Our Creative Process</h2>\n            <div class=\"space-y-8\">\n                <div class=\"bg-white p-8 rounded-xl border-l-4 border-pink-600\">\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Discovery & Strategy</h3>\n                    <p class=\"text-gray-600\">We immerse ourselves in your brand story, understand your audience, and define clear creative direction.</p>\n                </div>\n                <div class=\"bg-white p-8 rounded-xl border-l-4 border-pink-600\">\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Conceptualization</h3>\n                    <p class=\"text-gray-600\">Creative brainstorming and ideation. Exploring multiple directions and concepts.</p>\n                </div>\n                <div class=\"bg-white p-8 rounded-xl border-l-4 border-pink-600\">\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Design & Refinement</h3>\n                    <p class=\"text-gray-600\">Detailed design execution, iteration, and refinement based on your feedback.</p>\n                </div>\n                <div class=\"bg-white p-8 rounded-xl border-l-4 border-pink-600\">\n                    <h3 class=\"text-2xl font-bold text-gray-900 mb-3\">Delivery & Support</h3>\n                    <p class=\"text-gray-600\">Final files in all formats, brand guidelines, and ongoing support.</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <section id=\"testimonials\" class=\"py-20 px-4 sm:px-6 lg:px-8 bg-gray-50\">\n        <div class=\"max-w-4xl mx-auto\">\n            <h2 class=\"text-4xl lg:text-5xl font-bold text-gray-900 mb-16 text-center\">What Clients Say</h2>\n            <div class=\"space-y-8\">\n                <div class=\"bg-white p-8 rounded-xl border border-gray-200\">\n                    <div class=\"flex gap-1 mb-4\">\n                        <i class=\"fas fa-star text-yellow-400\"></i>\n                        <i class=\"fas fa-star text-yellow-400\"></i>\n                        <i class=\"fas fa-star text-yellow-400\"></i>\n                        <i class=\"fas fa-star text-yellow-400\"></i>\n                        <i class=\"fas fa-star text-yellow-400\"></i>\n                    </div>\n                    <p class=\"text-gray-700 mb-4\">\"CreativeStudio completely transformed our brand. The design is stunning and perfectly captures our vision. Highly recommend!\"</p>\n                    <p class=\"font-bold text-gray-900\">Founder, Fashion Brand</p>\n                </div>\n                <div class=\"bg-white p-8 rounded-xl border border-gray-200\">\n                    <div class=\"flex gap-1 mb-4\">\n                        <i class=\"fas fa-star text-yellow-400\"></i>\n                        <i class=\"fas fa-star text-yellow-400\"></i>\n                        <i class=\"fas fa-star text-yellow-400\"></i>\n                        <i class=\"fas fa-star text-yellow-400\"></i>\n                        <i class=\"fas fa-star text-yellow-400\"></i>\n                    </div>\n                    <p class=\"text-gray-700 mb-4\">\"Professional, creative, and collaborative. They understood our brand better than we did!\"</p>\n                    <p class=\"font-bold text-gray-900\">CEO, Tech Company</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <section class=\"py-20 px-4 sm:px-6 lg:px-8 gradient-creative text-white\">\n        <div class=\"max-w-4xl mx-auto text-center\">\n            <h2 class=\"text-4xl lg:text-5xl font-bold mb-6\">Ready to Create Something Beautiful?</h2>\n            <p class=\"text-xl mb-10 opacity-90\">Let's bring your creative vision to life.</p>\n            <button onclick=\"openModal()\" class=\"bg-white text-pink-600 px-10 py-4 rounded-lg font-bold hover:shadow-2xl transition text-lg hover:bg-gray-100\">\n                Start a Conversation\n            </button>\n        </div>\n    </section>\n\n    <footer class=\"bg-gray-900 text-gray-400 py-12 px-4 sm:px-6 lg:px-8\">\n        <div class=\"max-w-6xl mx-auto\">\n            <div class=\"grid md:grid-cols-4 gap-8 mb-8\">\n                <div>\n                    <h4 class=\"text-white font-bold mb-4\">CreativeStudio</h4>\n                    <p class=\"text-sm\">Award-winning branding and design studio.</p>\n                </div>\n                <div>\n                    <h4 class=\"text-white font-bold mb-4\">Services</h4>\n                    <ul class=\"space-y-2 text-sm\">\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Branding</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Design</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">UI/UX</a></li>\n                    </ul>\n                </div>\n                <div>\n                    <h4 class=\"text-white font-bold mb-4\">Company</h4>\n                    <ul class=\"space-y-2 text-sm\">\n                        <li><a href=\"#\" class=\"hover:text-white transition\">About</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Team</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Contact</a></li>\n                    </ul>\n                </div>\n                <div>\n                    <h4 class=\"text-white font-bold mb-4\">Connect</h4>\n                    <ul class=\"space-y-2 text-sm\">\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Instagram</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">Behance</a></li>\n                        <li><a href=\"#\" class=\"hover:text-white transition\">LinkedIn</a></li>\n                    </ul>\n                </div>\n            </div>\n            <div class=\"border-t border-gray-700 pt-8 text-center text-sm\">\n                <p class=\"text-center text-gray-400 text-sm\">Created by <a href=\"https://devweavex.netlify.app/\" class=\"text-gray-300 hover:text-white transition\">DevWeaveX</a> — <a href=\"https://faizyab-hussain.vercel.app/\" class=\"text-gray-300 hover:text-white transition\">Syed Faizyab Hussain</a> & <a href=\"https://www.linkedin.com/in/syed-danish-raza/\" class=\"text-gray-300 hover:text-white transition\">Syed Danish Raza</a></p>\n                <p>&copy; 2026 CreativeStudio. All rights reserved.</p>\n            </div>\n        </div>\n    </footer>\n\n    <div id=\"inquireModal\" class=\"modal-hide fixed inset-0 bg-black bg-opacity-50 z-50 items-center justify-center p-4\">\n        <div class=\"bg-white rounded-xl shadow-2xl max-w-md w-full p-8\">\n            <div class=\"flex justify-between items-center mb-6\">\n                <h3 class=\"text-2xl font-bold text-gray-900\">Let's Create</h3>\n                <button onclick=\"closeModal()\" class=\"text-gray-600 hover:text-gray-900\">\n                    <i class=\"fas fa-times text-2xl\"></i>\n                </button>\n            </div>\n            <form class=\"space-y-4\">\n                <input type=\"text\" placeholder=\"Your Name\" class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-pink-600 focus:ring-1 focus:ring-pink-600\">\n                <input type=\"email\" placeholder=\"Email\" class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-pink-600 focus:ring-1 focus:ring-pink-600\">\n                <input type=\"tel\" placeholder=\"Phone\" class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-pink-600 focus:ring-1 focus:ring-pink-600\">\n                <select class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-pink-600 focus:ring-1 focus:ring-pink-600\">\n                    <option>Project Type</option>\n                    <option>Brand Identity</option>\n                    <option>Graphic Design</option>\n                    <option>UI/UX Design</option>\n                    <option>Rebranding</option>\n                </select>\n                <button type=\"submit\" class=\"w-full gradient-creative text-white py-3 rounded-lg font-bold hover:shadow-lg transition\">\n                    Let's Talk\n                </button>\n            </form>\n        </div>\n    </div>\n\n    <script>\n        function toggleMobileMenu() {\n            document.getElementById('mobileMenu').classList.toggle('hidden');\n        }\n        function openModal() {\n            document.getElementById('inquireModal').classList.add('open');\n        }\n        function closeModal() {\n            document.getElementById('inquireModal').classList.remove('open');\n        }\n        document.addEventListener('click', (e) => {\n            const modal = document.getElementById('inquireModal');\n            if (e.target === modal) closeModal();\n        });\n        document.querySelectorAll('a[href^=\"#\"]').forEach(anchor => {\n            anchor.addEventListener('click', function (e) {\n                e.preventDefault();\n                const target = document.querySelector(this.getAttribute('href'));\n                if (target) {\n                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });\n                    document.getElementById('mobileMenu').classList.add('hidden');\n                }\n            });\n        });\n    </script>\n</body>\n</html>",
