      "summary": "Main template source file imported from Website Template Hub.",
      "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"description\" content=\"MentalWell - Mental health therapy and counseling platform\">\n    <meta name=\"keywords\" content=\"mental health, therapy, counseling, psychology, mental wellness\">\n    <title>MentalWell - Therapy For Everyone</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n    <style>\n        * { font-family: 'Raleway', sans-serif; }\n        h1, h2, h3, h4, h5, h6 { font-family: 'Raleway', sans-serif; font-weight: 800; }\n        .gradient-mental { background: linear-gradient(135deg, #a78bfa 0%, #9333ea 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }\n        .mental-glow { box-shadow: 0 0 50px rgba(167, 139, 250, 0.35); animation: mentalGlow 2.3s ease-in-out infinite; }\n        @keyframes mentalGlow { 0%, 100% { box-shadow: 0 0 50px rgba(167, 139, 250, 0.35); } 50% { box-shadow: 0 0 70px rgba(147, 51, 234, 0.45); } }\n        .modal-hidden { display: none !important; }\n        .modal-hidden.show { display: flex !important; }\n        .therapist-card { transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }\n        .therapist-card:hover { transform: translateY(-10px); box-shadow: 0 25px 70px rgba(167, 139, 250, 0.2); }\n    </style>\n    <!-- Page Loader -->\n    \n</head>\n<body class=\"bg-white\">\n    <!-- Header -->\n    <header class=\"fixed top-0 w-full bg-white z-50 border-b border-gray-100\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex justify-between items-center\">\n            <div class=\"flex items-center gap-3\">\n                <div class=\"w-12 h-12 bg-gradient-to-br from-purple-400 to-purple-600 rounded-xl flex items-center justify-center shadow-lg\">\n                    <i class=\"fas fa-brain text-white text-xl\"></i>\n                </div>\n                <span class=\"text-2xl font-bold text-gray-900\">MentalWell</span>\n            </div>\n            \n            <nav class=\"hidden lg:flex gap-12 items-center\">\n                <a href=\"#therapists\" class=\"text-gray-700 font-medium hover:text-purple-600 transition\">Therapists</a>\n                <a href=\"#services\" class=\"text-gray-700 font-medium hover:text-purple-600 transition\">Services</a>\n                <a href=\"#faq\" class=\"text-gray-700 font-medium hover:text-purple-600 transition\">Help</a>\n                <button onclick=\"openModal()\" class=\"bg-gradient-to-r from-purple-400 to-purple-600 text-white px-6 py-3 rounded-lg font-bold hover:shadow-lg transition shadow-md\">Book Session</button>\n            </nav>\n            \n            <button id=\"mobileToggleBtn\" class=\"lg:hidden text-gray-700\" onclick=\"toggleMobileMenu()\">\n                <i class=\"fas fa-bars text-2xl\"></i>\n            </button>\n        </div>\n        \n        <div id=\"mobileMenu\" class=\"hidden lg:hidden border-t bg-white\">\n            <div class=\"px-4 py-4 space-y-4\">\n                <a href=\"#therapists\" class=\"block text-gray-700 font-medium py-2\">Therapists</a>\n                <a href=\"#services\" class=\"block text-gray-700 font-medium py-2\">Services</a>\n                <a href=\"#faq\" class=\"block text-gray-700 font-medium py-2\">Help</a>\n                <button onclick=\"openModal()\" class=\"w-full bg-gradient-to-r from-purple-400 to-purple-600 text-white px-6 py-3 rounded-lg font-bold\">Book Session</button>\n            </div>\n        </div>\n    </header>\n    \n    <!-- Hero -->\n    <section class=\"pt-32 pb-24 px-4 sm:px-6 lg:px-8 bg-gradient-to-br from-purple-50 to-indigo-50\">\n        <div class=\"max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center\">\n            <div>\n                <div class=\"inline-block bg-purple-100 text-purple-700 px-4 py-2 rounded-full text-sm font-bold mb-8 flex items-center gap-2\">\n                    <i class=\"fas fa-heart\"></i> Mental Health Care\n                </div>\n                <h1 class=\"text-6xl lg:text-7xl font-bold text-gray-900 mb-6 leading-tight\">\n                    Therapy<br/><span class=\"gradient-mental\">Made Accessible</span>\n                </h1>\n                <p class=\"text-xl text-gray-600 mb-8 leading-relaxed\">\n                    Connect with licensed therapists. Confidential counseling. Flexible scheduling. Affordable rates. Start feeling better today.\n                </p>\n                <div class=\"flex flex-col sm:flex-row gap-4 mb-8\">\n                    <button onclick=\"openModal()\" class=\"bg-gradient-to-r from-purple-400 to-purple-600 text-white px-8 py-4 rounded-lg font-bold text-lg hover:shadow-xl transition shadow-lg\">\n                        Book First Session\n                    </button>\n                    <button class=\"border-2 border-purple-300 text-purple-600 px-8 py-4 rounded-lg font-bold hover:bg-purple-50 transition\">\n                        Learn More\n                    </button>\n                </div>\n                <div class=\"flex gap-8 text-sm\">\n                    <div>\n                        <p class=\"text-3xl font-bold text-purple-600\">200K+</p>\n                        <p class=\"text-gray-600\">Sessions Completed</p>\n                    </div>\n                    <div>\n                        <p class=\"text-3xl font-bold text-purple-600\">4.9 <i class=\"fas fa-star text-yellow-500\"></i></p>\n                        <p class=\"text-gray-600\">Average Rating</p>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"hidden lg:flex items-center justify-center\">\n                <div class=\"mental-glow w-80 h-80 bg-gradient-to-br from-purple-100 to-indigo-100 rounded-3xl flex items-center justify-center\">\n                    <i class=\"fas fa-brain text-7xl text-purple-200 opacity-40\"></i>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <!-- Therapists -->\n    <section id=\"therapists\" class=\"py-24 px-4 sm:px-6 lg:px-8 bg-gray-50\">\n        <div class=\"max-w-7xl mx-auto\">\n            <h2 class=\"text-5xl font-bold text-center text-gray-900 mb-4\">Licensed Therapists</h2>\n            <p class=\"text-xl text-gray-600 text-center mb-16\">Find your perfect therapist match</p>\n            \n            <div class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-8\">\n                <div class=\"therapist-card bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm\">\n                    <div class=\"h-48 bg-gradient-to-br from-purple-300 to-purple-500 flex items-center justify-center\">\n                        <i class=\"fas fa-user-nurse text-6xl text-purple-200 opacity-40\"></i>\n                    </div>\n                    <div class=\"p-6\">\n                        <h3 class=\"text-lg font-bold text-gray-900 mb-2\">Dr. Emma Collins</h3>\n                        <p class=\"text-purple-600 font-semibold mb-3\">Licensed Clinical Psychologist</p>\n                        <p class=\"text-gray-600 text-sm mb-4\">Depression, Anxiety, Trauma. 12+ years experience.</p>\n                        <div class=\"flex justify-between items-center\">\n                            <p class=\"text-yellow-500 font-semibold\"><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i> (98)</p>\n                            <button onclick=\"openModal()\" class=\"bg-purple-100 text-purple-700 px-3 py-2 rounded-lg font-bold text-sm hover:bg-purple-200 transition\">\n                                Book\n                            </button>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"therapist-card bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm\">\n                    <div class=\"h-48 bg-gradient-to-br from-indigo-300 to-indigo-500 flex items-center justify-center\">\n                        <i class=\"fas fa-user-nurse text-6xl text-indigo-200 opacity-40\"></i>\n                    </div>\n                    <div class=\"p-6\">\n                        <h3 class=\"text-lg font-bold text-gray-900 mb-2\">Marcus Johnson</h3>\n                        <p class=\"text-purple-600 font-semibold mb-3\">Licensed Therapist</p>\n                        <p class=\"text-gray-600 text-sm mb-4\">Relationships, Stress, Life Transitions. 8+ years.</p>\n                        <div class=\"flex justify-between items-center\">\n                            <p class=\"text-yellow-500 font-semibold\"><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i> (87)</p>\n                            <button onclick=\"openModal()\" class=\"bg-purple-100 text-purple-700 px-3 py-2 rounded-lg font-bold text-sm hover:bg-purple-200 transition\">\n                                Book\n                            </button>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"therapist-card bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm\">\n                    <div class=\"h-48 bg-gradient-to-br from-purple-300 to-indigo-500 flex items-center justify-center\">\n                        <i class=\"fas fa-user-nurse text-6xl text-purple-200 opacity-40\"></i>\n                    </div>\n                    <div class=\"p-6\">\n                        <h3 class=\"text-lg font-bold text-gray-900 mb-2\">Dr. Sofia Martinez</h3>\n                        <p class=\"text-purple-600 font-semibold mb-3\">Psychiatrist</p>\n                        <p class=\"text-gray-600 text-sm mb-4\">ADHD, Bipolar, Medication Management. 15+ yrs.</p>\n                        <div class=\"flex justify-between items-center\">\n                            <p class=\"text-yellow-500 font-semibold\"><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i> (102)</p>\n                            <button onclick=\"openModal()\" class=\"bg-purple-100 text-purple-700 px-3 py-2 rounded-lg font-bold text-sm hover:bg-purple-200 transition\">\n                                Book\n                            </button>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <!-- Services -->\n    <section id=\"services\" class=\"py-24 px-4 sm:px-6 lg:px-8\">\n        <div class=\"max-w-7xl mx-auto\">\n            <h2 class=\"text-5xl font-bold text-center text-gray-900 mb-16\">Our Services</h2>\n            \n            <div class=\"grid md:grid-cols-2 gap-8 max-w-4xl mx-auto\">\n                <div class=\"bg-white rounded-2xl border border-gray-200 p-8 hover:shadow-lg transition\">\n                    <div class=\"w-14 h-14 bg-purple-100 rounded-xl flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-video text-purple-600 text-2xl\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-gray-900 mb-3\">Video Therapy</h3>\n                    <p class=\"text-gray-600 mb-4\">Secure video sessions. Privacy guaranteed. Schedule anytime.</p>\n                    <p class=\"text-purple-600 font-bold\">$60 per session</p>\n                </div>\n                \n                <div class=\"bg-white rounded-2xl border border-gray-200 p-8 hover:shadow-lg transition\">\n                    <div class=\"w-14 h-14 bg-indigo-100 rounded-xl flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-phone text-indigo-600 text-2xl\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-gray-900 mb-3\">Phone Therapy</h3>\n                    <p class=\"text-gray-600 mb-4\">Talk on the phone. Ideal for busy schedules.</p>\n                    <p class=\"text-purple-600 font-bold\">$55 per session</p>\n                </div>\n                \n                <div class=\"bg-white rounded-2xl border border-gray-200 p-8 hover:shadow-lg transition\">\n                    <div class=\"w-14 h-14 bg-purple-100 rounded-xl flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-message text-purple-600 text-2xl\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-gray-900 mb-3\">Messaging</h3>\n                    <p class=\"text-gray-600 mb-4\">Text your therapist. Get support between sessions.</p>\n                    <p class=\"text-purple-600 font-bold\">Unlimited</p>\n                </div>\n                \n                <div class=\"bg-white rounded-2xl border border-gray-200 p-8 hover:shadow-lg transition\">\n                    <div class=\"w-14 h-14 bg-indigo-100 rounded-xl flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-prescription-bottle text-indigo-600 text-2xl\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-gray-900 mb-3\">Medication Support</h3>\n                    <p class=\"text-gray-600 mb-4\">Psychiatric evaluation & medication management.</p>\n                    <p class=\"text-purple-600 font-bold\">$100 per session</p>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <!-- FAQ -->\n    <section id=\"faq\" class=\"py-24 px-4 sm:px-6 lg:px-8 bg-gray-50\">\n        <div class=\"max-w-4xl mx-auto\">\n            <h2 class=\"text-5xl font-bold text-center text-gray-900 mb-16\">Questions?</h2>\n            \n            <div class=\"space-y-6\">\n                <div class=\"bg-white rounded-xl border border-gray-200 p-8\">\n                    <button onclick=\"toggleFaq(0)\" class=\"w-full text-left flex justify-between items-center font-bold text-lg text-gray-900 hover:text-purple-600 transition\">\n                        <span>Is my information confidential?</span>\n                        <i class=\"fas fa-chevron-down transition-transform\" id=\"faq-icon-0\"></i>\n                    </button>\n                    <div id=\"faq-content-0\" class=\"hidden mt-4 text-gray-600 leading-relaxed border-t pt-4\">\n                        Yes, all conversations are private and protected under HIPAA. End-to-end encrypted. We never share your data.\n                    </div>\n                </div>\n                \n                <div class=\"bg-white rounded-xl border border-gray-200 p-8\">\n                    <button onclick=\"toggleFaq(1)\" class=\"w-full text-left flex justify-between items-center font-bold text-lg text-gray-900 hover:text-purple-600 transition\">\n                        <span>How do I get started?</span>\n                        <i class=\"fas fa-chevron-down transition-transform\" id=\"faq-icon-1\"></i>\n                    </button>\n                    <div id=\"faq-content-1\" class=\"hidden mt-4 text-gray-600 leading-relaxed border-t pt-4\">\n                        Answer a brief questionnaire about your needs, browse available therapists, and book your first session. Easy!\n                    </div>\n                </div>\n                \n                <div class=\"bg-white rounded-xl border border-gray-200 p-8\">\n                    <button onclick=\"toggleFaq(2)\" class=\"w-full text-left flex justify-between items-center font-bold text-lg text-gray-900 hover:text-purple-600 transition\">\n                        <span>Do you accept insurance?</span>\n                        <i class=\"fas fa-chevron-down transition-transform\" id=\"faq-icon-2\"></i>\n                    </button>\n                    <div id=\"faq-content-2\" class=\"hidden mt-4 text-gray-600 leading-relaxed border-t pt-4\">\n                        Yes, we work with many insurance plans. We provide documentation for reimbursement. Contact our support team.\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <!-- CTA -->\n    <section class=\"py-24 px-4 sm:px-6 lg:px-8 bg-gradient-to-r from-purple-600 to-indigo-600\">\n        <div class=\"max-w-4xl mx-auto text-center\">\n            <h2 class=\"text-5xl md:text-6xl font-bold text-white mb-6\">Your Mental Health Matters</h2>\n            <p class=\"text-xl text-purple-100 mb-10\">Take the first step today</p>\n            <button onclick=\"openModal()\" class=\"bg-white text-purple-600 px-10 py-4 rounded-lg font-bold text-lg hover:bg-gray-100 transition shadow-xl\">\n                Book Session\n            </button>\n        </div>\n    </section>\n    \n    <!-- Footer -->\n    <footer class=\"bg-gray-900 text-gray-300 py-16 px-4 sm:px-6 lg:px-8\">\n        <div class=\"max-w-7xl mx-auto grid md:grid-cols-5 gap-12 mb-12\">\n            <div>\n                <div class=\"flex items-center gap-3 mb-4\">\n                    <div class=\"w-8 h-8 bg-gradient-to-br from-purple-400 to-purple-600 rounded-lg flex items-center justify-center\">\n                        <i class=\"fas fa-brain text-white text-sm\"></i>\n                    </div>\n                    <span class=\"text-lg font-bold text-white\">MentalWell</span>\n                </div>\n            </div>\n            <div>\n                <h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Services</h4>\n                <ul class=\"space-y-2 text-sm\">\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">Therapy</a></li>\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">Therapists</a></li>\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">Pricing</a></li>\n                </ul>\n            </div>\n            <div>\n                <h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Company</h4>\n                <ul class=\"space-y-2 text-sm\">\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">About</a></li>\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">Blog</a></li>\n                </ul>\n            </div>\n            <div>\n                <h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Support</h4>\n                <ul class=\"space-y-2 text-sm\">\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">Help</a></li>\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">Contact</a></li>\n                </ul>\n            </div>\n            <div>\n                <h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Legal</h4>\n                <ul class=\"space-y-2 text-sm\">\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">Privacy</a></li>\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">Terms</a></li>\n                </ul>\n            </div>\n        </div>\n        \n        <div class=\"border-t border-gray-800 pt-8\">\n            <p class=\"text-center text-gray-400 text-sm\">Created by <a href=\"https://devweavex.netlify.app/\" class=\"text-gray-300 hover:text-white transition\">DevWeaveX</a> — <a href=\"https://faizyab-hussain.vercel.app/\" class=\"text-gray-300 hover:text-white transition\">Syed Faizyab Hussain</a> & <a href=\"https://www.linkedin.com/in/syed-danish-raza/\" class=\"text-gray-300 hover:text-white transition\">Syed Danish Raza</a></p>\n        </div>\n    </footer>\n    \n    <!-- Modal -->\n    <div id=\"modal\" class=\"modal-hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center px-4\">\n        <div class=\"bg-white rounded-2xl shadow-2xl max-w-md w-full\">\n            <div class=\"flex justify-between items-center p-6 border-b border-gray-200\">\n                <h3 class=\"text-2xl font-bold text-gray-900\">Book Session</h3>\n                <button onclick=\"closeModal()\" class=\"text-gray-400 hover:text-gray-600\">\n                    <i class=\"fas fa-times text-xl\"></i>\n                </button>\n            </div>\n            \n            <div class=\"p-6\">\n                <form class=\"space-y-4\">\n                    <div>\n                        <label class=\"block text-sm font-semibold text-gray-700 mb-2\">Select Therapist</label>\n                        <select class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-purple-600 focus:ring-2 focus:ring-purple-100\">\n                            <option>Dr. Emma Collins</option>\n                            <option>Marcus Johnson</option>\n                            <option>Dr. Sofia Martinez</option>\n                        </select>\n                    </div>\n                    \n                    <div>\n                        <label class=\"block text-sm font-semibold text-gray-700 mb-2\">Session Type</label>\n                        <select class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-purple-600 focus:ring-2 focus:ring-purple-100\">\n                            <option>Video ($60)</option>\n                            <option>Phone ($55)</option>\n                        </select>\n                    </div>\n                    \n                    <div>\n                        <label class=\"block text-sm font-semibold text-gray-700 mb-2\">Preferred Time</label>\n                        <input type=\"datetime-local\" class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-purple-600 focus:ring-2 focus:ring-purple-100\">\n                    </div>\n                    \n                    <button type=\"button\" onclick=\"closeModal()\" class=\"w-full bg-gradient-to-r from-purple-400 to-purple-600 text-white py-3 rounded-lg font-bold hover:shadow-lg transition\">\n                        Confirm Booking\n                    </button>\n                </form>\n            </div>\n        </div>\n    </div>\n    \n    <script>\n        function toggleMobileMenu() {\n            document.getElementById('mobileMenu').classList.toggle('hidden');\n        }\n        \n        function openModal() {\n            document.getElementById('modal').classList.add('show');\n            document.body.style.overflow = 'hidden';\n        }\n        \n        function closeModal() {\n            document.getElementById('modal').classList.remove('show');\n            document.body.style.overflow = 'auto';\n        }\n        \n        function toggleFaq(index) {\n            const content = document.getElementById(`faq-content-${index}`);\n            const icon = document.getElementById(`faq-icon-${index}`);\n            \n            content.classList.toggle('hidden');\n            icon.style.transform = content.classList.contains('hidden') ? 'rotate(0)' : 'rotate(180deg)';\n        }\n        \n        window.onclick = function(event) {\n            const modal = document.getElementById('modal');\n            if (event.target === modal) {\n                closeModal();\n            }\n        }\n    </script>\n</body>\n</html>",
      "primary": true
    }
  ],
  "previewHtml": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta name=\"description\" content=\"MentalWell - Mental health therapy and counseling platform\">\n    <meta name=\"keywords\" content=\"mental health, therapy, counseling, psychology, mental wellness\">\n    <title>MentalWell - Therapy For Everyone</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n    <style>\n        * { font-family: 'Raleway', sans-serif; }\n        h1, h2, h3, h4, h5, h6 { font-family: 'Raleway', sans-serif; font-weight: 800; }\n        .gradient-mental { background: linear-gradient(135deg, #a78bfa 0%, #9333ea 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }\n        .mental-glow { box-shadow: 0 0 50px rgba(167, 139, 250, 0.35); animation: mentalGlow 2.3s ease-in-out infinite; }\n        @keyframes mentalGlow { 0%, 100% { box-shadow: 0 0 50px rgba(167, 139, 250, 0.35); } 50% { box-shadow: 0 0 70px rgba(147, 51, 234, 0.45); } }\n        .modal-hidden { display: none !important; }\n        .modal-hidden.show { display: flex !important; }\n        .therapist-card { transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }\n        .therapist-card:hover { transform: translateY(-10px); box-shadow: 0 25px 70px rgba(167, 139, 250, 0.2); }\n    </style>\n    <!-- Page Loader -->\n    \n</head>\n<body class=\"bg-white\">\n    <!-- Header -->\n    <header class=\"fixed top-0 w-full bg-white z-50 border-b border-gray-100\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex justify-between items-center\">\n            <div class=\"flex items-center gap-3\">\n                <div class=\"w-12 h-12 bg-gradient-to-br from-purple-400 to-purple-600 rounded-xl flex items-center justify-center shadow-lg\">\n                    <i class=\"fas fa-brain text-white text-xl\"></i>\n                </div>\n                <span class=\"text-2xl font-bold text-gray-900\">MentalWell</span>\n            </div>\n            \n            <nav class=\"hidden lg:flex gap-12 items-center\">\n                <a href=\"#therapists\" class=\"text-gray-700 font-medium hover:text-purple-600 transition\">Therapists</a>\n                <a href=\"#services\" class=\"text-gray-700 font-medium hover:text-purple-600 transition\">Services</a>\n                <a href=\"#faq\" class=\"text-gray-700 font-medium hover:text-purple-600 transition\">Help</a>\n                <button onclick=\"openModal()\" class=\"bg-gradient-to-r from-purple-400 to-purple-600 text-white px-6 py-3 rounded-lg font-bold hover:shadow-lg transition shadow-md\">Book Session</button>\n            </nav>\n            \n            <button id=\"mobileToggleBtn\" class=\"lg:hidden text-gray-700\" onclick=\"toggleMobileMenu()\">\n                <i class=\"fas fa-bars text-2xl\"></i>\n            </button>\n        </div>\n        \n        <div id=\"mobileMenu\" class=\"hidden lg:hidden border-t bg-white\">\n            <div class=\"px-4 py-4 space-y-4\">\n                <a href=\"#therapists\" class=\"block text-gray-700 font-medium py-2\">Therapists</a>\n                <a href=\"#services\" class=\"block text-gray-700 font-medium py-2\">Services</a>\n                <a href=\"#faq\" class=\"block text-gray-700 font-medium py-2\">Help</a>\n                <button onclick=\"openModal()\" class=\"w-full bg-gradient-to-r from-purple-400 to-purple-600 text-white px-6 py-3 rounded-lg font-bold\">Book Session</button>\n            </div>\n        </div>\n    </header>\n    \n    <!-- Hero -->\n    <section class=\"pt-32 pb-24 px-4 sm:px-6 lg:px-8 bg-gradient-to-br from-purple-50 to-indigo-50\">\n        <div class=\"max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center\">\n            <div>\n                <div class=\"inline-block bg-purple-100 text-purple-700 px-4 py-2 rounded-full text-sm font-bold mb-8 flex items-center gap-2\">\n                    <i class=\"fas fa-heart\"></i> Mental Health Care\n                </div>\n                <h1 class=\"text-6xl lg:text-7xl font-bold text-gray-900 mb-6 leading-tight\">\n                    Therapy<br/><span class=\"gradient-mental\">Made Accessible</span>\n                </h1>\n                <p class=\"text-xl text-gray-600 mb-8 leading-relaxed\">\n                    Connect with licensed therapists. Confidential counseling. Flexible scheduling. Affordable rates. Start feeling better today.\n                </p>\n                <div class=\"flex flex-col sm:flex-row gap-4 mb-8\">\n                    <button onclick=\"openModal()\" class=\"bg-gradient-to-r from-purple-400 to-purple-600 text-white px-8 py-4 rounded-lg font-bold text-lg hover:shadow-xl transition shadow-lg\">\n                        Book First Session\n                    </button>\n                    <button class=\"border-2 border-purple-300 text-purple-600 px-8 py-4 rounded-lg font-bold hover:bg-purple-50 transition\">\n                        Learn More\n                    </button>\n                </div>\n                <div class=\"flex gap-8 text-sm\">\n                    <div>\n                        <p class=\"text-3xl font-bold text-purple-600\">200K+</p>\n                        <p class=\"text-gray-600\">Sessions Completed</p>\n                    </div>\n                    <div>\n                        <p class=\"text-3xl font-bold text-purple-600\">4.9 <i class=\"fas fa-star text-yellow-500\"></i></p>\n                        <p class=\"text-gray-600\">Average Rating</p>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"hidden lg:flex items-center justify-center\">\n                <div class=\"mental-glow w-80 h-80 bg-gradient-to-br from-purple-100 to-indigo-100 rounded-3xl flex items-center justify-center\">\n                    <i class=\"fas fa-brain text-7xl text-purple-200 opacity-40\"></i>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <!-- Therapists -->\n    <section id=\"therapists\" class=\"py-24 px-4 sm:px-6 lg:px-8 bg-gray-50\">\n        <div class=\"max-w-7xl mx-auto\">\n            <h2 class=\"text-5xl font-bold text-center text-gray-900 mb-4\">Licensed Therapists</h2>\n            <p class=\"text-xl text-gray-600 text-center mb-16\">Find your perfect therapist match</p>\n            \n            <div class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-8\">\n                <div class=\"therapist-card bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm\">\n                    <div class=\"h-48 bg-gradient-to-br from-purple-300 to-purple-500 flex items-center justify-center\">\n                        <i class=\"fas fa-user-nurse text-6xl text-purple-200 opacity-40\"></i>\n                    </div>\n                    <div class=\"p-6\">\n                        <h3 class=\"text-lg font-bold text-gray-900 mb-2\">Dr. Emma Collins</h3>\n                        <p class=\"text-purple-600 font-semibold mb-3\">Licensed Clinical Psychologist</p>\n                        <p class=\"text-gray-600 text-sm mb-4\">Depression, Anxiety, Trauma. 12+ years experience.</p>\n                        <div class=\"flex justify-between items-center\">\n                            <p class=\"text-yellow-500 font-semibold\"><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i> (98)</p>\n                            <button onclick=\"openModal()\" class=\"bg-purple-100 text-purple-700 px-3 py-2 rounded-lg font-bold text-sm hover:bg-purple-200 transition\">\n                                Book\n                            </button>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"therapist-card bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm\">\n                    <div class=\"h-48 bg-gradient-to-br from-indigo-300 to-indigo-500 flex items-center justify-center\">\n                        <i class=\"fas fa-user-nurse text-6xl text-indigo-200 opacity-40\"></i>\n                    </div>\n                    <div class=\"p-6\">\n                        <h3 class=\"text-lg font-bold text-gray-900 mb-2\">Marcus Johnson</h3>\n                        <p class=\"text-purple-600 font-semibold mb-3\">Licensed Therapist</p>\n                        <p class=\"text-gray-600 text-sm mb-4\">Relationships, Stress, Life Transitions. 8+ years.</p>\n                        <div class=\"flex justify-between items-center\">\n                            <p class=\"text-yellow-500 font-semibold\"><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i> (87)</p>\n                            <button onclick=\"openModal()\" class=\"bg-purple-100 text-purple-700 px-3 py-2 rounded-lg font-bold text-sm hover:bg-purple-200 transition\">\n                                Book\n                            </button>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"therapist-card bg-white rounded-2xl border border-gray-200 overflow-hidden shadow-sm\">\n                    <div class=\"h-48 bg-gradient-to-br from-purple-300 to-indigo-500 flex items-center justify-center\">\n                        <i class=\"fas fa-user-nurse text-6xl text-purple-200 opacity-40\"></i>\n                    </div>\n                    <div class=\"p-6\">\n                        <h3 class=\"text-lg font-bold text-gray-900 mb-2\">Dr. Sofia Martinez</h3>\n                        <p class=\"text-purple-600 font-semibold mb-3\">Psychiatrist</p>\n                        <p class=\"text-gray-600 text-sm mb-4\">ADHD, Bipolar, Medication Management. 15+ yrs.</p>\n                        <div class=\"flex justify-between items-center\">\n                            <p class=\"text-yellow-500 font-semibold\"><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i><i class=\"fas fa-star\"></i> (102)</p>\n                            <button onclick=\"openModal()\" class=\"bg-purple-100 text-purple-700 px-3 py-2 rounded-lg font-bold text-sm hover:bg-purple-200 transition\">\n                                Book\n                            </button>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <!-- Services -->\n    <section id=\"services\" class=\"py-24 px-4 sm:px-6 lg:px-8\">\n        <div class=\"max-w-7xl mx-auto\">\n            <h2 class=\"text-5xl font-bold text-center text-gray-900 mb-16\">Our Services</h2>\n            \n            <div class=\"grid md:grid-cols-2 gap-8 max-w-4xl mx-auto\">\n                <div class=\"bg-white rounded-2xl border border-gray-200 p-8 hover:shadow-lg transition\">\n                    <div class=\"w-14 h-14 bg-purple-100 rounded-xl flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-video text-purple-600 text-2xl\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-gray-900 mb-3\">Video Therapy</h3>\n                    <p class=\"text-gray-600 mb-4\">Secure video sessions. Privacy guaranteed. Schedule anytime.</p>\n                    <p class=\"text-purple-600 font-bold\">$60 per session</p>\n                </div>\n                \n                <div class=\"bg-white rounded-2xl border border-gray-200 p-8 hover:shadow-lg transition\">\n                    <div class=\"w-14 h-14 bg-indigo-100 rounded-xl flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-phone text-indigo-600 text-2xl\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-gray-900 mb-3\">Phone Therapy</h3>\n                    <p class=\"text-gray-600 mb-4\">Talk on the phone. Ideal for busy schedules.</p>\n                    <p class=\"text-purple-600 font-bold\">$55 per session</p>\n                </div>\n                \n                <div class=\"bg-white rounded-2xl border border-gray-200 p-8 hover:shadow-lg transition\">\n                    <div class=\"w-14 h-14 bg-purple-100 rounded-xl flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-message text-purple-600 text-2xl\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-gray-900 mb-3\">Messaging</h3>\n                    <p class=\"text-gray-600 mb-4\">Text your therapist. Get support between sessions.</p>\n                    <p class=\"text-purple-600 font-bold\">Unlimited</p>\n                </div>\n                \n                <div class=\"bg-white rounded-2xl border border-gray-200 p-8 hover:shadow-lg transition\">\n                    <div class=\"w-14 h-14 bg-indigo-100 rounded-xl flex items-center justify-center mb-6\">\n                        <i class=\"fas fa-prescription-bottle text-indigo-600 text-2xl\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-bold text-gray-900 mb-3\">Medication Support</h3>\n                    <p class=\"text-gray-600 mb-4\">Psychiatric evaluation & medication management.</p>\n                    <p class=\"text-purple-600 font-bold\">$100 per session</p>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <!-- FAQ -->\n    <section id=\"faq\" class=\"py-24 px-4 sm:px-6 lg:px-8 bg-gray-50\">\n        <div class=\"max-w-4xl mx-auto\">\n            <h2 class=\"text-5xl font-bold text-center text-gray-900 mb-16\">Questions?</h2>\n            \n            <div class=\"space-y-6\">\n                <div class=\"bg-white rounded-xl border border-gray-200 p-8\">\n                    <button onclick=\"toggleFaq(0)\" class=\"w-full text-left flex justify-between items-center font-bold text-lg text-gray-900 hover:text-purple-600 transition\">\n                        <span>Is my information confidential?</span>\n                        <i class=\"fas fa-chevron-down transition-transform\" id=\"faq-icon-0\"></i>\n                    </button>\n                    <div id=\"faq-content-0\" class=\"hidden mt-4 text-gray-600 leading-relaxed border-t pt-4\">\n                        Yes, all conversations are private and protected under HIPAA. End-to-end encrypted. We never share your data.\n                    </div>\n                </div>\n                \n                <div class=\"bg-white rounded-xl border border-gray-200 p-8\">\n                    <button onclick=\"toggleFaq(1)\" class=\"w-full text-left flex justify-between items-center font-bold text-lg text-gray-900 hover:text-purple-600 transition\">\n                        <span>How do I get started?</span>\n                        <i class=\"fas fa-chevron-down transition-transform\" id=\"faq-icon-1\"></i>\n                    </button>\n                    <div id=\"faq-content-1\" class=\"hidden mt-4 text-gray-600 leading-relaxed border-t pt-4\">\n                        Answer a brief questionnaire about your needs, browse available therapists, and book your first session. Easy!\n                    </div>\n                </div>\n                \n                <div class=\"bg-white rounded-xl border border-gray-200 p-8\">\n                    <button onclick=\"toggleFaq(2)\" class=\"w-full text-left flex justify-between items-center font-bold text-lg text-gray-900 hover:text-purple-600 transition\">\n                        <span>Do you accept insurance?</span>\n                        <i class=\"fas fa-chevron-down transition-transform\" id=\"faq-icon-2\"></i>\n                    </button>\n                    <div id=\"faq-content-2\" class=\"hidden mt-4 text-gray-600 leading-relaxed border-t pt-4\">\n                        Yes, we work with many insurance plans. We provide documentation for reimbursement. Contact our support team.\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    \n    <!-- CTA -->\n    <section class=\"py-24 px-4 sm:px-6 lg:px-8 bg-gradient-to-r from-purple-600 to-indigo-600\">\n        <div class=\"max-w-4xl mx-auto text-center\">\n            <h2 class=\"text-5xl md:text-6xl font-bold text-white mb-6\">Your Mental Health Matters</h2>\n            <p class=\"text-xl text-purple-100 mb-10\">Take the first step today</p>\n            <button onclick=\"openModal()\" class=\"bg-white text-purple-600 px-10 py-4 rounded-lg font-bold text-lg hover:bg-gray-100 transition shadow-xl\">\n                Book Session\n            </button>\n        </div>\n    </section>\n    \n    <!-- Footer -->\n    <footer class=\"bg-gray-900 text-gray-300 py-16 px-4 sm:px-6 lg:px-8\">\n        <div class=\"max-w-7xl mx-auto grid md:grid-cols-5 gap-12 mb-12\">\n            <div>\n                <div class=\"flex items-center gap-3 mb-4\">\n                    <div class=\"w-8 h-8 bg-gradient-to-br from-purple-400 to-purple-600 rounded-lg flex items-center justify-center\">\n                        <i class=\"fas fa-brain text-white text-sm\"></i>\n                    </div>\n                    <span class=\"text-lg font-bold text-white\">MentalWell</span>\n                </div>\n            </div>\n            <div>\n                <h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Services</h4>\n                <ul class=\"space-y-2 text-sm\">\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">Therapy</a></li>\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">Therapists</a></li>\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">Pricing</a></li>\n                </ul>\n            </div>\n            <div>\n                <h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Company</h4>\n                <ul class=\"space-y-2 text-sm\">\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">About</a></li>\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">Blog</a></li>\n                </ul>\n            </div>\n            <div>\n                <h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Support</h4>\n                <ul class=\"space-y-2 text-sm\">\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">Help</a></li>\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">Contact</a></li>\n                </ul>\n            </div>\n            <div>\n                <h4 class=\"font-bold text-white mb-4 text-sm uppercase\">Legal</h4>\n                <ul class=\"space-y-2 text-sm\">\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">Privacy</a></li>\n                    <li><a href=\"#\" class=\"hover:text-purple-400 transition\">Terms</a></li>\n                </ul>\n            </div>\n        </div>\n        \n        <div class=\"border-t border-gray-800 pt-8\">\n            <p class=\"text-center text-gray-400 text-sm\">Created by <a href=\"https://devweavex.netlify.app/\" class=\"text-gray-300 hover:text-white transition\">DevWeaveX</a> — <a href=\"https://faizyab-hussain.vercel.app/\" class=\"text-gray-300 hover:text-white transition\">Syed Faizyab Hussain</a> & <a href=\"https://www.linkedin.com/in/syed-danish-raza/\" class=\"text-gray-300 hover:text-white transition\">Syed Danish Raza</a></p>\n        </div>\n    </footer>\n    \n    <!-- Modal -->\n    <div id=\"modal\" class=\"modal-hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center px-4\">\n        <div class=\"bg-white rounded-2xl shadow-2xl max-w-md w-full\">\n            <div class=\"flex justify-between items-center p-6 border-b border-gray-200\">\n                <h3 class=\"text-2xl font-bold text-gray-900\">Book Session</h3>\n                <button onclick=\"closeModal()\" class=\"text-gray-400 hover:text-gray-600\">\n                    <i class=\"fas fa-times text-xl\"></i>\n                </button>\n            </div>\n            \n            <div class=\"p-6\">\n                <form class=\"space-y-4\">\n                    <div>\n                        <label class=\"block text-sm font-semibold text-gray-700 mb-2\">Select Therapist</label>\n                        <select class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-purple-600 focus:ring-2 focus:ring-purple-100\">\n                            <option>Dr. Emma Collins</option>\n                            <option>Marcus Johnson</option>\n                            <option>Dr. Sofia Martinez</option>\n                        </select>\n                    </div>\n                    \n                    <div>\n                        <label class=\"block text-sm font-semibold text-gray-700 mb-2\">Session Type</label>\n                        <select class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-purple-600 focus:ring-2 focus:ring-purple-100\">\n                            <option>Video ($60)</option>\n                            <option>Phone ($55)</option>\n                        </select>\n                    </div>\n                    \n                    <div>\n                        <label class=\"block text-sm font-semibold text-gray-700 mb-2\">Preferred Time</label>\n                        <input type=\"datetime-local\" class=\"w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-purple-600 focus:ring-2 focus:ring-purple-100\">\n                    </div>\n                    \n                    <button type=\"button\" onclick=\"closeModal()\" class=\"w-full bg-gradient-to-r from-purple-400 to-purple-600 text-white py-3 rounded-lg font-bold hover:shadow-lg transition\">\n                        Confirm Booking\n                    </button>\n                </form>\n            </div>\n        </div>\n    </div>\n    \n    <script>\n        function toggleMobileMenu() {\n            document.getElementById('mobileMenu').classList.toggle('hidden');\n        }\n        \n        function openModal() {\n            document.getElementById('modal').classList.add('show');\n            document.body.style.overflow = 'hidden';\n        }\n        \n        function closeModal() {\n            document.getElementById('modal').classList.remove('show');\n            document.body.style.overflow = 'auto';\n        }\n        \n        function toggleFaq(index) {\n            const content = document.getElementById(`faq-content-${index}`);\n            const icon = document.getElementById(`faq-icon-${index}`);\n            \n            content.classList.toggle('hidden');\n            icon.style.transform = content.classList.contains('hidden') ? 'rotate(0)' : 'rotate(180deg)';\n        }\n        \n        window.onclick = function(event) {\n            const modal = document.getElementById('modal');\n            if (event.target === modal) {\n                closeModal();\n            }\n        }\n    </script>\n</body>\n</html>",
