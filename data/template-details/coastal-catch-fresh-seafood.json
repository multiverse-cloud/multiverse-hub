order border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-blue-600\">\n                <input type=\"number\" min=\"1\" max=\"12\" placeholder=\"Guests\" required class=\"w-full border border-gray-300 px-4 py-2 rounded focus:outline-none focus:border-blue-600\">\n                <button type=\"submit\" class=\"w-full bg-blue-600 text-white py-2 rounded font-bold hover:bg-blue-700\">Reserve</button>\n                <button type=\"button\" onclick=\"closeBook()\" class=\"w-full border border-gray-300 py-2 rounded font-semibold text-gray-700 hover:bg-gray-50\">Cancel</button>\n            </form>\n        </div>\n    </div>\n\n    <!-- Footer -->\n    <footer class=\"bg-gray-900 text-gray-300 py-8 px-4 text-center\">\n        <p>&copy; 2024 Coastal Catch. Sustainable Seafood. Uncompromising Freshness.</p>\n    </footer>\n\n    <script>\n        function toggleMenu() { const menu = document.getElementById('navMenu'); menu ? menu.classList.toggle('hidden') : null; }\n        function openBook() { document.getElementById('bookModal').classList.remove('hidden'); }\n        function closeBook() { document.getElementById('bookModal').classList.add('hidden'); }\n        function submitBook(e) { e.preventDefault(); alert('Reservation confirmed!'); closeBook(); }\n    </script>\n</body>\n</html>",
